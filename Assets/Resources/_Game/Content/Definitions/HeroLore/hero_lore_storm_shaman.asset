  _canonBio: "\uC57C\uC218\uC871 \uC528\uC871\uC758 \uC5EC\uC131 \uC758\uB840 \uAD00\uC7A5\uC790\uC774\uC790
    \uACF5\uB3D9\uCCB4 \uCE58\uC720\uC0AC. \uC21C\uD658\uC758 \uC228\uACB0(Breath
    of the Cycle) \uC758\uB840\uB97C \uD1B5\uD574 \uC528\uC871\uC758 \uAE30\uC5B5\uACFC
    \uC720\uB300\uB97C \uC720\uC9C0\uD558\uB294 \uC5ED\uD560\uC744 \uB9E1\uACE0 \uC788\uB2E4.
    \uC6D0\uC815\uC5D0 \uD569\uB958\uD55C \uAC83\uC740 \uBB34\uB9AC\uC5D0\uC11C \uB5A8\uC5B4\uC838
    \uB098\uC628 \uC804\uC0AC\uB4E4\uC758 \uC601\uD63C\uC744 \uB3CC\uBCF4\uAE30 \uC704\uD574\uC11C\uB2E4.
    \uADF8\uB140\uB294 Heartforge\uC758 \uACF5\uBA85\uC744 \uBCF8\uB2A5\uC801\uC73C\uB85C
    \uAC10\uC9C0\uD558\uBA70, \uC774\uAC83\uC774 \uC528\uC871 \uC758\uB840\uC758
    \uBFCC\uB9AC\uC640 \uC5F0\uACB0\uB418\uC5B4 \uC788\uB2E4\uB294 \uC9C1\uAC10\uC744
    \uD488\uACE0 \uC788\uB2E4. \uC804\uD22C\uBCF4\uB2E4 \uCE58\uC720\uB97C, \uD30C\uAD34\uBCF4\uB2E4
    \uBCF5\uC6D0\uC744 \uC6B0\uC120\uD558\uBA70, \uC528\uC871\uC758 \uC758\uB840\uAC00
    \uB04A\uC5B4\uC9C0\uC9C0 \uC54A\uB294 \uD55C \uD76C\uB9DD\uC740 \uB0A8\uC544
    \uC788\uB2E4\uACE0 \uBBFF\uB294\uB2E4.\n\n\uC57C\uC218\uC871 \uACF5\uB3D9\uCCB4\uC758
    \uC758\uB840"
