  _canonBio: "\uC6D0\uC815\uB300\uAC00 \uCC98\uC74C\uC73C\uB85C \uC870\uC6B0\uD55C
    \uAC01\uC131 Relicborn. \uACA9\uC790 \uB178\uB4DC \uD558\uB098\uAC00 \uC644\uC804\uD788
    \uD30C\uAD34\uB418\uBA74\uC11C \uAC15\uC81C \uAC01\uC131\uD588\uC73C\uBA70, \uACA9\uC790
    \uBCF5\uC6D0\uC774\uB77C\uB294 \uB300\uC758\uBCF4\uB2E4\uB294 \uB208\uC55E\uC758
    \uB178\uB4DC\uB97C \uC9C0\uD0A4\uACA0\uB2E4\uB294 \uBCF8\uB2A5\uC5D0 \uAC00\uAE5D\uAC8C
    \uC6C0\uC9C1\uC778\uB2E4. \uC5B8\uC5B4 \uC18C\uD1B5\uC774 \uADF9\uD788 \uC81C\uD55C\uC801\uC774\uACE0,
    \uC758\uC0AC \uD45C\uD604\uC740 \uAC70\uC758 \uD589\uB3D9\uC73C\uB85C\uB9CC \uC774\uB8E8\uC5B4\uC9C4\uB2E4.
    \uC6D0\uC815\uB300\uB97C \uBCF4\uD638\uD558\uB294 \uC774\uC720\uB97C \uB9D0\uB85C
    \uC124\uBA85\uD55C \uC801\uC740 \uC5C6\uC9C0\uB9CC, \uC704\uAE30 \uC0C1\uD669\uC5D0\uC11C
    \uBC18\uBCF5\uC801\uC73C\uB85C \uC804\uC5F4\uC5D0 \uC11C\uB294 \uD589\uC704 \uC790\uCCB4\uAC00
    \uC2E0\uB8B0\uC758 \uC99D\uBA85\uC774 \uB41C\uB2E4. \uB9D0\uC774 \uC544\uB2C8\uB77C
    \uBAB8\uC73C\uB85C \uC99D\uBA85\uD558\uB294 \uC874\uC7AC\uC774\uBA70, Relicborn\uC774
    \uC801\uC774 \uC544\uB2D8\uC744 \uCC98\uC74C\uC73C\uB85C \uBCF4\uC5EC\uC8FC\uB294
    \uC0AC\uB840\uB2E4.\n\nRelicborn\uC758 \uBB38\uC9C0\uAE30"
