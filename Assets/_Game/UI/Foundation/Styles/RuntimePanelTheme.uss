.screen {
    flex-grow: 1;
    padding-left: var(--space-5);
    padding-right: var(--space-5);
    padding-top: var(--space-5);
    padding-bottom: var(--space-4);
    background-color: var(--color-bg);
    color: var(--color-text);
}

.screen__topbar {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-4);
}

.screen__title {
    font-size: var(--font-size-xl);
    unity-font-style: bold;
    color: var(--color-text);
}

.screen__locale {
    flex-direction: row;
    align-items: center;
}

.screen__locale > Button {
    margin-left: var(--space-2);
}

.screen__locale-status {
    min-width: 120px;
    font-size: var(--font-size-s);
    color: var(--color-text-muted);
}

.screen__toolbar {
    flex-direction: row;
    align-items: center;
}

.screen__toolbar > * {
    margin-left: var(--space-2);
}

.screen__body {
    flex-grow: 1;
    flex-direction: row;
}

.screen__body > * {
    margin-right: var(--space-4);
}

.screen__column {
    flex-grow: 1;
}

.screen__column > * {
    margin-bottom: var(--space-3);
}

.panel {
    background-color: var(--color-surface);
    border-top-left-radius: var(--radius-m);
    border-top-right-radius: var(--radius-m);
    border-bottom-left-radius: var(--radius-m);
    border-bottom-right-radius: var(--radius-m);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: var(--color-panel-border);
    border-right-color: var(--color-panel-border);
    border-top-color: var(--color-panel-border);
    border-bottom-color: var(--color-panel-border);
    padding-left: var(--space-4);
    padding-right: var(--space-4);
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
}

.panel--dense {
    padding-left: var(--space-3);
    padding-right: var(--space-3);
    padding-top: var(--space-3);
    padding-bottom: var(--space-3);
}

.panel__title {
    margin-bottom: var(--space-2);
    font-size: var(--font-size-l);
    unity-font-style: bold;
}

.panel__text {
    white-space: normal;
    font-size: var(--font-size-m);
    color: var(--color-text);
}

.panel__text--muted {
    color: var(--color-text-muted);
}

.help-strip {
    flex-direction: row;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-3);
    background-color: rgba(217, 144, 61, 0.14);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(217, 144, 61, 0.35);
    border-right-color: rgba(217, 144, 61, 0.35);
    border-top-color: rgba(217, 144, 61, 0.35);
    border-bottom-color: rgba(217, 144, 61, 0.35);
}

.help-strip__body {
    flex-grow: 1;
    margin-right: var(--space-3);
    color: var(--color-text);
}

.help-strip__dismiss {
    min-width: 72px;
}

.action-row {
    flex-direction: row;
    flex-wrap: wrap;
}

.action-row > Button {
    margin-right: var(--space-2);
    margin-bottom: var(--space-2);
}

.ui-button {
    min-height: 34px;
    padding-left: var(--space-3);
    padding-right: var(--space-3);
    border-top-left-radius: var(--radius-s);
    border-top-right-radius: var(--radius-s);
    border-bottom-left-radius: var(--radius-s);
    border-bottom-right-radius: var(--radius-s);
    background-color: var(--color-surface-alt);
    color: var(--color-text);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(255, 255, 255, 0.08);
    border-right-color: rgba(255, 255, 255, 0.08);
    border-top-color: rgba(255, 255, 255, 0.08);
    border-bottom-color: rgba(255, 255, 255, 0.08);
}

.ui-button:hover {
    background-color: rgb(40, 52, 72);
}

.ui-button--accent {
    background-color: var(--color-accent);
    color: rgb(22, 15, 9);
}

.ui-button--warning {
    background-color: rgb(84, 59, 28);
    color: rgb(255, 241, 222);
}

.ui-button--danger {
    background-color: rgb(96, 39, 36);
}

.ui-button--debug {
    background-color: rgba(74, 80, 97, 0.85);
    color: var(--color-text-muted);
}

.card-row {
    flex-direction: row;
}

.card-row > * {
    margin-right: var(--space-3);
}

.card {
    flex-grow: 1;
    min-width: 0;
    background-color: rgba(255, 255, 255, 0.03);
    border-top-left-radius: var(--radius-m);
    border-top-right-radius: var(--radius-m);
    border-bottom-left-radius: var(--radius-m);
    border-bottom-right-radius: var(--radius-m);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(255, 255, 255, 0.08);
    border-right-color: rgba(255, 255, 255, 0.08);
    border-top-color: rgba(255, 255, 255, 0.08);
    border-bottom-color: rgba(255, 255, 255, 0.08);
    padding-left: var(--space-3);
    padding-right: var(--space-3);
    padding-top: var(--space-3);
    padding-bottom: var(--space-3);
}

.card > * {
    margin-bottom: var(--space-2);
}

.card__title {
    unity-font-style: bold;
    font-size: var(--font-size-l);
}

.card__body {
    flex-grow: 1;
    white-space: normal;
    color: var(--color-text-muted);
}

.status-bar {
    margin-top: var(--space-3);
    padding-top: var(--space-2);
    border-top-width: 1px;
    border-top-color: rgba(255, 255, 255, 0.08);
    color: var(--color-text-muted);
}

.action-group {
    margin-bottom: var(--space-2);
}

.action-group__title {
    margin-bottom: var(--space-2);
    font-size: var(--font-size-s);
    color: var(--color-text-muted);
    unity-font-style: bold;
    text-transform: uppercase;
}

.action-group--debug .action-group__title {
    color: rgba(180, 191, 214, 0.7);
}

.action-group--warning .action-group__title {
    color: rgb(231, 188, 122);
}

.deploy-grid {
    flex-direction: row;
    flex-wrap: wrap;
}

.deploy-grid > Button {
    margin-right: var(--space-2);
    margin-bottom: var(--space-2);
}

.deploy-button {
    width: 148px;
    min-height: 48px;
    white-space: normal;
}

.node-card {
    width: 150px;
}

.node-card--current {
    border-left-color: rgba(217, 144, 61, 0.9);
    border-right-color: rgba(217, 144, 61, 0.9);
    border-top-color: rgba(217, 144, 61, 0.9);
    border-bottom-color: rgba(217, 144, 61, 0.9);
}

.node-card--selected {
    background-color: rgba(92, 162, 219, 0.16);
}

.node-card--completed {
    background-color: rgba(77, 176, 105, 0.16);
}

.battle-track {
    height: 18px;
    background-color: rgba(255, 255, 255, 0.08);
    border-top-left-radius: 9px;
    border-top-right-radius: 9px;
    border-bottom-left-radius: 9px;
    border-bottom-right-radius: 9px;
}

.battle-track__fill {
    height: 100%;
    width: 0%;
    background-color: var(--color-accent);
    border-top-left-radius: 9px;
    border-bottom-left-radius: 9px;
}

.battle-settings {
    position: absolute;
    top: 68px;
    right: 24px;
    width: 260px;
}

.battle-settings > * {
    margin-bottom: var(--space-2);
}

.battle-shell__main {
    flex-grow: 1;
    flex-direction: row;
}

.battle-shell__main > * {
    margin-right: var(--space-4);
}

.battle-shell__center {
    flex-grow: 1;
}

.battle-shell__center > * {
    margin-bottom: var(--space-3);
}

.battle-shell__side {
    width: 300px;
}

.battle-shell__side > * {
    margin-bottom: var(--space-3);
}

.battle-shell__status {
    color: var(--color-text-muted);
}

/* =============================================================
   v0.2 FOUNDATION UTILITY CLASSES
   claude.ai/design Foundation pack v0.2 mock 톤(JRPG + 원신 +
   유니콘 오버로드)을 atom/molecule level에 일관 적용하기 위한
   utility class 묶음.
   소스오브트루스: docs/02_design/ui/handoff/foundation-pack-v0.2/
   ============================================================= */

/* --- Vellum 카드 --- */
/* 양피지 위 잉크 톤. card / panel / modal body에 base로 적용 */
.sm-vellum-card {
    background-color: var(--sm-bg-1);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: var(--sm-line-1);
    border-right-color: var(--sm-line-1);
    border-top-color: var(--sm-line-1);
    border-bottom-color: var(--sm-line-1);
    border-top-left-radius: var(--sm-r-md);
    border-top-right-radius: var(--sm-r-md);
    border-bottom-left-radius: var(--sm-r-md);
    border-bottom-right-radius: var(--sm-r-md);
    color: var(--sm-ink-1);
    padding-left: var(--sm-s-3);
    padding-right: var(--sm-s-3);
    padding-top: var(--sm-s-3);
    padding-bottom: var(--sm-s-3);
}

/* --- Ornate frame: gold corner cap이 들어가는 큰 frame --- */
/* card / panel header 등 강조 surface에. Gold line 강조. */
.sm-ornate-frame {
    background-color: var(--sm-bg-2);
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: var(--sm-gold-500);
    border-right-color: var(--sm-gold-500);
    border-top-color: var(--sm-gold-400);
    border-bottom-color: var(--sm-gold-500);
    border-top-left-radius: var(--sm-r-md);
    border-top-right-radius: var(--sm-r-md);
    border-bottom-left-radius: var(--sm-r-md);
    border-bottom-right-radius: var(--sm-r-md);
}

/* --- Gold corner cap (L-bracket) --- */
/* card / button 모서리에 작은 gold L-bracket overlay.
   기본 single-bracket: border-top + border-left만 두고 나머지는 0
   으로 L 모양. position 별 modifier로 4 방향 처리.
   사용: 부모에 position:relative 또는 absolute,
   <ve class="sm-corner-cap sm-corner-cap--tl" /> 식 4개 자식으로. */
.sm-corner-cap {
    position: absolute;
    width: 14px;
    height: 14px;
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    border-left-color: var(--sm-gold-300);
    border-right-color: var(--sm-gold-300);
    border-top-color: var(--sm-gold-300);
    border-bottom-color: var(--sm-gold-300);
}

.sm-corner-cap--tl {
    top: -1px;
    left: -1px;
    border-top-width: 2px;
    border-left-width: 2px;
}

.sm-corner-cap--tr {
    top: -1px;
    right: -1px;
    border-top-width: 2px;
    border-right-width: 2px;
}

.sm-corner-cap--bl {
    bottom: -1px;
    left: -1px;
    border-bottom-width: 2px;
    border-left-width: 2px;
}

.sm-corner-cap--br {
    bottom: -1px;
    right: -1px;
    border-bottom-width: 2px;
    border-right-width: 2px;
}

/* 작은 diamond gem inlay — corner cap 안쪽에 함께 배치하면
   L-bracket + diamond accent 조합. transform rotate로 45도. */
.sm-diamond-inlay {
    position: absolute;
    width: 4px;
    height: 4px;
    background-color: var(--sm-gold-200);
    rotate: 45deg;
}

.sm-diamond-inlay--tl {
    top: 4px;
    left: 4px;
}

.sm-diamond-inlay--tr {
    top: 4px;
    right: 4px;
}

.sm-diamond-inlay--bl {
    bottom: 4px;
    left: 4px;
}

.sm-diamond-inlay--br {
    bottom: 4px;
    right: 4px;
}

/* --- Vine flourish on hover --- */
/* primary button hover 시 좌우 양쪽 부드럽게 reveal.
   Unity USS는 ::before 미지원. children VisualElement에
   class를 주고 transition opacity로 처리. */
.sm-vine-flourish {
    opacity: 0;
    transition-property: opacity;
    transition-duration: var(--sm-t-snap);
    transition-timing-function: ease-out;
}

.sm-vine-flourish-host:hover .sm-vine-flourish {
    opacity: 1;
}

/* --- Family-tint rib --- */
/* card 상단 띠. archetype 가족 색을 띠로 표시.
   children에 <ve class="sm-family-tint-rib sm-family-tint-rib--vanguard" />
   식으로 modifier class 적용. */
.sm-family-tint-rib {
    height: 4px;
    width: 100%;
}

.sm-family-tint-rib--beastkin {
    background-color: var(--sm-fam-beastkin);
}

.sm-family-tint-rib--vanguard {
    background-color: var(--sm-fam-vanguard);
}

.sm-family-tint-rib--striker {
    background-color: var(--sm-fam-striker);
}

.sm-family-tint-rib--ranger {
    background-color: var(--sm-fam-ranger);
}

.sm-family-tint-rib--mystic {
    background-color: var(--sm-fam-mystic);
}

/* --- Jewel duotone — rarity --- */
/* tier dot / item slot border / portrait frame에 적용.
   common(parchment) / rare(sapphire) / epic(amethyst→flame). */
.sm-jewel-duotone {
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    background-color: var(--sm-rare-common);
    border-left-color: var(--sm-rare-common-deep);
    border-right-color: var(--sm-rare-common-deep);
    border-top-color: var(--sm-rare-common-deep);
    border-bottom-color: var(--sm-rare-common-deep);
}

.sm-jewel-common {
    background-color: var(--sm-rare-common);
    border-left-color: var(--sm-rare-common-deep);
    border-right-color: var(--sm-rare-common-deep);
    border-top-color: var(--sm-rare-common-deep);
    border-bottom-color: var(--sm-rare-common-deep);
}

.sm-jewel-rare {
    background-color: var(--sm-rare-rare);
    border-left-color: var(--sm-rare-rare-deep);
    border-right-color: var(--sm-rare-rare-deep);
    border-top-color: var(--sm-rare-rare-deep);
    border-bottom-color: var(--sm-rare-rare-deep);
}

.sm-jewel-epic {
    background-color: var(--sm-rare-epic);
    border-left-color: var(--sm-rare-epic-deep);
    border-right-color: var(--sm-rare-epic-deep);
    border-top-color: var(--sm-rare-epic-deep);
    border-bottom-color: var(--sm-rare-epic-deep);
}

.sm-jewel-duotone--common {
    background-color: var(--sm-rare-common);
    border-left-color: var(--sm-rare-common-deep);
    border-right-color: var(--sm-rare-common-deep);
    border-top-color: var(--sm-rare-common-deep);
    border-bottom-color: var(--sm-rare-common-deep);
}

.sm-jewel-duotone--rare {
    background-color: var(--sm-rare-rare);
    border-left-color: var(--sm-rare-rare-deep);
    border-right-color: var(--sm-rare-rare-deep);
    border-top-color: var(--sm-rare-rare-deep);
    border-bottom-color: var(--sm-rare-rare-deep);
}

.sm-jewel-duotone--epic {
    background-color: var(--sm-rare-epic);
    border-left-color: var(--sm-rare-epic-2);
    border-right-color: var(--sm-rare-epic-deep);
    border-top-color: var(--sm-rare-epic-2);
    border-bottom-color: var(--sm-rare-epic-deep);
}

/* --- State overlay --- */
/* card / portrait에 상태 표시 overlay. */
.sm-state-locked-overlay {
    background-color: rgba(107, 110, 133, 0.55);
}

.sm-state-ko-overlay {
    background-color: rgba(138, 138, 152, 0.62);
}

.sm-state-injured-overlay {
    background-color: rgba(182, 51, 74, 0.18);
}

.sm-state-selected-glow {
    border-left-color: var(--sm-gold-300);
    border-right-color: var(--sm-gold-300);
    border-top-color: var(--sm-gold-300);
    border-bottom-color: var(--sm-gold-300);
}

/* --- Headline --- */
/* SURVIVAL · MANAGER 식 메타 헤드라인. Cinzel display 톤. */
.sm-headline {
    font-size: 32px;
    -unity-font-style: bold;
    color: var(--sm-gold-200);
    letter-spacing: 4px;
}

.sm-headline--lg {
    font-size: 46px;
}

/* --- Eyebrow caption --- */
/* 헤드라인 위 작은 dev tag (mono). */
.sm-eyebrow {
    font-size: 11px;
    color: var(--sm-gold-300);
    -unity-font-style: bold;
    letter-spacing: 2px;
}

/* =============================================================
   ORNATE DETAIL — 이중 라인 / 스티치 / vine
   USS만으로 가능한 한도에서 mock의 frame 정교화 흡수.
   Unity USS는 border-image / box-shadow 미지원이라
   inner element를 child로 두는 layering 패턴.
   본격 ornate(SVG vine flourish, gradient corner glow, embossed
   relief)는 별도 image asset 필요 (5/8 cycle 후 본격).
   ============================================================= */

/* --- Double gold line --- */
/* ornate-frame 안쪽에 한 줄 더. 부모에 sm-ornate-frame 두고
   바로 안쪽 child VisualElement에 sm-inner-line. 1px gap. */
.sm-inner-line {
    position: absolute;
    top: 4px;
    left: 4px;
    right: 4px;
    bottom: 4px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: var(--sm-gold-500);
    border-right-color: var(--sm-gold-500);
    border-top-color: var(--sm-gold-500);
    border-bottom-color: var(--sm-gold-500);
}

/* --- Stitched hairline --- */
/* 양피지 위 스티치 hint. divider 또는 panel 가장자리에. */
.sm-stitch-h {
    height: 1px;
    background-color: var(--sm-gold-500);
    opacity: 0.55;
}

.sm-stitch-h--accent {
    background-color: var(--sm-gold-300);
    opacity: 0.85;
}

.sm-stitch-v {
    width: 1px;
    background-color: var(--sm-gold-500);
    opacity: 0.55;
}

.sm-stitch-v--accent {
    width: 1px;
    background-color: var(--sm-gold-300);
    opacity: 0.85;
}

/* --- Vine flourish placeholder --- */
/* 진짜 vine curve는 SVG asset 필요. USS 한도에서 단순화:
   thin gold line 양쪽 + 가운데 작은 diamond. parent에 두고
   children으로 line + dot 4개 layout. 임시 ornament. */
.sm-vine-line {
    height: 1px;
    background-color: var(--sm-gold-300);
    opacity: 0.7;
}

.sm-vine-dot {
    width: 3px;
    height: 3px;
    background-color: var(--sm-gold-200);
    rotate: 45deg;
}

/* --- Center gem inlay (family-tint rib 위 보조) --- */
/* family-tint-rib 중앙에 작은 gem. 4px diamond + family color. */
.sm-rib-gem {
    width: 6px;
    height: 6px;
    background-color: var(--sm-gold-200);
    rotate: 45deg;
}

/* --- Inset shadow placeholder --- */
/* 진짜 inner shadow는 USS 미지원. inner element를 어둡게 두고
   가장자리만 살짝 비치게. card 깊이감 hint. */
.sm-inner-shade {
    position: absolute;
    top: 1px;
    left: 1px;
    right: 1px;
    bottom: 1px;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(0, 0, 0, 0.18);
    border-right-color: rgba(0, 0, 0, 0.18);
    border-top-color: rgba(0, 0, 0, 0.28);
    border-bottom-color: rgba(0, 0, 0, 0.10);
}

/* --- Gradient stripe (linear emulation) --- */
/* USS는 gradient 미지원. 단색 layered 분할로 emulation.
   3 child element로 gold-100 / gold-200 / gold-300 단계 — 또는
   반복 사용. 임시. */
.sm-stripe-gold-100 { background-color: var(--sm-gold-100); }
.sm-stripe-gold-200 { background-color: var(--sm-gold-200); }
.sm-stripe-gold-300 { background-color: var(--sm-gold-300); }
.sm-stripe-gold-400 { background-color: var(--sm-gold-400); }
.sm-stripe-gold-500 { background-color: var(--sm-gold-500); }

/* =============================================================
   V1 MODAL FRAME — 시안 갤러리 (8 Town Preview surface)
   parchment / ceremony / modal-small mood baseline.
   각 Preview USS는 local .xxx-frame / .xxx-frame__corner / .xxx-cta
   rule 대신 본 atom 참조. 토큰은 ThemeTokens.uss "MOOD BASELINE" 절.
   ============================================================= */

/* --- Backdrop layer template ---
   풀스크린 backdrop image + dim overlay. image url은 surface USS에서
   설정 (surface마다 backdrop이 다를 수 있음 — town 외 다른 hub 등). */
.sm-backdrop {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    -unity-background-scale-mode: scale-and-crop;
}

.sm-backdrop-dim {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-color: var(--sm-backdrop-dim);
}

/* --- Modal frame (centered absolute, gold border + corner cap host) ---
   inset (left/right/top/bottom)은 surface 별로 변하므로 atom에서 lock
   안 함. surface USS에서 position offset 지정. 본 atom은 mood/trim만 통일. */
.sm-modal-frame {
    position: absolute;
    background-color: var(--sm-frame-ceremony-bg);
    border-left-width: var(--sm-frame-trim-w);
    border-right-width: var(--sm-frame-trim-w);
    border-top-width: var(--sm-frame-trim-w);
    border-bottom-width: var(--sm-frame-trim-w);
    border-left-color: var(--sm-frame-trim-color);
    border-right-color: var(--sm-frame-trim-color);
    border-top-color: var(--sm-frame-trim-color);
    border-bottom-color: var(--sm-frame-trim-color);
}

.sm-modal-frame--parchment {
    background-color: var(--sm-frame-parchment-bg);
}

.sm-modal-frame--ceremony {
    background-color: var(--sm-frame-ceremony-bg);
}

.sm-modal-frame--modal-small {
    background-color: var(--sm-frame-modal-bg);
    border-left-width: var(--sm-frame-trim-w-small);
    border-right-width: var(--sm-frame-trim-w-small);
    border-top-width: var(--sm-frame-trim-w-small);
    border-bottom-width: var(--sm-frame-trim-w-small);
}

/* --- Frame corner ornament (vine SVG @ 4 corners, mirrored) ---
   audit §4.2 frame 합성 전환: 기존 flat gold square → ornament-corner-vine.svg
   (vector, 해상도 독립). HeroPortraitCard .sm-hpc__cornament와 같은 패턴 —
   default orientation = top-left, 나머지 3코너는 USS scale로 미러. tint는 gold token. */
.sm-frame-corner-cap {
    position: absolute;
    width: var(--sm-frame-corner-size);
    height: var(--sm-frame-corner-size);
    background-image: url("project://database/Assets/_Game/UI/Foundation/Ornaments/ornament-corner-vine.svg");
    -unity-background-image-tint-color: var(--sm-frame-corner-color);
}

.sm-frame-corner-cap--small {
    width: var(--sm-frame-corner-size-small);
    height: var(--sm-frame-corner-size-small);
}

.sm-frame-corner-cap--tl { top: -3px; left: -3px; }
.sm-frame-corner-cap--tr { top: -3px; right: -3px; scale: -1 1; }
.sm-frame-corner-cap--bl { bottom: -3px; left: -3px; scale: 1 -1; }
.sm-frame-corner-cap--br { bottom: -3px; right: -3px; scale: -1 -1; }

.sm-frame-corner-cap--small.sm-frame-corner-cap--tl { top: -2px; left: -2px; }
.sm-frame-corner-cap--small.sm-frame-corner-cap--tr { top: -2px; right: -2px; }
.sm-frame-corner-cap--small.sm-frame-corner-cap--bl { bottom: -2px; left: -2px; }
.sm-frame-corner-cap--small.sm-frame-corner-cap--br { bottom: -2px; right: -2px; }

/* --- CTA button (4 height tier × 3 tone variant) ---
   8 Preview surface가 같은 height + border width 규약을 공유.
   tone: primary(gold)/secondary(navy)/utility(blue).
   surface 별 추가 padding/glyph은 local rule로. */
.sm-cta {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    /* embossed border: 밝은 top + 어두운 bottom = 입체감 + 두께 차이로 raster gradient 흉내 */
    border-top-width: 1px;
    border-left-width: 1.5px;
    border-right-width: 1.5px;
    border-bottom-width: 2.5px;
    -unity-font-style: bold;
    letter-spacing: 1px;
    transition-property: background-color, scale, translate, border-top-color, border-bottom-color;
    transition-duration: 120ms;
    transition-timing-function: ease-out;
}

.sm-cta:hover {
    scale: 1.03 1.03;
    border-top-color: var(--sm-gold-100);
}

.sm-cta:active {
    scale: 0.97 0.97;
    translate: 0 1px;
    border-top-width: 2px;
    border-bottom-width: 1px;
}

.sm-cta:disabled {
    opacity: 0.45;
}

.sm-cta--inline { height: var(--sm-cta-h-inline); padding-left: var(--sm-s-3); padding-right: var(--sm-s-3); }
.sm-cta--md     { height: var(--sm-cta-h-md);     padding-left: var(--sm-s-4); padding-right: var(--sm-s-4); }
.sm-cta--lg     { height: var(--sm-cta-h-lg);     padding-left: var(--sm-s-5); padding-right: var(--sm-s-5); }
.sm-cta--hero   { height: var(--sm-cta-h-hero);   padding-left: var(--sm-s-6); padding-right: var(--sm-s-6); }

/* primary — gold filled, deep amber rim. JRPG hero CTA 톤. */
.sm-cta--primary {
    background-color: rgba(200, 147, 42, 0.95);
    border-top-color: var(--sm-gold-100);
    border-left-color: var(--sm-gold-300);
    border-right-color: var(--sm-gold-300);
    border-bottom-color: var(--sm-gold-500);
    color: rgb(31, 19, 9);
}

.sm-cta--primary:hover {
    background-color: rgba(230, 183, 81, 0.98);
    border-bottom-color: var(--sm-gold-400);
}

/* secondary — navy parchment + gold trim. utility/menu CTA. */
.sm-cta--secondary {
    background-color: rgba(38, 45, 84, 0.92);
    border-top-color: var(--sm-gold-200);
    border-left-color: var(--sm-gold-400);
    border-right-color: var(--sm-gold-400);
    border-bottom-color: var(--sm-gold-500);
    color: var(--sm-vellum);
}

.sm-cta--secondary:hover {
    background-color: rgba(54, 64, 116, 0.95);
    border-top-color: var(--sm-gold-100);
}

/* utility — sapphire blue + gold trim. debug/Quick Battle. */
.sm-cta--utility {
    background-color: rgba(74, 114, 184, 0.92);
    border-top-color: var(--sm-gold-200);
    border-left-color: var(--sm-gold-400);
    border-right-color: var(--sm-gold-400);
    border-bottom-color: var(--sm-fam-vanguard-deep);
    color: var(--sm-ink-0);
}

.sm-cta--utility:hover {
    background-color: rgba(95, 140, 215, 0.95);
    border-top-color: var(--sm-gold-100);
}

/* --- Frame divider hairline ---
   ceremony header bottom / column hairline (gold tint). parchment은
   warm shadow gold tint. surface USS에서 border-bottom / border-right
   에 사용. */
.sm-frame-divider-ceremony {
    border-bottom-color: var(--sm-frame-divider-ceremony);
}

.sm-frame-divider-parchment {
    border-bottom-color: var(--sm-frame-divider-parchment);
}

/* =============================================================
   콘솔급 UI texture layer — 9-slice frame / ornament / glow
   town-profile-binding-workflow.md "UI 품질 기준" 절 참조.
   flat color border 위에 ornate gold trim 이미지를 overlay해서
   JRPG 콘솔급 엣지 마감. mood bg color는 그대로 두고, texture는
   absolute-fill 자식 element로 얹는다 (border-image 미지원 우회).

   art-pipeline 원본: Foundation/Sprites/Frame/*.png
   (panel_card_frame_9slice / ornament_divider_warm_gold / glow_halo_warm_gold).
   panel_modal_frame_9slice는 audit §4.2로 폐기 — modal frame은 vine SVG 코너
   (.sm-frame-corner-cap) + sm-modal-frame border/bg 합성 구조로 전환.
   ============================================================= */

/* --- Modal frame inner edge accent ---
   audit §4.2: 기존 panel_modal_frame_9slice.png 9-slice는 raster 코너 blur +
   중앙 baked parchment가 mood color와 충돌 → 폐기. 합성 구조로 전환 —
   코너 = sm-frame-corner-cap vine SVG / 엣지 trim = sm-modal-frame border /
   중앙 = sm-modal-frame mood bg color. 본 layer는 outer trim 안쪽 얇은 gold
   hairline만 — 깊이 accent (raster blur 없이 ceremony 마감). picking-mode ignore. */
.sm-modal-frame__texture {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    border-left-width: 1px;
    border-right-width: 1px;
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-color: rgba(230, 183, 81, 0.20);
    border-right-color: rgba(230, 183, 81, 0.20);
    border-top-color: rgba(230, 183, 81, 0.20);
    border-bottom-color: rgba(230, 183, 81, 0.20);
}

/* --- 9-slice card frame texture overlay ---
   card / panel 단위 ornate border. modal frame보다 얇은 trim. */
.sm-card-frame__texture {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background-image: url("project://database/Assets/_Game/UI/Foundation/Sprites/Frame/panel_card_frame_9slice.png");
    -unity-slice-left: 48;
    -unity-slice-top: 48;
    -unity-slice-right: 48;
    -unity-slice-bottom: 48;
    -unity-slice-scale: 0.5;
}

/* --- Ornament divider ---
   header bottom / section 구분에 쓰는 warm gold ornament 띠.
   flat hairline 대신 image. 높이는 surface USS에서 조정. */
.sm-ornament-divider {
    height: 10px;
    background-image: url("project://database/Assets/_Game/UI/Foundation/Sprites/Frame/ornament_divider_warm_gold.png");
    -unity-background-scale-mode: scale-to-fit;
}

/* --- Glow halo ---
   selected / keystone / hero portrait 등 강조 element 뒤에 까는
   warm gold glow. absolute-fill 또는 고정 크기 자식. picking ignore. */
.sm-glow-halo {
    position: absolute;
    background-image: url("project://database/Assets/_Game/UI/Foundation/Sprites/Frame/glow_halo_warm_gold.png");
    -unity-background-scale-mode: scale-to-fit;
    opacity: 0.85;
}

/* =============================================================
   Modal / element 애니메이션 atom — JRPG 콘솔급 motion.
   UI Toolkit USS transition 기반. C#에서 class toggle로 trigger.
   3-tier (analysis-town-ui-component-system-v1):
     tier 1 — modal in/out (scale + opacity)
     tier 2 — card hover / tab 전환 (rim glow, raise)
     tier 3 — node toggle / chip select (snap scale)
   ============================================================= */

/* tier 1 — modal 등장/퇴장. C#: 열 때 --enter 제거, 닫을 때 --exit 추가. */
.sm-modal-anim {
    transition-property: opacity, scale;
    transition-duration: 200ms, 200ms;
    transition-timing-function: ease-out, ease-out;
    opacity: 1;
    scale: 1 1;
}
.sm-modal-anim--enter {
    opacity: 0;
    scale: 0.96 0.96;
}
.sm-modal-anim--exit {
    opacity: 0;
    scale: 0.96 0.96;
}

/* tier 2 — card / tab hover. cool blue rim + 살짝 raise. */
.sm-hover-raise {
    transition-property: translate, scale;
    transition-duration: 120ms;
    transition-timing-function: ease-out;
}
.sm-hover-raise:hover {
    translate: 0 -2px;
    scale: 1.02 1.02;
}

/* tier 3 — node / chip select snap. */
.sm-select-snap {
    transition-property: scale;
    transition-duration: 90ms;
    transition-timing-function: ease-out;
}
.sm-select-snap:active {
    scale: 0.95 0.95;
}
