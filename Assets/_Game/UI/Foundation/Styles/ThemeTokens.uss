/* =============================================================
   Survival Manager — Theme Tokens
   v0.2 transcribe from claude.ai/design Foundation pack:
     docs/02_design/ui/handoff/foundation-pack-v0.2/style-guide.html
   톤: Genshin Impact + Unicorn Overlord 흡수 (1인 인디 단순화)
     - 따뜻한 네이비 양피지 BG (검정 X)
     - 와인 + 골드 + 사파이어 메뉴 액센트
     - 풍성한 곡선 ornament + 보석 인레이 (대형은 utility class에서)
     - vellum cream ink (양피지 위 잉크)
   ============================================================= */
:root {
    /* === SURFACE — warm navy parchment ===================== */
    --sm-bg-0: rgb(12, 17, 38);          /* page deep midnight indigo */
    --sm-bg-1: rgb(20, 26, 53);          /* panel base (Genshin menu tone) */
    --sm-bg-2: rgb(28, 34, 67);          /* panel raised */
    --sm-bg-3: rgb(38, 45, 84);          /* panel tier */
    --sm-line-1: rgb(44, 53, 104);       /* hairline */
    --sm-line-2: rgb(59, 70, 127);       /* divider */
    --sm-vellum: rgb(245, 234, 208);     /* #F5EAD0 양피지 ink primary */
    --sm-vellum-2: rgb(226, 212, 173);   /* 양피지 muted */
    --sm-transparent: rgba(0, 0, 0, 0);

    /* === GOLD — menu trim ladder =========================== */
    --sm-gold-100: rgb(255, 233, 168);   /* glaint */
    --sm-gold-200: rgb(245, 214, 138);   /* light gold */
    --sm-gold-300: rgb(230, 183, 81);    /* signature gold (corner cap) */
    --sm-gold-400: rgb(200, 147, 42);    /* line gold */
    --sm-gold-500: rgb(138, 100, 24);    /* shadow gold */
    --sm-gold-glow: rgba(245, 214, 138, 0.35);

    /* === INK — on parchment ================================ */
    --sm-ink-0: rgb(255, 248, 224);      /* highlight ink (#FFF8E0) */
    --sm-ink-1: rgb(245, 234, 208);      /* primary text */
    --sm-ink-2: rgb(216, 199, 153);      /* secondary */
    --sm-ink-3: rgb(157, 138, 94);       /* muted */
    --sm-ink-4: rgb(107, 93, 63);        /* very muted */

    /* === ARCHETYPE FAMILY — pigment tone (saturation up) === */
    /* Beastkin / Undead — moss / orc */
    --sm-fam-beastkin: rgb(122, 138, 82);
    --sm-fam-beastkin-deep: rgb(46, 56, 24);
    --sm-fam-beastkin-glow: rgb(185, 201, 128);
    /* Vanguard — sapphire steel */
    --sm-fam-vanguard: rgb(74, 114, 184);
    --sm-fam-vanguard-deep: rgb(26, 42, 82);
    --sm-fam-vanguard-glow: rgb(127, 163, 224);
    /* Striker — wine + ember (lead family) */
    --sm-fam-striker: rgb(182, 51, 74);
    --sm-fam-striker-deep: rgb(90, 14, 28);
    --sm-fam-striker-glow: rgb(240, 138, 60);
    /* Ranger — forest / ochre */
    --sm-fam-ranger: rgb(181, 138, 54);
    --sm-fam-ranger-deep: rgb(77, 58, 20);
    --sm-fam-ranger-glow: rgb(230, 200, 120);
    /* Mystic — amethyst + ivory */
    --sm-fam-mystic: rgb(138, 92, 184);
    --sm-fam-mystic-deep: rgb(58, 31, 90);
    --sm-fam-mystic-glow: rgb(212, 180, 240);

    /* === RARITY — jewel duotone ============================ */
    --sm-rare-common: rgb(205, 196, 168);
    --sm-rare-common-deep: rgb(107, 98, 72);
    --sm-rare-common-glow: rgb(245, 234, 208);
    --sm-rare-rare: rgb(91, 142, 209);
    --sm-rare-rare-deep: rgb(31, 59, 102);
    --sm-rare-rare-glow: rgb(155, 190, 237);
    --sm-rare-epic: rgb(181, 97, 214);
    --sm-rare-epic-2: rgb(240, 138, 60);     /* purple → flame dueltone */
    --sm-rare-epic-deep: rgb(74, 33, 104);
    --sm-rare-epic-glow: rgb(255, 224, 160);

    /* === STATE ============================================= */
    --sm-state-safe: rgb(109, 191, 120);
    --sm-state-warn: rgb(232, 169, 59);
    --sm-state-danger: rgb(226, 85, 72);
    --sm-state-locked: rgb(107, 110, 133);
    --sm-state-ko: rgb(138, 138, 152);
    --sm-state-injured: rgb(182, 51, 74);    /* warm bruise — lead와 통일 */

    /* === TYPE FAMILY — v0.2 source font token names ========= */
    /* Unity Font asset wiring uses -unity-font-definition at rule level.
       These tokens preserve the source family contract for component specs. */
    --sm-type-ko: Pretendard;
    --sm-type-mincho: ShipporiMincho;
    --sm-type-display: Cinzel;
    --sm-type-garamond: CormorantGaramond;
    --sm-type-mono: JetBrainsMono;

    /* === SPACING — 8pt grid ================================ */
    --sm-s-1: 4px;
    --sm-s-2: 8px;
    --sm-s-3: 12px;
    --sm-s-4: 16px;
    --sm-s-5: 24px;
    --sm-s-6: 32px;
    --sm-s-7: 48px;

    /* === RADIUS — flat indie scope ========================= */
    --sm-r-sm: 2px;
    --sm-r-md: 4px;
    --sm-r-lg: 6px;

    /* === MOTION ============================================ */
    --sm-t-snap: 200ms;
    --sm-e-snap: ease-out;

    /* === ALPHA / LAYER TOKENS — USS-safe gradient stand-ins == */
    --sm-bg-0-a84: rgba(12, 17, 38, 0.84);
    --sm-bg-1-a54: rgba(12, 17, 31, 0.54);
    --sm-bg-2-a78: rgba(18, 24, 45, 0.78);
    --sm-bg-void-a20: rgba(7, 8, 10, 0.20);
    --sm-bg-vital-a72: rgba(4, 8, 10, 0.72);
    --sm-bg-portrait-a70: rgba(31, 25, 19, 0.70);
    --sm-bg-portrait-a82: rgba(31, 25, 19, 0.82);
    --sm-bg-portrait-missing-a66: rgba(78, 61, 42, 0.66);
    --sm-vellum-a05: rgba(245, 234, 208, 0.05);
    --sm-vellum-a06: rgba(245, 234, 208, 0.06);
    --sm-vellum-a07: rgba(245, 234, 208, 0.07);
    --sm-vellum-a08: rgba(245, 234, 208, 0.08);
    --sm-vellum-a09: rgba(245, 234, 208, 0.09);
    --sm-vellum-a10: rgba(245, 234, 208, 0.10);
    --sm-vellum-a12: rgba(245, 234, 208, 0.12);
    --sm-vellum-a15: rgba(245, 234, 208, 0.15);
    --sm-vellum-a18: rgba(245, 234, 208, 0.18);
    --sm-gold-muted-a40: rgba(218, 187, 118, 0.40);
    --sm-gold-muted-a44: rgba(218, 187, 118, 0.44);
    --sm-gold-muted-a54: rgba(218, 187, 118, 0.54);
    --sm-gold-muted-a72: rgba(218, 187, 118, 0.72);
    --sm-gold-300-a20: rgba(230, 183, 81, 0.20);
    --sm-gold-300-a22: rgba(230, 183, 81, 0.22);
    --sm-gold-300-a24: rgba(230, 183, 81, 0.24);
    --sm-gold-300-a25: rgba(230, 183, 81, 0.25);
    --sm-gold-300-a26: rgba(230, 183, 81, 0.26);
    --sm-gold-300-a28: rgba(230, 183, 81, 0.28);
    --sm-gold-300-a32: rgba(230, 183, 81, 0.32);
    --sm-gold-300-a34: rgba(230, 183, 81, 0.34);
    --sm-gold-300-a36: rgba(230, 183, 81, 0.36);
    --sm-gold-300-a42: rgba(230, 183, 81, 0.42);
    --sm-gold-300-a78: rgba(230, 183, 81, 0.78);
    --sm-fam-vanguard-glow-a45: rgba(127, 163, 224, 0.45);
    --sm-state-warn-a56: rgba(232, 169, 59, 0.56);
    --sm-state-safe-a86: rgba(166, 220, 154, 0.86);
    --sm-state-safe-a92: rgba(166, 220, 154, 0.92);
    --sm-state-shield-a82: rgba(118, 168, 230, 0.82);
    --sm-state-injured-a22: rgba(120, 56, 74, 0.22);

    /* === FONT SIZE — 4-tier ================================ */
    /* Korean body / display / dev tag 공용. font-family는
       UITK Font asset reference라 token에 직접 두지 않고
       USS rule에서 -unity-font-definition으로 wire한다. */
    --sm-fs-s: 12px;
    --sm-fs-m: 14px;
    --sm-fs-l: 18px;
    --sm-fs-xl: 24px;

    /* === MOOD BASELINE — V1 시안 갤러리 (8 Town Preview surface) ===
       3 mood frame + 1 backdrop + 4 CTA tier. 8 Preview surface가
       본 token만 참조해서 corner/trim/CTA drift 제거.
         parchment = TacticalWorkshop / Inventory (cream BG, dark ink)
         ceremony  = Recruit / EquipmentRefit / PermanentAugment /
                     PassiveBoard / Theater (deep navy BG, gold ink)
         modal-sm  = Settings (작은 modal, navy 같지만 corner/border 축소) */
    --sm-frame-parchment-bg: rgba(235, 220, 178, 0.96);
    --sm-frame-ceremony-bg: rgba(20, 26, 53, 0.96);
    --sm-frame-modal-bg: rgba(20, 26, 53, 0.96);
    --sm-backdrop-dim: rgba(12, 17, 38, 0.55);

    --sm-frame-trim-color: var(--sm-gold-400);
    --sm-frame-trim-w: 3px;
    --sm-frame-trim-w-small: 2px;

    --sm-frame-corner-color: var(--sm-gold-300);
    /* corner = ornament-corner-vine.svg (vector, 34x34 viewBox). 1:1 size로 crisp 렌더. */
    --sm-frame-corner-size: 34px;
    --sm-frame-corner-size-small: 28px;

    --sm-frame-divider-ceremony: rgba(230, 183, 81, 0.32);
    --sm-frame-divider-parchment: rgba(138, 100, 24, 0.45);

    --sm-on-parchment-ink: rgb(61, 47, 18);
    --sm-on-parchment-ink-muted: rgb(107, 93, 63);

    /* CTA height tier: inline (inventory secondary) / md (settings, passive) /
       lg (recruit, refit, theater primary modal) / hero (augment equip, hub) */
    --sm-cta-h-inline: 36px;
    --sm-cta-h-md: 44px;
    --sm-cta-h-lg: 48px;
    --sm-cta-h-hero: 56px;

    /* =========================================================
       LEGACY ALIASES — backward-compat for existing screen USS
       기존 4 screen + Narrative USS의 var() reference가 깨지지
       않도록 v0.2 token에 alias. v0.2 적용 = 자동 톤 swap.
       ========================================================= */
    --color-bg: var(--sm-bg-0);
    --color-surface: var(--sm-bg-1);
    --color-surface-alt: var(--sm-bg-2);
    --color-panel-border: var(--sm-line-1);
    --color-text: var(--sm-ink-1);
    --color-text-muted: var(--sm-ink-3);
    --color-accent: var(--sm-gold-300);
    --color-accent-2: var(--sm-fam-vanguard);
    --color-good: var(--sm-state-safe);
    --color-danger: var(--sm-state-danger);

    --space-1: var(--sm-s-1);
    --space-2: var(--sm-s-2);
    --space-3: var(--sm-s-3);
    --space-4: var(--sm-s-4);
    --space-5: var(--sm-s-5);

    --radius-s: var(--sm-r-md);   /* 6 → 4 (flat indie tone) */
    --radius-m: var(--sm-r-lg);   /* 10 → 6 */
    --radius-l: 8px;              /* 14 → 8 */

    --font-size-s: var(--sm-fs-s);
    --font-size-m: var(--sm-fs-m);
    --font-size-l: var(--sm-fs-l);
    --font-size-xl: var(--sm-fs-xl);
}
