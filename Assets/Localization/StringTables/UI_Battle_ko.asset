      m_Items: []
  - m_Id: 73
    m_Localized: "\uC0C8 seed\uB85C Quick Battle (Smoke)\uB97C \uB2E4\uC2DC \uC2DC\uC791\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 74
    m_Localized: "\uC804\uD22C\uAC00 \uB05D\uB09C \uB4A4 Quick Battle (Smoke)\uB97C
