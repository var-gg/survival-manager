    m_Localized: Combat Sandbox
    m_Metadata:
      m_Items: []
  - m_Id: 3380253606010880
    m_Localized: 'Read the battle through the summary, recent log, and selected unit
      panel. Combat Sandbox stays inside battle: replay the same seed, roll a new
      seed, or exit the sandbox.'
    m_Metadata:
      m_Items: []
  - m_Id: 3380253606010881
    m_Localized: Replay Same Seed
    m_Metadata:
      m_Items: []
  - m_Id: 3380253606010882
    m_Localized: New Seed
    m_Metadata:
      m_Items: []
  - m_Id: 3380253606010883
    m_Localized: Exit Sandbox
    m_Metadata:
      m_Items: []
