  - m_Id: 1864474725179419
    m_Localized: "\uC989\uC2DC \uACE8\uB4DC\uB97C \uD655\uBCF4\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179420
    m_Localized: "\uCCA0\uB0A0 \uBCF4\uAE09"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179421
    m_Localized: "\uAE30\uBCF8 \uBB34\uAE30 \uC544\uC774\uD15C\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179422
    m_Localized: "\uACF5\uC138 \uC810\uD654"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179423
    m_Localized: "\uACF5\uACA9\uC801\uC778 \uC784\uC2DC \uC99D\uAC15\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179424
    m_Localized: "\uC804\uC7C1 \uC0C1\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179425
    m_Localized: "\uB9E4\uBCF5 \uACBD\uB85C \uC804\uC6A9 \uB300\uD615 \uACE8\uB4DC
      \uBCF4\uC0C1\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179426
    m_Localized: "\uAC08\uACE0\uB9AC \uCC3D"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179427
    m_Localized: "\uC804\uC5F4 \uAD50\uC804\uC6A9 \uC544\uC774\uD15C\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179428
    m_Localized: "\uC815\uCC30 \uBCF4\uACE0\uC11C"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179429
    m_Localized: "\uB2E4\uC74C recruit/retrain \uBCF5\uAD6C\uC6A9 Echo\uB97C \uCD94\uAC00\uB85C
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179430
    m_Localized: "\uD604\uC7A5 \uC218\uB9AC \uD0A4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179431
    m_Localized: "\uC548\uC815\uC801\uC778 \uBC29\uC5B4\uD615 \uC544\uC774\uD15C\uC744
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179432
    m_Localized: "\uACE0\uC815 \uBC15\uB3D9"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179433
    m_Localized: "\uC804\uC5F4 \uC720\uC9C0\uC6A9 \uC784\uC2DC \uC99D\uAC15\uC744
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179434
    m_Localized: "\uBCF4\uAE09 \uC8FC\uBA38\uB2C8"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179435
    m_Localized: "\uC911\uAC04 \uADDC\uBAA8\uC758 \uACE8\uB4DC \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179436
    m_Localized: "\uC601\uAD6C \uC18C\uCF13"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179437
    m_Localized: "\uC601\uAD6C \uC99D\uAC15 \uC2AC\uB86F\uC744 \uD655\uC7A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179438
    m_Localized: "\uC2DC\uC9C8 \uCF54\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179439
    m_Localized: "\uD6C4\uBC18 \uB300\uBE44\uC6A9 \uC544\uC774\uD15C\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179440
    m_Localized: "\uAD50\uB9AC \uBCF4\uAD00\uACE0"
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179441
    m_Localized: "Echo\uB97C \uD06C\uAC8C \uD655\uBCF4\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 1864474725179442
    m_Localized: "\uBE44\uC0C1 \uBCF4\uAE09\uD568"
