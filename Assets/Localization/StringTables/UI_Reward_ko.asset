    m_Metadata:
      m_Items: []
  - m_Id: 62
    m_Localized: "\uBCF4\uC0C1\uC774 \uD655\uC815\uB418\uC5C8\uC2B5\uB2C8\uB2E4.
      Town\uC73C\uB85C \uB3CC\uC544\uAC00 \uB2E4\uC74C \uC0C1\uD0DC\uB97C \uD655\uC778\uD558\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 63
    m_Localized: "Quick Battle \uC2A4\uBAA8\uD06C \uC815\uC0B0\uC785\uB2C8\uB2E4.
      \uCE74\uB4DC \uD55C \uC7A5\uC744 \uACE0\uB974\uACE0 Town\uC73C\uB85C \uB3CC\uC544\uAC00\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 64
    m_Localized: "\uB7F0\uC774 \uC2E4\uD328\uD588\uC2B5\uB2C8\uB2E4. fallback \uBCF4\uC0C1\uC744
      \uACE0\uB974\uACE0 Town\uC73C\uB85C \uB3CC\uC544\uAC00\uC138\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 65
    m_Localized: "\uB7F0\uC774 \uC644\uB8CC\uB418\uC5C8\uC2B5\uB2C8\uB2E4. \uBCF4\uC0C1\uC744
