      m_Items: []
  - m_Id: 33
    m_Localized: "\uC804\uC7C1 \uC0C1\uC790"
    m_Metadata:
      m_Items: []
  - m_Id: 34
    m_Localized: "\uB9E4\uBCF5 \uACBD\uB85C \uC804\uC6A9 \uB300\uD615 \uACE8\uB4DC
      \uBCF4\uC0C1\uC785\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 35
    m_Localized: "\uC804\uC5F4 \uAD50\uC804\uC6A9 \uC544\uC774\uD15C\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 36
    m_Localized: "\uB2E4\uC74C recruit/retrain \uBCF5\uAD6C\uC6A9 Echo\uB97C \uCD94\uAC00\uB85C
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 37
    m_Localized: "\uD604\uC7A5 \uC218\uB9AC \uD0A4\uD2B8"
    m_Metadata:
      m_Items: []
  - m_Id: 38
    m_Localized: "\uC548\uC815\uC801\uC778 \uBC29\uC5B4\uD615 \uC544\uC774\uD15C\uC744
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 39
    m_Localized: "\uACE0\uC815 \uBC15\uB3D9"
    m_Metadata:
      m_Items: []
  - m_Id: 40
    m_Localized: "\uC804\uC5F4 \uC720\uC9C0\uC6A9 \uC784\uC2DC \uC99D\uAC15\uC744
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 41
    m_Localized: "\uC911\uAC04 \uADDC\uBAA8\uC758 \uACE8\uB4DC \uBCF4\uC0C1\uC744
      \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 42
    m_Localized: "\uC601\uAD6C \uC18C\uCF13"
    m_Metadata:
      m_Items: []
  - m_Id: 43
    m_Localized: "\uC601\uAD6C \uC99D\uAC15 \uC2AC\uB86F\uC744 \uD655\uC7A5\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 44
    m_Localized: "\uC2DC\uC9C8 \uCF54\uC5B4"
    m_Metadata:
      m_Items: []
  - m_Id: 45
    m_Localized: "\uD6C4\uBC18 \uB300\uBE44\uC6A9 \uC544\uC774\uD15C\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 46
    m_Localized: "Echo\uB97C \uD06C\uAC8C \uD655\uBCF4\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 47
    m_Localized: "\uD328\uBC30 \uD6C4 \uCD5C\uC18C \uBCF4\uC0C1\uC744 \uCC59\uAE41\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 48
    m_Localized: "\uC804\uC220 \uBA54\uBAA8"
    m_Metadata:
      m_Items: []
  - m_Id: 49
    m_Localized: "\uC804\uC220 \uBCF4\uC815\uC6A9 Echo\uB97C \uD68D\uB4DD\uD569\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 50
    m_Localized: "\uC218\uD638 \uC810\uD654"
    m_Metadata:
      m_Items: []
  - m_Id: 51
    m_Localized: "\uC548\uC815\uD654\uC6A9 \uC784\uC2DC \uC99D\uAC15\uC744 \uD68D\uB4DD\uD569\uB2C8\uB2E4."
