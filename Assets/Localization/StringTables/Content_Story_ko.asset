      \uC788\uB2E4\uB294 \uC0AC\uC2E4\uC744 \uC54C\uAC8C \uB418\uBA74\uC11C, \uC601\uC5ED
      \uD0C8\uD658\uB9CC\uC73C\uB85C\uB294 \uC21C\uD658\uC744 \uB04A\uC744 \uC218
      \uC5C6\uC74C\uC744 \uAE68\uB2EB\uB294\uB2E4. \uB3D9\uAE30\uB294 '\uC528\uC871\uC758
      \uB545'\uC5D0\uC11C '\uBAA8\uB4E0 \uC885\uC758 \uC0DD\uC874\uAD8C'\uC73C\uB85C
      \uD655\uC7A5\uB41C\uB2E4.\n\n\uC778\uAC04\uACFC\uC758 \uB3D9\uB9F9\uC740 \uB9FA\uC5C8\uC73C\uB098
      \uC528\uC871 \uB0B4\uBD80 \uD569\uC758\uAC00 \uC644\uC131\uB418\uC9C0 \uC54A\uC558\uB2E4.
      \uC7A5\uB85C \uC77C\uBD80\uB294 \uC5EC\uC804\uD788 \uC778\uAC04\uC744 \uC801\uC73C\uB85C
      \uBCF4\uBA70, \uB3D9\uB9F9\uC774 \uAE4A\uC5B4\uC9C8\uC218\uB85D \uBB34\uB9AC
      \uB0B4 \uBD84\uC5F4\uB3C4 \uAE4A\uC5B4\uC9C4\uB2E4. ch4\uC5D0\uC11C \uC528\uC871
      \uC7A5\uB85C\uB4E4\uC740 \uADF8\uC758 \uB3D9\uB9F9\uC744 \uBC30\uC2E0\uC73C\uB85C
      \uC120\uC5B8\uD558\uACE0, \uC528\uC871\uC758 \uC77C\uBD80\uAC00 \uC601\uAD6C\uC801\uC73C\uB85C
