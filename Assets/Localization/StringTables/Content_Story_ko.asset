  - m_Id: 501679644745
    m_Localized: "\uC911\uD6C4\uBC18 \uC804\uC5F4 \uB3CC\uD30C \uC7A5\uCE58\n\n\uC911\uD6C4\uBC18
      \uC804\uC5F4 \uB3CC\uD30C \uC7A5\uCE58"
    m_Metadata:
      m_Items: []
  - m_Id: 501679644746
    m_Localized: Storm Shaman
    m_Metadata:
      m_Items: []
  - m_Id: 501679644747
    m_Localized: "\uC57C\uC218\uC871 \uC528\uC871\uC758 \uC5EC\uC131 \uC758\uB840
      \uAD00\uC7A5\uC790\uC774\uC790 \uACF5\uB3D9\uCCB4 \uCE58\uC720\uC0AC. \uC21C\uD658\uC758
      \uC228\uACB0(Breath of the Cycle) \uC758\uB840\uB97C \uD1B5\uD574 \uC528\uC871\uC758
      \uAE30\uC5B5\uACFC \uC720\uB300\uB97C \uC720\uC9C0\uD558\uB294 \uC5ED\uD560\uC744
      \uB9E1\uACE0 \uC788\uB2E4. \uC6D0\uC815\uC5D0 \uD569\uB958\uD55C \uAC83\uC740
      \uBB34\uB9AC\uC5D0\uC11C \uB5A8\uC5B4\uC838 \uB098\uC628 \uC804\uC0AC\uB4E4\uC758
      \uC601\uD63C\uC744 \uB3CC\uBCF4\uAE30 \uC704\uD574\uC11C\uB2E4. \uADF8\uB140\uB294
      Heartforge\uC758 \uACF5\uBA85\uC744 \uBCF8\uB2A5\uC801\uC73C\uB85C \uAC10\uC9C0\uD558\uBA70,
      \uC774\uAC83\uC774 \uC528\uC871 \uC758\uB840\uC758 \uBFCC\uB9AC\uC640 \uC5F0\uACB0\uB418\uC5B4
      \uC788\uB2E4\uB294 \uC9C1\uAC10\uC744 \uD488\uACE0 \uC788\uB2E4. \uC804\uD22C\uBCF4\uB2E4
      \uCE58\uC720\uB97C, \uD30C\uAD34\uBCF4\uB2E4 \uBCF5\uC6D0\uC744 \uC6B0\uC120\uD558\uBA70,
      \uC528\uC871\uC758 \uC758\uB840\uAC00 \uB04A\uC5B4\uC9C0\uC9C0 \uC54A\uB294
      \uD55C \uD76C\uB9DD\uC740 \uB0A8\uC544 \uC788\uB2E4\uACE0 \uBBFF\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644748
    m_Localized: "\uC57C\uC218\uC871 \uACF5\uB3D9\uCCB4\uC758 \uC758\uB840"
    m_Metadata:
      m_Items: []
  - m_Id: 501679644749
    m_Localized: "\uC57C\uC218\uC871 \uC528\uC871\uC758 \uC5EC\uC131 \uC758\uB840
      \uAD00\uC7A5\uC790\uC774\uC790 \uACF5\uB3D9\uCCB4 \uCE58\uC720\uC0AC. \uC21C\uD658\uC758
      \uC228\uACB0(Breath of the Cycle) \uC758\uB840\uB97C \uD1B5\uD574 \uC528\uC871\uC758
      \uAE30\uC5B5\uACFC \uC720\uB300\uB97C \uC720\uC9C0\uD558\uB294 \uC5ED\uD560\uC744
      \uB9E1\uACE0 \uC788\uB2E4. \uC6D0\uC815\uC5D0 \uD569\uB958\uD55C \uAC83\uC740
      \uBB34\uB9AC\uC5D0\uC11C \uB5A8\uC5B4\uC838 \uB098\uC628 \uC804\uC0AC\uB4E4\uC758
      \uC601\uD63C\uC744 \uB3CC\uBCF4\uAE30 \uC704\uD574\uC11C\uB2E4. \uADF8\uB140\uB294
      Heartforge\uC758 \uACF5\uBA85\uC744 \uBCF8\uB2A5\uC801\uC73C\uB85C \uAC10\uC9C0\uD558\uBA70,
      \uC774\uAC83\uC774 \uC528\uC871 \uC758\uB840\uC758 \uBFCC\uB9AC\uC640 \uC5F0\uACB0\uB418\uC5B4
      \uC788\uB2E4\uB294 \uC9C1\uAC10\uC744 \uD488\uACE0 \uC788\uB2E4. \uC804\uD22C\uBCF4\uB2E4
      \uCE58\uC720\uB97C, \uD30C\uAD34\uBCF4\uB2E4 \uBCF5\uC6D0\uC744 \uC6B0\uC120\uD558\uBA70,
      \uC528\uC871\uC758 \uC758\uB840\uAC00 \uB04A\uC5B4\uC9C0\uC9C0 \uC54A\uB294
      \uD55C \uD76C\uB9DD\uC740 \uB0A8\uC544 \uC788\uB2E4\uACE0 \uBBFF\uB294\uB2E4.\n\n\uC57C\uC218\uC871
      \uACF5\uB3D9\uCCB4\uC758 \uC758\uB840"
    m_Metadata:
      m_Items: []
  - m_Id: 501679644750
    m_Localized: Trail Scout
    m_Metadata:
      m_Items: []
  - m_Id: 501679644751
    m_Localized: "\uC57C\uC218\uC871\uACFC \uC778\uAC04 \uC601\uC5ED\uC758 \uACBD\uACC4\uC5D0\uC11C
      \uC790\uB780 \uD63C\uD608 \uC5EC\uC131 \uC815\uCC30\uBCD1. \uC5B4\uB290 \uCABD\uC5D0\uB3C4
      \uC644\uC804\uD788 \uC18D\uD558\uC9C0 \uBABB\uD55C \uACBD\uD5D8\uC774 \uC624\uD788\uB824
      \uC591\uCABD \uC0AC\uC774\uC758 \uC644\uCDA9\uC7AC \uC5ED\uD560\uC744 \uAC00\uB2A5\uD558\uAC8C
      \uB9CC\uB4E4\uC5C8\uB2E4. \uAE34\uC7A5\uC774 \uADF9\uC5D0 \uB2EC\uD560 \uB54C
      \uAC74\uC870\uD55C \uB18D\uB2F4\uC73C\uB85C \uBD84\uC704\uAE30\uB97C \uAEBE\uB294
      \uB2A5\uB825\uC774 \uC788\uC73C\uBA70, \uBCF8\uC778\uC740 \uC774\uAC83\uC744
      \uC0DD\uC874 \uAE30\uC220\uC774\uB77C \uBD80\uB978\uB2E4. \uC720\uBA38 \uC544\uB798\uC5D0\uB294
      \uC5B4\uB514\uC5D0\uB3C4 \uC18D\uD558\uC9C0 \uBABB\uD55C \uC790\uC758 \uC678\uB85C\uC6C0\uC774
      \uC788\uC9C0\uB9CC, \uADF8\uB140\uAC00 \uADF8\uAC83\uC744 \uB4DC\uB7EC\uB0B4\uB294
      \uC77C\uC740 \uAC70\uC758 \uC5C6\uB2E4. \uB450 \uC138\uACC4 \uC0AC\uC774\uC758
      \uB2E4\uB9AC\uAC00 \uB418\uB294 \uAC83\uC774 \uC18C\uBA85\uC774\uB77C\uAE30\uBCF4\uB2E4\uB294,
      \uADF8 \uC704\uCE58 \uB9D0\uACE0\uB294 \uC124 \uACF3\uC774 \uC5C6\uAE30 \uB54C\uBB38\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644752
    m_Localized: "\uC720\uBA38\uC640 \uACBD\uACC4\uC758 \uC644\uCDA9\uC7AC"
    m_Metadata:
      m_Items: []
  - m_Id: 501679644753
    m_Localized: "\uC57C\uC218\uC871\uACFC \uC778\uAC04 \uC601\uC5ED\uC758 \uACBD\uACC4\uC5D0\uC11C
      \uC790\uB780 \uD63C\uD608 \uC5EC\uC131 \uC815\uCC30\uBCD1. \uC5B4\uB290 \uCABD\uC5D0\uB3C4
      \uC644\uC804\uD788 \uC18D\uD558\uC9C0 \uBABB\uD55C \uACBD\uD5D8\uC774 \uC624\uD788\uB824
      \uC591\uCABD \uC0AC\uC774\uC758 \uC644\uCDA9\uC7AC \uC5ED\uD560\uC744 \uAC00\uB2A5\uD558\uAC8C
      \uB9CC\uB4E4\uC5C8\uB2E4. \uAE34\uC7A5\uC774 \uADF9\uC5D0 \uB2EC\uD560 \uB54C
      \uAC74\uC870\uD55C \uB18D\uB2F4\uC73C\uB85C \uBD84\uC704\uAE30\uB97C \uAEBE\uB294
      \uB2A5\uB825\uC774 \uC788\uC73C\uBA70, \uBCF8\uC778\uC740 \uC774\uAC83\uC744
      \uC0DD\uC874 \uAE30\uC220\uC774\uB77C \uBD80\uB978\uB2E4. \uC720\uBA38 \uC544\uB798\uC5D0\uB294
      \uC5B4\uB514\uC5D0\uB3C4 \uC18D\uD558\uC9C0 \uBABB\uD55C \uC790\uC758 \uC678\uB85C\uC6C0\uC774
      \uC788\uC9C0\uB9CC, \uADF8\uB140\uAC00 \uADF8\uAC83\uC744 \uB4DC\uB7EC\uB0B4\uB294
      \uC77C\uC740 \uAC70\uC758 \uC5C6\uB2E4. \uB450 \uC138\uACC4 \uC0AC\uC774\uC758
      \uB2E4\uB9AC\uAC00 \uB418\uB294 \uAC83\uC774 \uC18C\uBA85\uC774\uB77C\uAE30\uBCF4\uB2E4\uB294,
      \uADF8 \uC704\uCE58 \uB9D0\uACE0\uB294 \uC124 \uACF3\uC774 \uC5C6\uAE30 \uB54C\uBB38\uC774\uB2E4.\n\n\uC720\uBA38\uC640
      \uACBD\uACC4\uC758 \uC644\uCDA9\uC7AC"
    m_Metadata:
      m_Items: []
  - m_Id: 501679644754
    m_Localized: "\"\uC800 \uBE5B\uC740... \uC131\uC720\uBB3C\uC758 \uBE5B\uC785\uB2C8\uB2E4.
      \uC65C \uBB34\uAE30\uC5D0 \uAE43\uB4E4\uC5B4 \uC788\uC2B5\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644755
    m_Localized: "\"\uBE5B\uB098\uB4E0 \uB9D0\uB4E0. \uBD80\uC218\uBA74 \uAEBC\uC838.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644756
    m_Localized: "\uACE8\uB818\uC758 \uAC00\uC2B4\uD310\uC774 \uAC08\uB77C\uC9C0\uACE0,
      \uC548\uCABD\uC5D0\uC11C \uB0AF\uC775\uC740 \uBE5B\uC774 \uC3DF\uC544\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644757
    m_Localized: "\"\uBFCC\uB9AC\uC758 \uAD00\uB9DD\uC790. 1800\uB144 \uB3D9\uC548
      \uC774 \uC790\uB9AC\uB97C \uC9C0\uD0A8 \uBB38\uC9C0\uAE30.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644758
    m_Localized: "\"\uC774\uD574\uB97C \uC704\uD55C \uC2F8\uC6C0\uC785\uB2C8\uB2E4.
      \uC815\uBCF5\uC774 \uC544\uB2D9\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644759
    m_Localized: "\"\uB3D9\uC871\uC774\uB2E4. \uAC00\uBCCD\uAC8C \uD558\uC9C0 \uB9C8\uB77C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644760
    m_Localized: "\"\uACA9\uC790\uAC00 \uAF2C\uC5EC \uC788\uB2E4. \uC800 \uC548\uC5D0
      \uC758\uC9C0\uAC00 \uC788\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644761
    m_Localized: "\"Aldric\uC758 \uAC83\uC785\uB2C8\uB2E4. \uC54C\uACE0 \uC788\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644762
    m_Localized: "\"\uC758\uC9C0\uB4E0 \uBB50\uB4E0. \uBD80\uC218\uBA74 \uC870\uC6A9\uD574\uC9C0\uACA0\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644763
    m_Localized: "\"\uAD00\uBB38 \uC218\uD638\uC790\uB2E4. \uB098\uC640 \uAC19\uC740
      \uC2DC\uB300\uC758.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644764
    m_Localized: "\"\uAE38\uC744 \uC5F4\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644765
    m_Localized: "\"\uC5ED\uC0AC \uC218\uC5C5\uC740 \uB098\uC911\uC5D0. \uBA3C\uC800
      \uC9C0\uB098\uAC00\uC790.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644766
    m_Localized: "\"\uCE68\uBB35\uC758 \uAE30\uB85D\uAD00. \uB098\uBCF4\uB2E4 \uC624\uB798\uB41C
      \uAE30\uC5B5\uC744 \uD488\uACE0 \uC788\uC5B4. \uC5F4\uC1E0\uB97C \uC548 \uB118\uAE30\uBA74
      \uC544\uBB34\uAC83\uB3C4 \uBABB \uAEBC\uB0B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644767
    m_Localized: "\"\uC9C4\uC2E4\uC5D0 \uB2E4\uAC00\uAC00\uB294 \uAE38\uC740 \uB9E4\uBC88
      \uC774\uB807\uC2B5\uB2C8\uAE4C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644768
    m_Localized: "\"\uC26C\uC6E0\uC73C\uBA74 \uC9C4\uC2E4\uC774\uB77C\uACE0 \uC548
      \uBD88\uB800\uACA0\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644769
    m_Localized: "\"\uC800\uAC74 \uC655\uC774\uC5C8\uC5B4. \uC0AC\uB0E5\uD130\uC758
      \uC655. \uC9C0\uAE08\uC740...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644770
    m_Localized: "\"\uACA9\uC790\uAC00 \uB9CC\uB4E0 \uC655\uC774\uB2E4. \uBCF8\uB798
      \uBAA8\uC2B5\uC774 \uC544\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644771
    m_Localized: "\"\uD574\uBC29\uC2DC\uCF1C \uC90D\uC2DC\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644772
    m_Localized: "\"\uC9D1\uC815\uAD00 \uAC01\uD558. \uC9C8\uC11C\uB97C \uC9C0\uD0A4\uACA0\uB2E4\uACE0
      \uB9F9\uC138\uD55C \uBD84\uC774 \uC65C \uC774 \uC790\uB9AC\uC5D0 \uC11C \uACC4\uC2ED\uB2C8\uAE4C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644773
    m_Localized: "\"\uAC11\uC637\uC5D0\uC11C \uD1A0\uD15C\uC774\uB791 \uAC19\uC740
      \uBE5B\uC774 \uB098. \uC9C1\uC811 \uBC97\uACA8\uC904\uAC8C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644774
    m_Localized: "\uC9D1\uC815\uAD00\uC774 \uB300\uB2F5\uD558\uC9C0 \uC54A\uB294\uB2E4.
      \uAC11\uC637\uC758 \uBE5B\uB9CC\uC774 \uC751\uB2F5\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644775
    m_Localized: "\"\uB300\uC2EC\uBB38\uAD00. \uADF8 \uBD88\uAF43\uC774 \uD0DC\uC6B4
      \uAC83\uC740 \uC774\uB2E8\uC774 \uC544\uB2C8\uB77C \uC9C4\uC2E4\uC774\uC5C8\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644776
    m_Localized: "\"\uC9C4\uC9DC \uBD88\uAF43 \uC0C9\uC774 \uAD81\uAE08\uD588\uB294\uB370.
      \uAE08\uC0C9\uC774 \uC544\uB2C8\uB77C \uD54F\uBE5B\uC774\uC5C8\uB124.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644777
    m_Localized: "\uB300\uC2EC\uBB38\uAD00\uC758 \uC190\uC5D0\uC11C \uACA9\uC790
      \uBE5B\uC774 \uD0C0\uC624\uB978\uB2E4. Dawn Priest\uC640 \uAC19\uC740 \uBE5B\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644778
    m_Localized: "\"\uD68C\uC0C9 \uC1A1\uACF3\uB2C8. \uD615\uC81C\uC57C. \uB0A0 \uBC30\uC2E0\uC790\uB85C
      \uBD80\uB974\uACA0\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644779
    m_Localized: "\uC232 \uAE4A\uC740 \uACF3\uC5D0\uC11C \uB0AE\uC740 \uC6B8\uC74C\uC18C\uB9AC\uAC00
      \uC6B8\uB824\uC628\uB2E4. \uBD84\uB178\uAC00 \uC544\uB2C8\uB2E4. \uB354 \uC624\uB798\uB41C
      \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644780
    m_Localized: "\"\uADFC\uB370 \uC800\uB188 \uB0C4\uC0C8\uAC00 \uB2EC\uB77C. \uBD84\uB178\uAC00
      \uC774\uB807\uAC8C \uC624\uB798 \uAC00\uB294 \uAC74 \uC790\uC5F0\uC2A4\uB7FD\uC9C0
      \uC54A\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644781
    m_Localized: "\"\uB0B4\uAC00 Heartforge\uB97C \uD1B5\uC81C\uD588\uC18C. \uB0B4\uAC00
      \uD63C\uB3C8\uC5D0 \uC9C8\uC11C\uB97C \uAC00\uC838\uC654\uC18C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644782
    m_Localized: "\"\uB108\uD76C\uB294 \uB0B4\uAC00 \uC138\uC6B4 \uBAA8\uB4E0 \uAC83\uC744
      \uD30C\uAD34\uD558\uACE0 \uC788\uC18C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644783
    m_Localized: "\"\uB2F9\uC2E0\uC774 \uC138\uC6B4 \uAC83\uC740 \uB3C4\uAD74 \uC704\uC758
      \uC131\uC804\uC774\uC5C8\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644784
    m_Localized: "\"\uB05D\uC774\uB2E4, \uC124\uACC4\uC790.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644785
    m_Localized: "\uACE8\uB818\uC758 \uBAB8\uCCB4\uAC00 \uAC08\uB77C\uC9C4\uB2E4.
      \uAC00\uC2B4 \uC548\uCABD\uC5D0 \uC8FC\uBA39 \uD06C\uAE30\uC758 \uD30C\uD3B8\uC774
      \uBC15\uD600 \uC788\uB2E4. \uC131\uBB3C\uD568 \uC548\uC5D0 \uC788\uC5B4\uC57C
      \uD560 \uBE5B\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644786
    m_Localized: "\"\uC774\uAC83\uC774... \uACE8\uB818\uC758 \uC2EC\uC7A5\uC5D0...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644787
    m_Localized: "\"\uB124 \uC2E0\uC559\uC758 \uBE5B\uC774 \uB3CC\uB369\uC5B4\uB9AC
      \uC8FC\uBA39 \uC548\uC5D0 \uB4E4\uC5B4 \uC788\uC5C8\uB2E4. \uCD95\uBCF5\uC774\uB77C,
      \uCC38 \uC4F8\uBAA8 \uC788\uB294 \uB9D0\uC774\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644788
    m_Localized: "\"\uBAB0\uB77C\uC11C \uADF8\uB7AC\uB358 \uAC70\uC57C. \uC6B0\uB9AC
      \uBAA8\uB450. \uC11C\uB85C\uB97C \uC801\uC774\uB77C \uBBFF\uC740 \uAC74 \uBB34\uC9C0\uC600\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644789
    m_Localized: "\"\uC778\uAC04\uB3C4, \uC57C\uC218\uC871\uB3C4, \uC5B8\uB370\uB4DC\uB3C4...
      \uAC19\uC740 \uAC83\uC5D0 \uB2F9\uD558\uACE0 \uC788\uC5C8\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644790
    m_Localized: "\uAD00\uB9DD\uC790\uC758 \uBAB8\uC774 \uBE5B\uC73C\uB85C \uD769\uC5B4\uC9C4\uB2E4.
      \uBA3C\uC9C0\uAC00 \uC544\uB2C8\uB77C \uAE30\uC5B5\uC774 \uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644791
    m_Localized: "\uACB0\uC815\uC774 \uBD80\uC11C\uC9C0\uBA74\uC11C \uBE5B\uC774
      \uC0AC\uBC29\uC73C\uB85C \uD769\uC5B4\uC9C4\uB2E4. \uC7A0\uC2DC, \uC18D\uC0AD\uC784\uC774
      \uBA48\uCD98\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644792
    m_Localized: "\"\uC7A0\uC2DC\uBFD0\uC785\uB2C8\uB2E4. \uBCF8\uCCB4\uB294 \uC544\uB798\uC5D0
      \uC788\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644793
    m_Localized: "\"\uC7A0\uC2DC\uB77C\uB3C4 \uC870\uC6A9\uD558\uBA74 \uACE0\uB9C8\uC6B4
      \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644794
    m_Localized: "\uC218\uD638\uC790\uAC00 \uBE5B\uC73C\uB85C \uD769\uC5B4\uC9C4\uB2E4.
      \uAE38\uC774 \uC5F4\uB9B0\uB2E4. \uC544\uB798\uC5D0\uC11C \uC5F4\uAE30\uAC00
      \uC62C\uB77C\uC628\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644795
    m_Localized: "\"\uBB38\uC9C0\uAE30 \uCE58\uACE0 \uC608\uC758 \uBC14\uB974\uB354\uB77C.
      \uC8FD\uC73C\uBA74\uC11C\uB3C4 \uAE38\uC744 \uC5F4\uC5B4\uC8FC\uB2E4\uB2C8.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644796
    m_Localized: "\"\uC608\uC758\uAC00 \uC544\uB2C8\uB2E4. \uC778\uACC4\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644797
    m_Localized: "\uAE30\uB85D\uAD00\uC774 \uBB34\uB98E\uC744 \uAFC7\uB294\uB2E4.
      \uAC00\uC2B4\uC5D0\uC11C \uBE5B\uC774 \uC0C8\uC5B4\uB098\uC640 Dawn Priest\uC758
      \uC190\uC73C\uB85C \uD758\uB7EC\uAC04\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644798
    m_Localized: "\"\uC5F4\uC1E0\uB97C \uB118\uACBC\uC5B4. \uB9C8\uC9C0\uB9C9 \uC21C\uAC04\uC5D0
      \uC6B0\uB9B4 \uC778\uC815\uD55C \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644799
    m_Localized: "\"\uC774 \uBB34\uAC8C\uB97C \uBC1B\uC744 \uC790\uACA9\uC774...
      \uC788\uC744\uAE4C\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644800
    m_Localized: "\uC57C\uC218 \uAD70\uC8FC\uAC00 \uC4F0\uB7EC\uC9C4\uB2E4. \uBAB8\uC774
      \uD480\uB9AC\uBA74\uC11C \u2014 \uD55C \uC21C\uAC04 \u2014 \uC6D0\uB798 \uBAA8\uC2B5\uC774
      \uBE44\uCE5C\uB2E4. \uD06C\uACE0 \uC544\uB984\uB2E4\uC6B4 \uC9D0\uC2B9\uC774\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644801
    m_Localized: "\"\uC798 \uAC00\uB77C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644802
    m_Localized: "\"\uAE30\uC5B5\uD574 \uC904\uAC8C. \uC6D0\uB798 \uBAA8\uC2B5\uC73C\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644803
    m_Localized: "\uD30C\uD3B8\uC774 \uBB3C\uC5D0 \uB2FF\uC790, \uC218\uBA74 \uC704\uB85C
      80\uB144 \uC804\uC758 \uC601\uC0C1\uC774 \uB5A0\uC624\uB978\uB2E4. \uB204\uAD70\uAC00\uAC00
      \uB545\uC744 \uD30C\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644804
    m_Localized: "\"\uC131\uC720\uBB3C\uC774... \uB3C4\uAD74\uD488\uC774\uC5C8\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644805
    m_Localized: "\"80\uB144. \uADF8\uB3D9\uC548 \uC0C8\uB07C\uB4E4\uC774 \uC11C\uB85C
      \uBB3C\uC5B4\uB72F\uC740 \uC774\uC720\uAC00 \uC5EC\uAE30 \uC788\uC5C8\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644806
    m_Localized: "\uD0D1 \uB0B4\uBCBD\uC5D0 \uAE4A\uC774 \uC0C8\uACA8\uC9C4 \uBB38\uC591\uC774
      \uC788\uB2E4. \uC778\uAC04\uC758 \uC131\uBB3C \uB3C4\uC548\uB3C4, \uC57C\uC218\uC871\uC758
      \uAC08\uD034 \uC790\uAD6D\uB3C4 \uC544\uB2C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644807
    m_Localized: "\"\uC774 \uBB38\uC591\uC740... \uC5B4\uB514\uC11C\uB3C4 \uBCF8
      \uC801\uC774 \uC5C6\uC2B5\uB2C8\uB2E4. \uC131\uC804 \uAE30\uB85D\uC5D0\uB3C4
      \uC5C6\uB294 \uC591\uC2DD\uC774\uC5D0\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644808
    m_Localized: "\"\uC6B0\uB9AC \uAC83\uB3C4 \uC544\uB2C8\uC57C. \uB0C4\uC0C8\uAC00
      \uB2E4\uB974\uAC70\uB4E0. \uB3CC\uBCF4\uB2E4 \uC624\uB798\uB41C \uB0C4\uC0C8.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644809
    m_Localized: "\"\uBCF4\uACE0\uD560 \uAC83\uC774 \uC788\uC2B5\uB2C8\uB2E4. \uBB38\uC740
      \uBC16\uC5D0\uC11C\uAC00 \uC544\uB2C8\uB77C \uC548\uC5D0\uC11C \uBB34\uB108\uC84C\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644810
    m_Localized: "\"\uBCF4\uACE0\uB294 \uC88B\uC740\uB370. \uBBFF\uC744 \uC0AC\uB78C\uC774
      \uC788\uC73C\uB824\uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644811
    m_Localized: "\uB9C8\uC744\uC758 \uBD88\uBE5B\uC774 \uBCF4\uC778\uB2E4. \uC791\uACE0
      \uBD88\uC548\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644812
    m_Localized: "\"\uAD50\uD68C\uC5D0 \uBCF4\uACE0\uD574\uC57C \uD569\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC... \uBB34\uC5C7\uC744 \uBCF4\uACE0\uD574\uC57C \uD560\uC9C0
      \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644813
    m_Localized: "\"\uC9C4\uC2E4\uC744 \uBCF4\uACE0\uD574. \uB108\uD76C\uAC00 \uBB58
      \uD588\uB294\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501679644814
    m_Localized: "Dawn Priest\uAC00 \uB300\uB2F5\uD558\uC9C0 \uC54A\uB294\uB2E4.
      \uC0AC\uC81C \uC778\uC7A5\uC744 \uB9CC\uC9C0\uC791\uAC70\uB9AC\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501679644815
    m_Localized: "\"\uB9C8\uC744\uC774 \uC881\uC544 \uBCF4\uC774\uB124. \uC9C0\uD558\uC5D0
      3000\uB144\uCE58 \uAE30\uC5B5\uC744 \uBCF4\uACE0 \uC624\uB2C8\uAE4C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683838976
    m_Localized: "\"\uC2DC\uB044\uB7FD\uB2E4. \uC5EC\uAE30\uB3C4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683838977
    m_Localized: "\"\uC774\uC81C \uC2DC\uC791\uC785\uB2C8\uB2E4. \uBAA8\uB4E0 \uAC83\uC774.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683838978
    m_Localized: "\"\uB9C8\uC744\uC5D0 \uC640\uB3C4 \uC26C\uB294 \uAE30\uBD84\uC774
      \uC548 \uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683838979
    m_Localized: "\"\uC26C\uB294 \uAC74 \uB05D\uB098\uACE0 \uD574. \uB9CC\uC57D \uB05D\uB098\uBA74.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683838980
    m_Localized: "\"\uB05D\uB0C5\uB2C8\uB2E4. \uBC18\uB4DC\uC2DC.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683838981
    m_Localized: "\uB124 \uC0AC\uB78C\uC774 \uB9C8\uC744\uC744 \uB4F1\uC9C4\uB2E4.
      \uB9C8\uC9C0\uB9C9\uC73C\uB85C."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838982
    m_Localized: "\"\uB05D\uB0AC\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683838983
    m_Localized: "\"...\uB05D\uB0AC\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683838984
    m_Localized: "\uC138 \uC0AC\uB78C\uC774 \uB9C8\uC744\uB85C \uAC78\uC5B4 \uB4E4\uC5B4\uAC04\uB2E4.
      \uBE5B\uC774 \uB4F1 \uB4A4\uC5D0\uC11C \uBE44\uCD94\uACE0 \uC788\uB2E4. \uD55C
      \uBA85\uC774 \uBE60\uC838 \uC788\uB2E4. \uD558\uC9C0\uB9CC \uC11C \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838985
    m_Localized: "Ashen Gate\uC758 \uC794\uD574\uC5D0\uC11C \uCCAB \uBC88\uC9F8 Heartforge
      \uD30C\uD3B8\uC744 \uD655\uBCF4\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838986
    m_Localized: "\uCCAB \uB2E8\uC11C \uD68C\uC218"
    m_Metadata:
      m_Items: []
  - m_Id: 501683838987
    m_Localized: "Endless Cycle\uC774 \uD574\uAE08\uB418\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838988
    m_Localized: "\uC0C8 \uBAA8\uB4DC \uAC1C\uBC29"
    m_Metadata:
      m_Items: []
  - m_Id: 501683838989
    m_Localized: "Aegis Sentinel\uAC00 \uC6D0\uC815\uB300\uC5D0 \uD569\uB958\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838990
    m_Localized: "\uC601\uC6C5 \uD569\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 501683838991
    m_Localized: "Bastion Penitent\uAC00 \uC6D0\uC815\uB300\uC5D0 \uD569\uB958\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838992
    m_Localized: "\uC601\uC6C5 \uD569\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 501683838993
    m_Localized: "Echo Savant\uAC00 \uC6D0\uC815\uB300\uC5D0 \uD569\uB958\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838994
    m_Localized: "\uC601\uC6C5 \uD569\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 501683838995
    m_Localized: "Mirror Cantor\uAC00 \uC6D0\uC815\uB300\uC5D0 \uD569\uB958\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838996
    m_Localized: "\uC601\uC6C5 \uD569\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 501683838997
    m_Localized: "Pale Executor\uAC00 \uC6D0\uC815\uB300\uC5D0 \uD569\uB958\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683838998
    m_Localized: "\uC601\uC6C5 \uD569\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 501683838999
    m_Localized: "Prism Seeker\uAC00 \uC6D0\uC815\uB300\uC5D0 \uD569\uB958\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839000
    m_Localized: "\uC601\uC6C5 \uD569\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 501683839001
    m_Localized: "Rift Stalker\uAC00 \uC6D0\uC815\uB300\uC5D0 \uD569\uB958\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839002
    m_Localized: "\uC601\uC6C5 \uD569\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 501683839003
    m_Localized: "Shardblade\uAC00 \uC6D0\uC815\uB300\uC5D0 \uD569\uB958\uD588\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839004
    m_Localized: "\uC601\uC6C5 \uD569\uB958"
    m_Metadata:
      m_Items: []
  - m_Id: 501683839005
    m_Localized: "\uAE30\uC5B5 \uD22C\uC0AC\uAC00 \uBCBD\uC5D0 \uD3BC\uCCD0\uC9C4\uB2E4.
      \uD55C \uB0A8\uC790\uAC00 \uB545\uC5D0\uC11C \uACA9\uC790 \uD30C\uD3B8\uC744
      \uB72F\uC5B4\uB0B4\uACE0 \uC788\uB2E4. \uCC28\uBD84\uD55C \uC5BC\uAD74. \uD655\uC2E0\uC5D0
      \uCC2C \uC190."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839006
    m_Localized: "\"\uC800 \uC5BC\uAD74... \uAD50\uD68C \uCD08\uC0C1\uD654\uC5D0\uC11C
      \uBCF8 \uC801\uC774 \uC788\uC2B5\uB2C8\uB2E4. Aldric Sternholt.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839007
    m_Localized: "\"\uC544, \uC800 \uC0AC\uB78C. \uAE30\uC5B5\uD574. \uAF64 \uB611\uB612\uD55C
      \uC778\uAC04\uC774\uC5C8\uC9C0. 80\uB144 \uC804\uC774\uBA74... \uCD5C\uADFC\uC774\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839008
    m_Localized: "\"\uC774 \uC790\uC758 \uC758\uC9C0\uAC00... \uC544\uC9C1 \uC548\uC5D0
      \uC788\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839009
    m_Localized: "Echo Savant\uC758 \uBAB8\uC774 \uACBD\uC9C1\uB41C\uB2E4. \uBB34\uC5B8\uAC00\uB97C
      \uAC10\uC9C0\uD55C \uAC83\uC774\uB2E4 \u2014 \uACA9\uC790 \uC548\uCABD\uC5D0\uC11C."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839010
    m_Localized: "\"\uC0B4\uC544 \uC788\uB2E4\uB294 \uAC81\uB2C8\uAE4C? 40\uB144
      \uC804\uC5D0 \uC8FD\uC5C8\uB2E4\uACE0 \uAE30\uB85D\uB418\uC5B4 \uC788\uB294\uB370...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839011
    m_Localized: "\"\uC8FD\uC5C8\uB2E4. \uD558\uC9C0\uB9CC \uC758\uC9C0\uAC00 \uB0A8\uC558\uB2E4.
      \uC2EC\uC7A5\uC774 \uBA39\uC5C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839012
    m_Localized: "\"\uAE30\uC5B5\uC744 \uBA39\uB294 \uAE30\uACC4 \uC548\uC5D0\uC11C
      \uC8FD\uC5C8\uC73C\uBA74, \uAE30\uC5B5\uC774 \uB0A8\uB294 \uAC74 \uB2F9\uC5F0\uD558\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839013
    m_Localized: "\uAE30\uB85D\uC2E4 \uBC14\uB2E5\uC5D0 \uBB3C\uC774 \uCC28 \uC788\uB2E4.
      \uC120\uBC18 \uC704\uCABD\uC5D0\uB9CC \uCC45\uC774 \uB0A8\uC544 \uC788\uB2E4.
      Dawn Priest\uAC00 \uD55C \uAD8C\uC744 \uAEBC\uB0B8\uB2E4. \uD45C\uC9C0\uC5D0
      \uC11C\uBA85."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839014
    m_Localized: "\"A. Sternholt... \uC774 \uC774\uB984\uC744 \uC54C\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uAD50\uD68C \uCC3D\uC124 \uBB38\uC11C\uC5D0...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839015
    m_Localized: "\uC800\uB110 \uB9C8\uC9C0\uB9C9 \uD398\uC774\uC9C0\uC5D0 \uB2E4\uB978
      \uC789\uD06C\uB85C \uC4F4 \uBA54\uBAA8\uAC00 \uC788\uB2E4. '\uC81C4\uC218\uBB38
      \u2014 \uACA9\uC790\uAC00 \uC6B0\uB9AC\uAC00 \uC0DD\uAC01\uD55C \uAC83\uBCF4\uB2E4
      \uB354 \uB9CE\uC740 \uAC83\uC744 \uAE30\uC5B5\uD558\uACE0 \uC788\uB2E4. \uB124
      \uBC88\uC9F8 \uBD09\uC778 \uB4A4\uC5D0 \uBB34\uC5B8\uAC00 \uC7A0\uB4E4\uC5B4
      \uC788\uB2E4.'"
    m_Metadata:
      m_Items: []
  - m_Id: 501683839016
    m_Localized: "\"\uC81C4\uC218\uBB38? \uC601\uC6D0\uD55C \uC9C8\uC11C\uC758 \uAD50\uB9AC\uC5D0\uB294
      \uC218\uBB38\uC774 \uC138 \uAC1C\uBFD0\uC785\uB2C8\uB2E4. \uB124 \uBC88\uC9F8\uB77C\uB2C8...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839017
    m_Localized: "\"\uC138 \uAC1C\uB77C\uACE0 \uAC00\uB974\uCE58\uACE0 \uB124 \uAC1C\uC9F8\uB97C
      \uC228\uACBC\uB2E4? \uB108\uD76C \uC2E0\uC559\uB2F5\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839018
    m_Localized: "\"\uB204\uAD70\uB370.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839019
    m_Localized: "\"\uCD08\uB300 \uD559\uC790-\uC218\uC7A5\uC785\uB2C8\uB2E4. \uC601\uC6D0\uD55C
      \uC9C8\uC11C\uC758 \uAD50\uB9AC\uB97C \uC124\uACC4\uD55C \uC0AC\uB78C. \uC81C\uAC00
      \uBC30\uC6B4 \uBAA8\uB4E0 \uAE30\uB3C4\uC758... \uADFC\uC6D0\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839020
    m_Localized: "\uADF8\uB140\uC758 \uC190\uC774 \uD398\uC774\uC9C0\uB97C \uB118\uAE34\uB2E4.
      \uD544\uCCB4\uAC00 \uC810\uC810 \uAC70\uCE60\uC5B4\uC9C4\uB2E4. \uCD08\uBC18\uC758
      \uC815\uB3C8\uB41C \uAE00\uC528\uAC00 \uD6C4\uBC18\uC5D0\uB294 \uAC08\uACA8
      \uC4F4 \uAC83\uCC98\uB7FC \uBCC0\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839021
    m_Localized: "\"\uB124 \uAE30\uB3C4\uB97C \uB9CC\uB4E0 \uB188\uC774 \uB545\uC744
      \uD30C\uACE0 \uC788\uC5C8\uB2E4\uACE0? \uB300\uB2E8\uD55C \uC2E0\uC774\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839022
    m_Localized: "\"\uC77C\uC9C0\uC5D0 \uACA9\uC790 \uD30C\uD3B8\uC758 \uAD70\uC0AC
      \uC804\uC6A9 \uC808\uCC28\uAC00... \uC774\uAC83\uC774 \uBC29\uBCBD \uAE30\uC220\uC758
      \uAE30\uBC18\uC774\uC5C8\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839023
    m_Localized: "Dawn Priest\uAC00 \uC77C\uC9C0\uB97C \uB2EB\uB294\uB2E4. \uC7A0\uC2DC
      \uB3D9\uC548 \uC544\uBB34 \uB9D0\uB3C4 \uD558\uC9C0 \uC54A\uB294\uB2E4. \uBB3C\uC774
      \uBC1C\uBAA9\uC744 \uC801\uC2DC\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839024
    m_Localized: "\"\uC774 \uC0AC\uB78C\uC774 \uBAA8\uB4E0 \uAC83\uC744 \uC124\uACC4\uD588\uC2B5\uB2C8\uB2E4.
      \uAD50\uB9AC\uB3C4. \uBC29\uBCBD\uB3C4. \uC804\uBD80.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839025
    m_Localized: "\"\uC774\uC81C\uC57C \uB124 \uC9D1 \uAE30\uB465\uC774 \uB3C4\uB451\uC9C8\uB85C
      \uC138\uC6CC\uC9C4 \uAC78 \uC54C\uC558\uAD70.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839026
    m_Localized: "\uC720\uB9AC \uD30C\uD3B8\uC774 \uC6B8\uB9AC\uAE30 \uC2DC\uC791\uD55C\uB2E4.
      \uAC19\uC740 \uC18C\uB9AC\uAC00 \uC544\uB2C8\uB2E4. \uAC01\uC790 \uB2E4\uB978
      \uC8FC\uD30C\uC218\uB85C."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839027
    m_Localized: "(to Dawn Priest) \"\uADF8\uB300\uC758 \uC18D\uC8C4\uAC00 \uC774\uAC83\uC744
      \uC694\uAD6C\uD558\uC624. \uC815\uD654\uB9CC\uC774 \uADF8\uB300\uAC00 \uC9C4
      \uBE5A\uC744 \uAC1A\uB294 \uAE38\uC774\uC624.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839028
    m_Localized: "\"\uC774 \uBAA9\uC18C\uB9AC... \uC800\uB110\uC758 \uD544\uCCB4\uC640
      \uAC19\uC740 \uC0AC\uB78C. \uC65C \uC81C\uAC8C...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839029
    m_Localized: "(to Pack Raider) \"\uBD09\uC778\uD558\uC2DC\uC624. \uBB34\uB9AC\uAC00
      \uC548\uC804\uD574\uC9C0\uC624. \uC9C0\uAE08, \uB2F9\uC7A5. \uD76C\uC0DD\uC740
      \uD544\uC694 \uC5C6\uC18C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839030
    m_Localized: "\"\uAEBC\uC838. \uB124 \uBAA9\uC18C\uB9AC\uAC00 \uB2EC\uCF64\uD560\uC218\uB85D
      \uC369\uC740 \uB0C4\uC0C8\uAC00 \uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839031
    m_Localized: "Pack Raider\uAC00 \uCF54\uB97C \uCC21\uADF8\uB9B0\uB2E4. \uD558\uC9C0\uB9CC
      \uC190\uC774 \uB5A8\uB9B0\uB2E4. \uBD09\uC778\uC774\uB77C\uB294 \uB9D0\uC5D0
      \uD754\uB4E4\uB838\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839032
    m_Localized: "\"\uC774 \uC790\uB294 \uC6B0\uB9AC\uAC00 \uB4E3\uACE0 \uC2F6\uC740
      \uB9D0\uC744 \uD558\uACE0 \uC788\uC5B4\uC694. \uADF8\uAC8C \uAC00\uC7A5 \uC704\uD5D8\uD55C
      \uAC70\uC608\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839033
    m_Localized: "\"...\uC54C\uC544. \uC54C\uACE0 \uC788\uC5B4. \uADF8\uB798\uB3C4
      \uBC18\uC740 \uB9DE\uB294 \uB9D0\uC774\uC796\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839034
    m_Localized: "\uC7AC\uAC00 \uBC14\uB78C\uC5D0 \uC2E4\uB824 \uC628\uB2E4. \uAD6D\uACBD\uBB38\uC758
      \uCCA0 \uD30C\uD3B8\uC774 \uB4E4\uD310\uC5D0 \uBC15\uD600 \uC788\uACE0, \uADF8
      \uC704\uB85C \uAE4C\uB9C8\uADC0 \uD55C \uB9C8\uB9AC\uAC00 \uC6C0\uC9C1\uC774\uC9C0
      \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839035
    m_Localized: "\"\uC9D1\uC815\uAD00 \uD68C\uC758\uC758 \uBA85\uC5D0 \uB530\uB77C,
      \uC774 \uBB38 \uB108\uBA38\uB97C \uC870\uC0AC\uD569\uB2C8\uB2E4. \uC601\uC6D0\uD55C
      \uC9C8\uC11C\uC758 \uC774\uB984\uC73C\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839036
    m_Localized: "\uBC14\uB78C\uC774 \uBC29\uD5A5\uC744 \uBC14\uAFBC\uB2E4. \uC7AC\uAC00
      \uC6D0\uC815\uB300\uC758 \uB4F1 \uB4A4\uB85C \uD758\uB7EC\uAC04\uB2E4. \uB3CC\uC544\uAC08
      \uAE38\uC774 \uD68C\uC0C9\uC73C\uB85C \uBB3B\uD78C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839037
    m_Localized: "\"\uAE30\uB85D\uC740 \uC798 \uD558\uC2DC\uB124. \uC0B4\uC544\uC11C
      \uC77D\uC744 \uC218 \uC788\uC73C\uBA74 \uC88B\uACA0\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839038
    m_Localized: "\"\uB108\uD76C\uAC00 \uC138\uC6B4 \uBB38\uC774\uC796\uC544. \uB108\uD76C
      \uC190\uC73C\uB85C \uB2EB\uC558\uACE0, \uB108\uD76C \uC190\uC73C\uB85C \uBD80\uC248\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839039
    m_Localized: "\"\uC548\uC5D0\uC11C\uBD80\uD130 \uBD80\uC11C\uC9C4 \uD754\uC801\uC785\uB2C8\uB2E4.
      \uC678\uBD80 \uCE68\uACF5\uC758 \uC591\uC0C1\uC774 \uC544\uB2D9\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839040
    m_Localized: "Dawn Priest\uAC00 \uCCA0 \uD30C\uD3B8\uC5D0 \uC190\uC744 \uB304\uB2E4.
      \uC190\uB05D\uC5D0 \uC7AC\uAC00 \uBB3B\uACE0, \uADF8 \uC544\uB798 \uAE08\uC18D\uC774
      \uC544\uC9C1 \uB530\uB73B\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839041
    m_Localized: "\"\uC7AC \uB0C4\uC0C8\uAC00 \uC0AC\uD758\uC9F8 \uBC14\uB78C\uC744
      \uD0C0\uACE0 \uC654\uB2E4. \uCF54\uAC00 \uBA39\uBA39\uD574\uC9C8 \uC815\uB3C4\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839042
    m_Localized: "\"\uAE4C\uB9C8\uADC0\uAC00 \uB0AE\uAC8C \uC549\uC544 \uC788\uC2B5\uB2C8\uB2E4.
      \uBA39\uC744 \uAC83\uC774 \uB9CE\uB2E4\uB294 \uB73B\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839043
    m_Localized: "Pack Raider\uAC00 \uCF54\uB97C \uCC21\uADF8\uB9B0\uB2E4. \uADF8\uC758
      \uB208\uC774 \uB4E4\uD310\uC744 \uD6D1\uB294\uB2E4 \u2014 \uC2DC\uCCB4\uAC00
      \uC544\uB2C8\uB77C \uB0C4\uC0C8\uB97C \uC77D\uB294 \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839044
    m_Localized: "\"\uC2DC\uCCB4 \uC369\uB294 \uB0C4\uC0C8\uAC00 \uC544\uB2C8\uC57C.
      \uB3CC\uC774 \uD0C4 \uB0C4\uC0C8\uB2E4. \uB545 \uBC11\uC5D0\uC11C \uBB54\uAC00\uAC00
      \uC62C\uB77C\uC654\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839045
    m_Localized: "\"\uAE30\uB85D\uD558\uACA0\uC2B5\uB2C8\uB2E4. \uBB38\uC740 \uBC16\uC5D0\uC11C\uAC00
      \uC544\uB2C8\uB77C \uC548\uC5D0\uC11C \uBB34\uB108\uC84C\uB2E4\uACE0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839046
    m_Localized: "\uBF08\uAC00 \uB098\uBB34\uCC98\uB7FC \uC790\uB77C \uC788\uB2E4.
      \uAC00\uC9C0\uB9C8\uB2E4 \uC778\uAD11\uC774 \uB9E4\uB2EC\uB824 \uC788\uACE0,
      \uACF5\uAE30\uAC00 \uB450\uAEBC\uC6CC \uC228\uC26C\uAE30\uAC00 \uD798\uB4E4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839047
    m_Localized: "\"\uC5EC\uAE30\uB294 \uAE30\uC5B5\uC758 \uC6B0\uBB3C\uC774 \uC544\uB2C8\uB77C
      \uBC14\uB2E4\uC57C. \uBC00\uB3C4\uAC00 \uBB18\uC5ED\uC758 \uC218\uC2ED \uBC30.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839048
    m_Localized: "\"\uBF08\uAC00 \uBFCC\uB9AC\uCC98\uB7FC \uC790\uB790\uC5B4. \uC232\uC774\uB791\uC740
      \uB2E4\uB978 \uB0C4\uC0C8\uC57C. \uB3CC \uB0C4\uC0C8\uD558\uACE0... \uC2AC\uD514
      \uB0C4\uC0C8.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839049
    m_Localized: "\"\uACA9\uC790 \uC870\uAC01\uC774 \uBE5B\uB098\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uBB34\uC5B8\uAC00\uAC00 \uAE68\uC5B4\uB098\uB824 \uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839050
    m_Localized: "\"\uC870\uC2EC\uD574. \uC5EC\uAE30\uC11C \uBE60\uC9C0\uBA74 \uBABB
      \uB098\uC640. \uAE30\uC5B5\uC774 \uC0BC\uCF1C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839051
    m_Localized: "\uBC14\uB2E5\uC758 \uACA9\uC790\uBB38\uC774 \uD76C\uBBF8\uD558\uAC8C
      \uB9E5\uB3D9\uD55C\uB2E4. \uC2EC\uC7A5\uBC15\uB3D9 \uAC19\uC740 \uB9AC\uB4EC."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839052
    m_Localized: "\"\uBC11\uC5D0\uC11C \uBB54\uAC00\uAC00 \uB6F4\uB2E4. \uC2EC\uC7A5
      \uC18C\uB9AC \uAC19\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839053
    m_Localized: "\"\uC2EC\uC7A5\uC774 \uC544\uB2D9\uB2C8\uB2E4. \uB354 \uC624\uB798\uB41C
      \uAC83\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839054
    m_Localized: "\uACA9\uC790\uBB38\uC758 \uBE5B\uC774 \uAC15\uD574\uC9C4\uB2E4.
      \uC11D\uD654 \uB098\uBB34 \uC0AC\uC774\uC5D0\uC11C, \uBB34\uC5B8\uAC00\uAC00
      \uB208\uC744 \uB728\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839055
    m_Localized: "\"...\uC774\uAC74 \uAE30\uC5B5\uC758 \uC794\uD5A5\uC774 \uC544\uB2C8\uC57C.
      \uC0B4\uC544 \uC788\uB294 \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839056
    m_Localized: "\uB300\uC2EC\uBB38\uAD00\uC774 \uC4F0\uB7EC\uC9C4\uB2E4. \uC190\uC5D0\uC11C
      \uAEBC\uC9C0\uB294 \uBE5B\uC774 Dawn Priest\uC758 \uC190\uB05D\uC5D0\uC11C\uB3C4
      \uAC19\uC740 \uC0C9\uC73C\uB85C \uAE5C\uBE61\uC778\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839057
    m_Localized: "\"\uCD95\uBCF5\uACFC \uC815\uD654\uAC00 \uAC19\uC740 \uC6D0\uB9AC\uC600\uC2B5\uB2C8\uB2E4.
      \uC81C \uAE30\uB3C4\uC640 \uC800 \uC790\uC758 \uBD88\uAF43\uC740... \uBC29\uD5A5\uB9CC
      \uB2EC\uB790\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839058
    m_Localized: "\"\uC774 \uBAA9\uC18C\uB9AC... \uACBD\uC804\uC758 \uC11C\uBB38\uACFC
      \uAC19\uC740 \uC5B4\uC870\uC785\uB2C8\uB2E4. \uC65C \uBB34\uAE30\uC5D0\uC11C...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839059
    m_Localized: "Dawn Priest\uAC00 \uC790\uAE30 \uC190\uC744 \uB0B4\uB824\uB2E4\uBCF8\uB2E4.
      \uC624\uB798\uB3C4\uB85D."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839060
    m_Localized: "\"\uC0AC\uC81C \uC5BC\uAD74\uC774 \uCC98\uC74C\uC73C\uB85C \uBB34\uB108\uC84C\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839061
    m_Localized: "\"\uBB34\uB108\uC9C4 \uAC8C \uB9DE\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839062
    m_Localized: "\uBB3C\uC774 \uB300\uC2EC\uBB38\uAD00\uC758 \uBAB8 \uC704\uB85C
      \uCC28\uC624\uB978\uB2E4. \uBE5B\uC774 \uC644\uC804\uD788 \uAEBC\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839063
    m_Localized: "\"\uBBFF\uB358 \uAC8C \uBD80\uC11C\uC9C0\uB294 \uC18C\uB9AC\uAC00
      \uC774\uB807\uAC8C \uD06C\uB354\uB77C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839064
    m_Localized: "\"...\uC608.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839065
    m_Localized: "\uB300\uC2EC\uBB38\uAD00\uC758 \uAC11\uC637\uC5D0\uC11C \uACA9\uC790
      \uD30C\uD3B8\uC774 \uBE60\uC838\uB098\uC624\uBA70 \uC9E7\uC740 \uC74C\uC131\uC774
      \uC6B8\uB9B0\uB2E4. \uC624\uB798\uB41C \uB9D0\uD22C. \uAD50\uB9AC\uCC98\uB7FC
      \uB4E4\uB9AC\uC9C0\uB9CC \uBB34\uAE30\uC5D0\uC11C \uB098\uC628\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839066
    m_Localized: "\"...\uD1B5\uC81C\uD560 \uC218 \uC788\uC18C. \uC9C8\uC11C\uB294
      \uB3C4\uAD6C\uC5D0\uC11C \uC2DC\uC791\uD558\uC624...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839067
    m_Localized: "\uD68C\uC0C9 \uC1A1\uACF3\uB2C8\uAC00 \uC4F0\uB7EC\uC9C4\uB2E4.
      \uBAB8\uC5D0\uC11C \uBE5B\uC774 \uC0C8\uC5B4\uB098\uC628\uB2E4 \u2014 Heartforge
      \uD30C\uD3B8\uC774 \uADF8\uC758 \uC0B4 \uC548\uC5D0 \uBC15\uD600 \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839068
    m_Localized: "\"...\uD615\uC81C\uAC00 \uB9C8\uC9C0\uB9C9\uC5D0 \uB9D0\uD588\uC5B4.
      '\uC774 \uBD84\uB178\uAC00 \uB0B4 \uAC83\uC774 \uC544\uB2D0 \uC218\uB3C4 \uC788\uB2E4'\uACE0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839069
    m_Localized: "Pack Raider\uAC00 \uD615\uC81C\uC758 \uBAB8\uC5D0\uC11C \uD30C\uD3B8\uC744
      \uBF51\uB294\uB2E4. \uC190\uC774 \uB5A8\uB9B0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839070
    m_Localized: "\"\uBC14\uB78C\uC774 \uC544\uB2C8\uC57C. \uB545 \uBC11\uC5D0\uC11C
      \uC62C\uB77C\uC628 \uAC70\uC57C. \uC774\uB188\uC744 \uBBF8\uCE58\uAC8C \uB9CC\uB4E0
      \uAC83\uC774.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839071
    m_Localized: "\"\uC801\uB300\uAC00 \uC870\uC791\uB41C \uAC83\uC774\uB77C\uBA74...
      \uCC98\uC74C\uC73C\uB85C, \uD568\uAED8 \uAC78\uC744 \uC774\uC720\uAC00 \uC0DD\uACBC\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839072
    m_Localized: "\"\uC774\uC720 \uB530\uC704 \uD544\uC694 \uC5C6\uC5B4. \uD615\uC81C\uB97C
      \uBBF8\uCE58\uAC8C \uB9CC\uB4E0 \uB188\uC774 \uBC11\uC5D0 \uC788\uB2E4\uBA74
      \uAC00\uB294 \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839073
    m_Localized: "Pack Raider\uAC00 \uD30C\uD3B8\uC744 \uC8FC\uBA38\uB2C8\uC5D0 \uB123\uB294\uB2E4.
      Dawn Priest\uAC00 \uC190\uC744 \uBED7\uC9C0\uB9CC \u2014 \uADF8\uAC00 \uB208\uC73C\uB85C
      \uAC70\uC808\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839074
    m_Localized: "\"...\uC54C\uACA0\uC2B5\uB2C8\uB2E4. \uB2F9\uC2E0\uC758 \uAC83\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839075
    m_Localized: "\uC0C1\uC2B9\uC774 \uC2DC\uC791\uB41C\uB2E4. \uAE34 \uD1B5\uB85C.
      \uBC1C\uC18C\uB9AC\uAC00 \uC138 \uC0AC\uB78C\uBD84\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839076
    m_Localized: "Worldscar\uC758 \uC881\uC740 \uD2C8 \uC0AC\uC774\uB85C \uD558\uB298\uC774
      \uBCF4\uC778\uB2E4. \uC7AC\uAC00 \uC544\uB2C8\uB77C \uBE5B\uC774 \uB0B4\uB824\uC628\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839077
    m_Localized: "\"\uD55C \uBA85\uC774 \uBE60\uC84C\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839078
    m_Localized: "\uC544\uBB34\uB3C4 \uB300\uAFB8\uD558\uC9C0 \uC54A\uB294\uB2E4.
      \uBE5B\uC774 \uC138 \uC0AC\uB78C\uC758 \uC5BC\uAD74\uC744 \uBE44\uCD98\uB2E4.
      \uC9C0\uCE58\uACE0, \uC0C1\uCC98 \uC785\uACE0, \uC904\uC5B4\uB4E4\uC5C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC11C \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839079
    m_Localized: "\"\uBE5B\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839080
    m_Localized: "\uADF8\uB140\uC758 \uC190\uC5D0 \uC0AC\uC81C \uC778\uC7A5\uC774
      \uC5C6\uB2E4. \uB300\uC2E0 Aldric\uC758 \uC77C\uC9C0\uAC00 \uC788\uB2E4. \uC99D\uAC70\uB97C
      \uAC00\uC838\uAC04\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839081
    m_Localized: "\"\uB530\uB73B\uD574. \uBC14\uB78C\uC774.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839082
    m_Localized: "Pack Raider\uAC00 \uCF54\uB97C \uB4E4\uC5B4\uC62C\uB9B0\uB2E4.
      \uC7AC \uB0C4\uC0C8\uAC00 \uC544\uB2C8\uB2E4. \uD759 \uB0C4\uC0C8. \uC0B4\uC544
      \uC788\uB294 \uD759."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839083
    m_Localized: "\"...\uC5EC\uAE30 \uCC98\uC74C \uC628 \uAE30\uBD84\uC774\uC57C.
      \uC774\uC0C1\uD558\uB124. \uBD84\uBA85 \uC544\uB294 \uACF3\uC778\uB370.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839084
    m_Localized: "\uADF8\uB140\uAC00 \uC783\uC5B4\uBC84\uB9B0 \uAC83\uC758 \uD754\uC801.
      \uC775\uC219\uD568\uC758 \uBD80\uC7AC."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839085
    m_Localized: "\"\uAD1C\uCC2E\uC2B5\uB2C8\uB2E4. \uC0C8\uB85C\uC6B4 \uAE30\uC5B5\uC744
      \uB9CC\uB4E4\uBA74 \uB429\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839086
    m_Localized: "\uC138 \uC0AC\uB78C\uC774 \uBC16\uC73C\uB85C \uB098\uC628\uB2E4.
      \uD558\uB298\uC774 \uC5F4\uB824 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839087
    m_Localized: "\uC720\uB9AC \uC232 \uACBD\uACC4\uC5D0\uC11C \uC791\uC740 \uADF8\uB9BC\uC790\uAC00
      \uB2EC\uB824\uC628\uB2E4. \uC57C\uC218\uC871 \uC18C\uB140. \uB2E4\uB9AC\uC5D0
      \uD53C\uAC00 \uBB3B\uC5B4 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839088
    m_Localized: "\"\uD615... \uC624\uBE60! \uC7A5\uB85C\uB4E4\uC774... Grey Fang\uC774
      \uC11C\uC57D\uC744 \uCCA0\uD68C\uD588\uC5B4\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839089
    m_Localized: "\"\uC0AC\uC2E4\uC774\uC57C. \uADF8\uB9AC\uACE0 \uB3CC\uC544\uC624\uC9C0
      \uC54A\uC740 \uCABD\uB3C4 \uC0B4\uC558\uC5B4. \uB2E4\uB9CC \uB2E4\uB978 \uC774\uB984\uC73C\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839090
    m_Localized: "\"\uBB50\uB77C\uACE0?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839091
    m_Localized: "\"\uC778\uAC04\uACFC \uC190\uC7A1\uC740 \uAC74 \uBC30\uC2E0\uC774\uB798\uC694.
      \uBB34\uB9AC\uC758 \uBC18\uC774 \uB5A0\uB0AC\uC5B4\uC694. Grey Fang\uC774 \uC774\uB04C\uACE0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839092
    m_Localized: "Pack Raider\uAC00 \uC544\uBB34 \uB9D0\uB3C4 \uD558\uC9C0 \uC54A\uB294\uB2E4.
      \uBD84\uB178\uAC00 \uC544\uB2C8\uB2E4. \uBE44\uC5B4 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839093
    m_Localized: '"Pack Raider..."'
    m_Metadata:
      m_Items: []
  - m_Id: 501683839094
    m_Localized: "\"...\uD615\uC81C\uAC00 \uB0A0 \uBC84\uB838\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839095
    m_Localized: "\uADF8\uAC00 \uCC98\uC74C\uC73C\uB85C \uB0C4\uC0C8\uB3C4 \uBC14\uB78C\uB3C4
      \uC774\uC57C\uAE30\uD558\uC9C0 \uC54A\uB294\uB2E4. \uAC10\uAC01\uC774 \uAEBC\uC9C4
      \uAC83 \uAC19\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839096
    m_Localized: "\"400\uB144 \uC804\uC5D0\uB3C4 \uAC19\uC740 \uC77C\uC774 \uC788\uC5C8\uC9C0.
      \uBB34\uB9AC\uAC00 \uCABC\uAC1C\uC9C0\uACE0, \uD55C\uCABD\uC774 \uB3CC\uC544\uC624\uC9C0
      \uC54A\uC558\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839097
    m_Localized: "\"\uC704\uB85C\uC57C? \uB18D\uB2F4\uC774\uC57C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839098
    m_Localized: "\uC720\uB9AC \uC232\uC758 \uAC00\uC7A5\uC790\uB9AC. Worldscar \uD558\uAC15\uB85C\uAC00
      \uBCF4\uC778\uB2E4. \uB124 \uC0AC\uB78C\uC774 \uC11C \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839099
    m_Localized: "\"\uC800\uB294 Aldric\uC774 \uB9CC\uB4E0 \uAD50\uB9AC\uB97C \uB193\uC544\uC57C
      \uD569\uB2C8\uB2E4. \uC0AC\uC81C \uC778\uC7A5\uC774 \uBCF4\uC99D\uD558\uB294
      \uAC83\uC774... \uB354 \uC774\uC0C1 \uC81C \uAC83\uC774 \uC544\uB2D9\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839100
    m_Localized: "\"\uB098\uB294 \uB0A8\uB294\uB2E4. \uACA9\uC790 \uC548\uC5D0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839101
    m_Localized: "\uAC00\uC7A5 \uC9E7\uC740 \uBB38\uC7A5. \uAC00\uC7A5 \uBB34\uAC70\uC6B4
      \uBB38\uC7A5."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839102
    m_Localized: "\"...\uBB50\uB77C\uACE0?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839103
    m_Localized: "\"\uC601\uAD6C \uC218\uD638\uC790\uAC00 \uD544\uC694\uD558\uB2E4.
      \uC790\uC6D0\uD55C\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839104
    m_Localized: "\"\uB2E4\uB978 \uBC29\uBC95\uC774...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839105
    m_Localized: "\"1800\uB144 \uC804\uC5D0\uB3C4 \uC120\uD0DD\uD588\uB2E4. \uC774\uBC88\uC5D0\uB294
      \uB208\uC744 \uB728\uACE0 \uD55C\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839106
    m_Localized: "\"\uB09C \uC774\uBBF8 \uC528\uC871 \uBC18\uC744 \uC783\uC5C8\uC5B4.
      \uB354 \uC783\uC744 \uAC83\uB3C4 \uC5C6\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839107
    m_Localized: "\"\uB09C \uAC00\uC7A5 \uC624\uB798\uB41C \uAE30\uC5B5\uC744 \uC918\uC57C
      \uD574. \uB0B4\uAC00 \uB204\uAD6C\uC600\uB294\uC9C0\uC758 \uCC98\uC74C\uC744.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839108
    m_Localized: "Grave Hexer\uAC00 \uC6C3\uB294\uB2E4. \uD3C9\uC18C\uC758 \uAC74\uC870\uD55C
      \uC6C3\uC74C\uC774 \uC544\uB2C8\uB2E4. \uC57D\uAC04 \uB354 \uC587\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839109
    m_Localized: "\"\uBB50, \uCCAB \uAE30\uC5B5 \uC5C6\uC774\uB3C4 400\uB144\uC740
      \uC0B4\uC558\uC796\uC544. \uC5BC\uB9C8\uB098 \uC911\uC694\uD558\uACA0\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839110
    m_Localized: "\"\uC548\uC740 \uB108\uBB34 \uC870\uC6A9\uD558\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839111
    m_Localized: "\"\uBB50\uAC00?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839112
    m_Localized: "\"\uACA9\uC790 \uC548. 1800\uB144. \uC544\uBB34 \uC18C\uB9AC\uB3C4
      \uC5C6\uC5C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839113
    m_Localized: "Grave Hexer\uAC00 \uADF8 \uB9D0\uC758 \uBB34\uAC8C\uB97C \uC774\uD574\uD558\uAE30
      \uC804\uC5D0, Echo Savant\uAC00 \uC785\uC744 \uC5F0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839114
    m_Localized: "\uACA9\uC790 \uC548\uC5D0\uC11C \uD504\uB9AC\uC998 \uBCF4\uB77C\uBE5B\uC774
      \uC77C\uC815\uD55C \uB9AC\uB4EC\uC73C\uB85C \uB9E5\uB3D9\uD55C\uB2E4. Echo
      Savant\uC758 \uD615\uC0C1\uC774 \uD76C\uBBF8\uD558\uAC8C \uBCF4\uC778\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839115
    m_Localized: "\"\uAC10\uC0AC\uD569\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839116
    m_Localized: "\uADF8\uC758 \uB9C8\uC9C0\uB9C9 \uB9D0\uC774\uB2E4. \uACA9\uC790\uAC00
      \uACE0\uC694\uD574\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839117
    m_Localized: "\uB300\uB2F5\uC774 \uC5C6\uB2E4. \uD55C\uCC38 \uB3D9\uC548."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839118
    m_Localized: "\"...\uB4E4\uB9AC\uB098?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839119
    m_Localized: "\uB9E5\uB3D9\uC774 \uD55C \uBC88 \uAC15\uD574\uC9C4\uB2E4. \uB300\uB2F5\uC778
      \uAC83 \uAC19\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839120
    m_Localized: "\"\uAE30\uC5B5\uD574 \uC904\uAC8C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839121
    m_Localized: "Grave Hexer\uAC00 \uBA48\uCD98\uB2E4. \uADF8\uB140\uAC00 \uBB34\uC5C7\uC744
      \uAE30\uC5B5\uD560 \uC218 \uC788\uB294\uC9C0, \uC774\uC81C \uBCF8\uC778\uB3C4
      \uD655\uC2E4\uD558\uC9C0 \uC54A\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839122
    m_Localized: "\"...\uAE30\uC5B5\uD560 \uC218 \uC788\uB294 \uB9CC\uD07C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839123
    m_Localized: "\uB9E5\uB3D9\uC774 \uB610 \uD55C \uBC88. \uC774\uBC88\uC5D0\uB294
      \uC57D\uD558\uB2E4. \uBA40\uC5B4\uC9C0\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839124
    m_Localized: "\"...\uC2DC\uB044\uB7FD\uC9C0 \uC54A\uB2E4. \uCC98\uC74C\uC73C\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839125
    m_Localized: "\uACFC\uC218\uC6D0 \uCD9C\uAD6C. \uBF08\uB098\uBB34 \uC0AC\uC774\uB85C
      \uC778\uAD11\uC774 \uC2A4\uB7EC\uC9C4\uB2E4. \uC55E\uC11C \uAC77\uB294 \uC138
      \uC0AC\uB78C\uACFC \uB5A8\uC5B4\uC838, \uB458\uC774 \uB098\uB780\uD788 \uAC77\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839126
    m_Localized: "\"\uAE30\uC5B5\uC744 \uC5B4\uB5BB\uAC8C \uACAC\uB514\uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839127
    m_Localized: "\"...\uBB50?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839128
    m_Localized: "\"\uADF8 \uBB34\uAC8C\uB97C. \uC218\uBC31 \uB144. \uC5B4\uB5BB\uAC8C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839129
    m_Localized: "\"\uB18D\uB2F4\uC744 \uD574. 400\uB144 \uC804 \uC77C\uC744 \uC5B4\uC81C
      \uC77C\uCC98\uB7FC \uB9D0\uD558\uBA74 \uC0AC\uB78C\uB4E4\uC774 \uC6C3\uAC70\uB4E0.
      \uC6C3\uAE30\uBA74 \uACAC\uB51C \uB9CC\uD574.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839130
    m_Localized: '"..."'
    m_Metadata:
      m_Items: []
  - m_Id: 501683839131
    m_Localized: "Echo Savant\uAC00 \uC6C3\uC9C0 \uC54A\uB294\uB2E4. Grave Hexer\uB294
      \uADF8\uAC83\uC744 \uC54C\uC544\uCC28\uB9B0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839132
    m_Localized: "\"\uB108\uB294 \uC548 \uC6C3\uB294\uAD6C\uB098. 1800\uB144 \uB3D9\uC548
      \uD63C\uC790 \uC788\uC73C\uBA74 \uADF8\uB807\uAC8C \uB418\uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839133
    m_Localized: "\"\uC6C3\uB294 \uBC95\uC744 \uC78A\uC5C8\uB2E4. \uACA9\uC790 \uC548\uC5D0\uB294
      \uC6C3\uC744 \uC774\uC720\uAC00 \uC5C6\uC5C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839134
    m_Localized: "\"\uADF8\uB7FC \uB0B4\uAC00 \uB300\uC2E0 \uC6C3\uC5B4 \uC904\uAC8C.
      \uB124 \uBAAB\uAE4C\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839135
    m_Localized: "Aldric\uC774 \uC11C \uC788\uB2E4. \uAD34\uBB3C\uC774 \uC544\uB2C8\uB2E4.
      \uD55C \uB0A8\uC790\uC758 \uD615\uC0C1. \uD559\uC790\uC758 \uAC00\uC6B4\uC744
      \uC785\uACE0 \uC788\uB2E4. \uB208\uC774 \uCC28\uBD84\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839136
    m_Localized: "\"80\uB144\uC774\uC624. 80\uB144 \uB3D9\uC548 \uB0B4\uAC00 \uB9CC\uB4E0
      \uC9C8\uC11C\uAC00 \uC774 \uC138\uACC4\uB97C \uC720\uC9C0\uD588\uC18C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839137
    m_Localized: "\"\uCD5C\uC120\uC774 \uC774\uAC70\uC600\uB2E4\uBA74. \uCD5C\uC120\uC774
      \uB05D\uB0A0 \uB54C\uAC00 \uB410\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839138
    m_Localized: "\"\uB2F9\uC2E0\uC774 \uB9CC\uB4E0 \uC9C8\uC11C\uAC00 \uC544\uB2CC,
      \uC6B0\uB9AC\uAC00 \uC120\uD0DD\uD55C \uC9C8\uC11C\uB97C \uC138\uC6B0\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839139
    m_Localized: "\"\uADF8\uB798\uB3C4... \uAE30\uC5B5\uD574 \uC8FC\uC2DC\uC624.
      \uB0B4\uAC00 \uBA3C\uC800 \uBD88\uC744 \uCF30\uB2E4\uB294 \uAC83\uC744.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839140
    m_Localized: "Aldric\uC758 \uD615\uC0C1\uC774 \uBE5B\uB098\uAE30 \uC2DC\uC791\uD55C\uB2E4.
      \uC804\uD22C\uAC00 \uC2DC\uC791\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839141
    m_Localized: "\"\uC720\uC9C0\uAC00 \uC544\uB2D9\uB2C8\uB2E4. \uCC29\uCDE8\uC600\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839142
    m_Localized: "\"\uCC29\uCDE8\uB77C \uD558\uC2DC\uC624? \uB0B4\uAC00 \uC624\uAE30
      \uC804\uC5D0 \uB108\uD76C\uB294 \uC11C\uB85C\uB97C \uC8FD\uC774\uACE0 \uC788\uC5C8\uC18C.
      \uC774\uC720\uB3C4 \uBAA8\uB978 \uCC44.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839143
    m_Localized: "\uD2C0\uB9B0 \uB9D0\uC774 \uC544\uB2C8\uB2E4. Dawn Priest\uAC00
      \uB300\uAFB8\uD558\uC9C0 \uBABB\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839144
    m_Localized: "\"\uADF8\uB798, \uC774\uC720\uB294 \uBAB0\uB790\uC9C0. \uADFC\uB370
      \uB124\uAC00 \uC774\uC720\uB97C \uC54C\uACE0\uB3C4 \uC774\uC6A9\uD55C \uAC70\uC796\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839145
    m_Localized: "\"\uC774\uC6A9\uC774 \uC544\uB2C8\uB77C \uAD00\uB9AC\uC600\uC18C.
      \uD63C\uB3C8\uC5D0 \uAD6C\uC870\uB97C \uBD80\uC5EC\uD55C \uAC83\uC774\uC624.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839146
    m_Localized: "\"\uAD6C\uC870. \uB0B4 \uB3D9\uC871\uC758 \uAE30\uC5B5\uC744 \uC5F0\uB8CC\uB85C
      \uC4F0\uBA74\uC11C \uADF8\uAC78 \uAD6C\uC870\uB77C\uACE0 \uBD88\uB800\uAD70.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839147
    m_Localized: "\"\uB098\uB294... \uCD5C\uC120\uC744 \uD0DD\uD588\uC18C. \uBD88\uC644\uC804\uD55C
      \uC138\uACC4\uC5D0\uC11C \uBD88\uC644\uC804\uD55C \uC9C8\uC11C\uB97C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839148
    m_Localized: "\uD55C \uC21C\uAC04, Aldric\uC774 \uC9C4\uC2EC\uC73C\uB85C \uC2AC\uD37C
      \uBCF4\uC778\uB2E4. \uADF8\uB798\uC11C \uB354 \uBB34\uC12D\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839149
    m_Localized: "\uC720\uB9AC \uB098\uBB34\uAC00 \uBE5B\uC744 \uAD74\uC808\uC2DC\uD0A8\uB2E4.
      \uBB34\uC9C0\uAC1C \uD30C\uD3B8\uC774 \uC0AC\uBC29\uC5D0 \uD769\uC5B4\uC9C4\uB2E4.
      \uC544\uB984\uB2F5\uB2E4 \u2014 \uBC1C \uC544\uB798\uC11C \uC720\uB9AC\uAC00
      \uBD80\uC11C\uC9C0\uAE30 \uC804\uAE4C\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839150
    m_Localized: "\"\uACB0\uC815 \uC548\uC5D0... \uC0AC\uB78C\uC774 \uC788\uC2B5\uB2C8\uB2E4.
      \uAC11\uC637\uC744 \uC785\uC740 \uCC44\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839151
    m_Localized: "\uC720\uB9AC\uB97C \uBC1F\uC744 \uB54C\uB9C8\uB2E4 \uC18C\uB9AC\uAC00
      \uB09C\uB2E4. \uBF08\uAC00 \uBD80\uB7EC\uC9C0\uB294 \uC18C\uB9AC\uC640 \uBE44\uC2B7\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839152
    m_Localized: "\"\uC801\uC5B4\uB3C4 \uACF5\uD3C9\uD558\uAE34 \uD588\uB124. \uBAA8\uB450
      \uAC19\uC774 \uC8FD\uC5C8\uC73C\uB2C8\uAE4C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839153
    m_Localized: "\"\uAC19\uC774 \uC8FD\uC740 \uAC8C \uC544\uB2C8\uB2E4. \uAC19\uC774
      \uC5BC\uC5B4\uBD99\uC740 \uAC70\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839154
    m_Localized: "\"\uB2E4\uC2DC \uC774\uB7F0 \uC77C\uC774 \uC5C6\uB3C4\uB85D. \uADF8\uAC83\uC774
      \uC774\uC720\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839155
    m_Localized: "\"\uC57C\uC218\uC871\uB3C4 \uC788\uC5B4. \uB2EC\uB9AC\uB2E4\uAC00
      \uAD73\uC740 \uC790\uC138\uC57C. \uB3C4\uB9DD\uCE58\uACE0 \uC788\uC5C8\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839156
    m_Localized: "\"\uB0B4 \uB3D9\uC871\uB3C4 \uBCF4\uC5EC. \uC5EC\uAE30\uC11C \uBAA8\uB450\uAC00
      \uB3D9\uC2DC\uC5D0 \uC8FD\uC5C8\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839157
    m_Localized: "\uACB0\uC815 \uB098\uBB34 \uC0AC\uC774\uB85C \uBE5B\uC774 \uAD74\uC808\uB41C\uB2E4.
      \uB124 \uAC00\uC9C0 \uC0C9 \u2014 \uAC15\uCCA0 \uD68C\uC0C9, \uD638\uBC15\uC0C9,
      \uC778\uAD11 \uB179\uC0C9, \uD504\uB9AC\uC998 \uBCF4\uB77C."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839158
    m_Localized: "Echo Savant\uAC00 \uACE0\uAC1C\uB97C \uB4E0\uB2E4. \uC720\uB9AC
      \uC218\uAD00 \uC0AC\uC774\uB85C \uD558\uB298\uC774 \uBCF4\uC778\uB2E4. 1800\uB144
      \uB9CC\uC5D0 \uCC98\uC74C."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839159
    m_Localized: "\uD3C9\uAC00\uB3C4, \uBD84\uC11D\uB3C4 \uC544\uB2CC \uD45C\uC815\uC774
      \uADF8\uC758 \uC5BC\uAD74\uC5D0 \uB5A0\uC624\uB978\uB2E4. \uC6D0\uC815\uB300\uAC00
      \uCC98\uC74C \uBCF4\uB294 \uC5BC\uAD74\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839160
    m_Localized: "\"\uD3ED\uC8FC \uD754\uC801\uC774\uB2E4. \uC2EC\uC7A5\uC774 \uD55C
      \uBC88 \uD130\uC84C\uB2E4. \uC624\uB798\uC804\uC5D0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839161
    m_Localized: "\"\uBAA8\uB4E0 \uC138\uB825\uC758 \uC804\uC0AC\uAC00... \uAC19\uC740
      \uC21C\uAC04\uC5D0...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839162
    m_Localized: "\"\uC5EC\uAE30\uAC00 \uC911\uB9BD \uC9C0\uB300\uB77C\uB294 \uAC70\uC57C.
      \uC544\uBB34\uB3C4 \uC774\uAE30\uC9C0 \uBABB\uD55C \uACF3.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839163
    m_Localized: "\uC11D\uC870 \uAD00\uBB38\uC774 \uC19F\uC544 \uC788\uB2E4. \uB124
      \uC138\uB825\uC758 \uBB38\uC591\uC774 \uAC01 \uAE30\uB465\uC5D0 \uC0C8\uACA8\uC838
      \uC788\uB2E4. Heartforge\uC758 \uB9E5\uB3D9\uC774 \uAC00\uC2B4\uD30D\uAE4C\uC9C0
      \uC6B8\uB9B0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839164
    m_Localized: "\"\uB124 \uBB38\uC591\uC774 \uC788\uC2B5\uB2C8\uB2E4. \uB124 \uC138\uB825\uC774
      \uD568\uAED8 \uC788\uC744 \uB54C\uB9CC \uC5F4\uB9AC\uB294 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839165
    m_Localized: "\"...\uC84C\uB124.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839166
    m_Localized: "\uAD00\uBB38\uC774 \uC5F4\uB9B0\uB2E4. \uC548\uC5D0\uC11C \uC5B4\uB460\uC774
      \uC544\uB2C8\uB77C \uBE5B\uC774 \uC62C\uB77C\uC628\uB2E4. \uC624\uB798\uB41C
      \uBE5B."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839167
    m_Localized: "\"\uB0B4\uB824\uAC11\uC2DC\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839168
    m_Localized: "\"\uB3CC\uC544\uC62C \uC218 \uC788\uB294 \uAC70\uC9C0?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839169
    m_Localized: "\"\uBB38\uB3C4 \uC6B0\uB9AC\uBCF4\uB2E4 \uBA3C\uC800 \uC54C\uACE0
      \uC788\uC5C8\uB124. \uD568\uAED8 \uC640\uC57C \uD55C\uB2E4\uB294 \uAC78.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839170
    m_Localized: "\"3000\uB144 \uC804 \uBB38\uC774 \uC6B0\uB9AC\uBCF4\uB2E4 \uB611\uB611\uD558\uB2E4\uB2C8.
      \uC790\uC874\uC2EC \uC0C1\uD558\uB124.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839171
    m_Localized: "\"\uBB38\uC774 \uC544\uB2C8\uB2E4. \uC2DC\uD5D8\uC774\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839172
    m_Localized: "\uAD00\uBB38\uC758 \uBB38\uC591\uC774 \uBE5B\uB098\uAE30 \uC2DC\uC791\uD55C\uB2E4.
      \uAC01\uC790\uC758 \uC0C9\uC73C\uB85C."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839173
    m_Localized: "\"\uBB38\uC774\uB4E0 \uC2DC\uD5D8\uC774\uB4E0. \uC5F4\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839174
    m_Localized: "\"\uADF8\uB798. \uCDA9\uBD84\uD788 \uAE30\uB2E4\uB838\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839175
    m_Localized: "\"\uAE30\uB2E4\uB9B0 \uAC74 \uB098\uC57C. 400\uB144.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839176
    m_Localized: "\"1800\uB144.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839177
    m_Localized: "\uBE5B\uC758 \uD658\uC601\uC774 \uD3BC\uCCD0\uC9C4\uB2E4. \uB124
      \uC885\uC871\uC774 \uAC19\uC740 \uBB3C\uAC00\uC5D0 \uC11C \uC788\uB2E4. \uBB34\uAE30\uAC00
      \uC5C6\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839178
    m_Localized: "\"\uC774 \uAE30\uC5B5 \uBD10. \uC804\uC7C1 \uC774\uC804\uC774\uC57C.
      \uAF64 \uC88B\uC740 \uC2DC\uC808\uC774\uC5C8\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839179
    m_Localized: "\"\uD1A0\uD15C\uC774 \uAE30\uC5B5\uD558\uACE0 \uC788\uC5C8\uC5B4.
      \uC9C4\uB3D9 \uC18D\uC5D0 \uC61B \uB0C4\uC0C8\uAC00 \uB0A8\uC544 \uC788\uC5C8\uB294\uB370...
      \uC774\uAC70\uC600\uAD6C\uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839180
    m_Localized: "\"\uACF5\uC874\uC758 \uC99D\uAC70\uAC00 \uC788\uC5C8\uC2B5\uB2C8\uAE4C?
      \uC65C \uC544\uBB34\uB3C4...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839181
    m_Localized: "\"\uC774 \uAE30\uC5B5\uC744 \uC9C0\uC6B4 \uAC8C \uC655\uAD6D\uC758
      \uCCAB \uBC88\uC9F8 \uC8C4\uC57C. \uACF5\uC874\uC758 \uC99D\uAC70\uB97C \uBB3B\uACE0
      \uC801\uC744 \uB9CC\uB4E4\uC5C8\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839182
    m_Localized: "\uD658\uC601\uC774 \uD750\uB824\uC9C4\uB2E4. \uBB3C\uAC00\uC758
      \uB124 \uC885\uC871\uC774 \uC11C\uC11C\uD788 \uC0AC\uB77C\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839183
    m_Localized: "\"...\uC88B\uC740 \uB0C4\uC0C8\uC600\uC744 \uAC70\uC57C. \uADF8
      \uBB3C\uAC00.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839184
    m_Localized: "\"\uC6B0\uB9AC\uAC00 \uBB3B\uC740 \uAC83\uC774 \uC774\uB807\uAC8C\uB098
      \uB9CE\uC558\uC2B5\uB2C8\uAE4C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839185
    m_Localized: "\uACA9\uC790 \uC870\uAC01\uC774 Grave Hexer\uC758 \uC190\uC5D0\uC11C
      \uBC18\uC751\uD55C\uB2E4. \uBE5B\uC774 \uADF8\uB140\uC758 \uAC00\uC7A5 \uC624\uB798\uB41C
      \uAE30\uC5B5 \uCABD\uC73C\uB85C \uD750\uB978\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839186
    m_Localized: "\"...\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839187
    m_Localized: "\"\uBB34\uC2A8 \uC77C\uC785\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839188
    m_Localized: "\"\uC815\uD654\uC758 \uC5F4\uC1E0\uAC00 \uAE30\uC5B5\uC774\uC57C.
      \uAC00\uC7A5 \uC624\uB798\uB41C \uAE30\uC5B5. \uADF8\uB7EC\uB2C8\uAE4C...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839189
    m_Localized: "\"\uB0B4 \uAE30\uC6D0 \uAE30\uC5B5\uC774\uC57C. \uB0B4\uAC00 \uB204\uAD6C\uC600\uB294\uC9C0\uC758
      \uCC98\uC74C. \uADF8\uAC78 \uBA39\uC774\uB85C \uC918\uC57C \uD55C\uB2E4\uB294
      \uB73B\uC774\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839190
    m_Localized: "\"\uADF8\uB7EC\uBA74 \uB10C...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839191
    m_Localized: "\"\uBB50, 400\uB144\uCE58 \uB2E4\uB978 \uAE30\uC5B5\uC740 \uB0A8\uC73C\uB2C8\uAE4C.
      \uD638\uBC00\uBE75 \uC88B\uC544\uD588\uB358 \uC0AC\uB78C \uAE30\uC5B5\uC774\uB77C\uB4E0\uAC00.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839192
    m_Localized: "\uB18D\uB2F4\uC744 \uD558\uACE0 \uC788\uB2E4. \uD558\uC9C0\uB9CC
      \uC190\uC774 \uACA9\uC790 \uC870\uAC01\uC744 \uAF49 \uC950\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839193
    m_Localized: "\"...\uBB34\uAC81\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839194
    m_Localized: "\"400\uB144 \uC804 \uC804\uC7C1? \uC544, \uADF8\uAC70. \uD654\uC694\uC77C\uC774\uC5C8\uB098.
      \uC218\uC694\uC77C\uC774\uC5C8\uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839195
    m_Localized: "\"400\uB144\uC744 \uC694\uC77C\uB85C \uAE30\uC5B5\uD574?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839196
    m_Localized: "\"\uBE44\uAC00 \uC654\uAC70\uB4E0. \uBE44 \uC624\uB294 \uB0A0\uC740
      \uAE30\uC5B5\uC774 \uC798 \uD758\uB7EC\uB098\uC640\uC11C \uC815\uB9AC\uD558\uAE30
      \uC88B\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839197
    m_Localized: "\"\uC0B0 \uC790\uBCF4\uB2E4 \uC624\uB798 \uAE30\uC5B5\uD558\uC2DC\uB294
      \uBD84\uC774\uAD70\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839198
    m_Localized: "\"\uAE30\uC5B5\uC740 \uBABB \uB0B4\uB824\uB193\uC544. \uD314\uC774
      \uAE38\uC5B4\uC11C \uB9CE\uC774 \uB4DC\uB294 \uAC8C \uC544\uB2C8\uB77C, \uB0B4\uB824\uB193\uB294
      \uBC95\uC744 \uC78A\uC740 \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839199
    m_Localized: "Grave Hexer\uAC00 \uC11D\uAD00 \uD558\uB098\uB97C \uC190\uAC00\uB77D\uC73C\uB85C
      \uD22D \uCE5C\uB2E4. \uBA3C\uC9C0\uAC00 \uC77C\uC5B4\uB09C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839200
    m_Localized: "\"\uC774 \uC0AC\uB78C\uC740 270\uB144 \uC804\uC5D0 \uC8FD\uC5C8\uC5B4.
      \uBE75\uC744 \uC88B\uC544\uD588\uC9C0. \uD638\uBC00\uBE75.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839201
    m_Localized: "\"...\uADF8\uB7F0 \uAC83\uAE4C\uC9C0 \uAE30\uC5B5\uD574?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839202
    m_Localized: "Grave Hexer\uAC00 \uBE5B\uB098\uB294 \uAD6C\uC2AC\uC744 \uC591\uC190\uC5D0
      \uC950\uACE0 \uC788\uB2E4. \uC548\uC5D0\uC11C \uBE5B\uC774 \uB9E5\uB3D9\uD55C\uB2E4.
      \uB204\uAD70\uAC00\uC758 \uC6C3\uC74C\uC18C\uB9AC\uAC00 \uB4E4\uB9AC\uB294
      \uAC83 \uAC19\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839203
    m_Localized: "\"\uC774\uAC8C \uB0B4 \uCCAB \uAE30\uC5B5\uC774\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839204
    m_Localized: '"..."'
    m_Metadata:
      m_Items: []
  - m_Id: 501683839205
    m_Localized: "Grave Hexer\uAC00 \uD55C\uB3D9\uC548 \uC11C \uC788\uB2E4. \uC190\uC774
      \uD5C8\uACF5\uC744 \uC954\uB2E4. \uC544\uAE4C\uAE4C\uC9C0 \uBB34\uC5C7\uC744
      \uC950\uACE0 \uC788\uC5C8\uB294\uC9C0 \uBAA8\uB974\uACA0\uB2E4\uB294 \uC5BC\uAD74\uB85C."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839206
    m_Localized: "\"...\uBB50\uC600\uB354\uB77C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839207
    m_Localized: "\"\uC5B4\uB5A4 \uAE30\uC5B5\uC785\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839208
    m_Localized: "\"...\uD587\uBE5B\uC774\uC5C8\uC5B4. \uADF8\uB9AC\uACE0 \uB204\uAD70\uAC00\uC758
      \uBAA9\uC18C\uB9AC. \uC774\uB984\uC740 \uAE30\uC5B5 \uC548 \uB098. \uADFC\uB370
      \uB530\uB73B\uD588\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839209
    m_Localized: "\uD3C9\uC18C\uC758 \uAC74\uC870\uD568\uC774 \uC5C6\uB2E4. \uCC98\uC74C\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839210
    m_Localized: "\"\uB193\uC9C0 \uB9C8. \uB2E4\uB978 \uBC29\uBC95\uC774 \uC788\uC744
      \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839211
    m_Localized: "\"400\uB144 \uB3D9\uC548 \uC774\uAC83\uB9CC\uC740 \uC9C0\uCF30\uC5B4.
      \uB2E4\uB978 \uAE30\uC5B5\uC740 \uD750\uB824\uC838\uB3C4 \uC774\uAC74... \uC774\uAC74
      \uC120\uBA85\uD588\uAC70\uB4E0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839212
    m_Localized: "\uC190\uC774 \uB5A8\uB9B0\uB2E4. \uADF8\uB140\uC758 \uC190\uC774
      \uB5A8\uB9AC\uB294 \uAC83\uC744 \uCC98\uC74C \uBCF8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839213
    m_Localized: "\"\uADFC\uB370 \uC774\uAC83\uBCF4\uB2E4 \uC9C0\uCF1C\uC57C \uD560
      \uAC8C \uB354 \uB9CE\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839214
    m_Localized: "\uAD6C\uC2AC\uC744 \uACA9\uC790\uC5D0 \uBC00\uC5B4\uB123\uB294\uB2E4.
      \uBE5B\uC774 \uD37C\uC9C4\uB2E4. \uC6C3\uC74C\uC18C\uB9AC\uAC00 \uC0AC\uB77C\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839215
    m_Localized: "\"\uC138 \uAC00\uC9C0 \uAE38\uC774 \uC788\uB2E4. \uC815\uD654,
      \uBD09\uC778, \uD30C\uAD34.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839216
    m_Localized: "\uC9E7\uC740 \uCE68\uBB35. \uC720\uB9AC \uB098\uBB47\uAC00\uC9C0\uC5D0\uC11C
      \uBE5B\uC774 \uAD74\uC808\uB418\uC5B4 \uB124 \uC0AC\uB78C\uC758 \uC5BC\uAD74\uC5D0
      \uC11C\uB85C \uB2E4\uB978 \uC0C9\uC744 \uC785\uD78C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839217
    m_Localized: "\"\uBD09\uC778\uC740 \uC804\uB840\uAC00 \uC788\uB2E4. \uC6B0\uB9AC\uAC00
      1800\uB144 \uC804\uC5D0 \uD588\uB2E4. \uD558\uC9C0\uB9CC...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839218
    m_Localized: "\"\uACA9\uC790\uAC00 \uB2E4\uC2DC \uD48D\uD654\uB418\uBA74 \uB2E4\uC74C
      \uC138\uB300\uAC00 \uC6B0\uB9AC\uC640 \uAC19\uC740 \uC790\uB9AC\uC5D0 \uC120\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839219
    m_Localized: "\"...\uADF8\uB798\uB3C4 \uC9C0\uAE08 \uC5EC\uAE30\uC11C \uCE5C\uAD6C\uB97C
      \uBB3B\uC744 \uC21C \uC5C6\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839220
    m_Localized: "\uB124 \uC0AC\uB78C\uC774 \uC11C\uB85C \uB2E4\uB978 \uBC29\uD5A5\uC744
      \uBCF4\uACE0 \uC788\uB2E4. \uD569\uC758\uB294 \uC5C6\uB2E4. \uC720\uB9AC\uAC00
      \uBC14\uB78C\uC5D0 \uC6B8\uB9B0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839221
    m_Localized: "\"\uC815\uD654\uD574\uC57C \uD569\uB2C8\uB2E4. \uC655\uAD6D\uC774
      \uC9C4 \uBE5A\uC744 \uAC1A\uC73C\uB824\uBA74 \uC21C\uD658\uC744 \uC644\uC804\uD788
      \uB05D\uB0B4\uC57C \uD574\uC694. \uB300\uAC00\uAC00 \uC788\uB354\uB77C\uB3C4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839222
    m_Localized: "\"\uB300\uAC00? \uB204\uAD6C \uB300\uAC00? \uB124\uAC00 \uCE58\uB97C
      \uAC70\uC57C, \uC0AC\uC81C? \uC544\uB2C8\uBA74 \uC800 \uCE5C\uAD6C\uB97C \uACA9\uC790
      \uC548\uC5D0 \uAC00\uB458 \uAC70\uC57C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839223
    m_Localized: "\"\uADF8\uAC74...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839224
    m_Localized: "\"\uBD09\uC778\uC774\uBA74 \uC544\uBB34\uB3C4 \uC548 \uC8FD\uC5B4.
      \uC544\uBB34\uB3C4 \uC548 \uAC07\uD600. 200\uB144\uC774\uB4E0 500\uB144\uC774\uB4E0
      \uADF8\uB54C \uAC00\uC11C \uB610 \uC0DD\uAC01\uD558\uBA74 \uB418\uC796\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839225
    m_Localized: "\"200\uB144 \uD6C4\uC5D0 \uAC19\uC740 \uC804\uC7C1\uC774 \uBC18\uBCF5\uB3FC.
      \uB098\uB294 \uADF8 \uC804\uC7C1\uC744 \uAE30\uC5B5\uD558\uACE0 \uC788\uAC70\uB4E0.
      \uB611\uAC19\uC740 \uC804\uC7C1\uC744.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839226
    m_Localized: "\"\uADF8\uB798\uC11C \uAE30\uC5B5\uC744 \uBC14\uCE58\uACA0\uB2E4\uACE0?
      \uB124 \uAE30\uC6D0\uC744? \uADF8\uAC74 \uB124 \uC874\uC7AC \uC790\uCCB4\uC796\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839227
    m_Localized: '"..."'
    m_Metadata:
      m_Items: []
  - m_Id: 501683839228
    m_Localized: "Grave Hexer\uAC00 \uCC98\uC74C\uC73C\uB85C \uB9D0\uC744 \uC787\uC9C0
      \uBABB\uD55C\uB2E4. \uB18D\uB2F4\uB3C4, \uACFC\uAC70\uD615\uB3C4 \uB098\uC624\uC9C0
      \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839229
    m_Localized: "\uACA9\uC790 \uBE5B\uC774 \uB124 \uC0AC\uB78C\uC744 \uB3D9\uC2DC\uC5D0
      \uBE44\uCD98\uB2E4. \uCC98\uC74C\uC73C\uB85C \uAC19\uC740 \uBE5B \uC544\uB798
      \uC11C \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839230
    m_Localized: "\"\uACA9\uC790\uAC00 40% \uC774\uD558\uB2E4. \uC2EC\uC7A5\uC758
      \uCD9C\uB825\uC774 \uC5B5\uC81C \uC5C6\uC774 \uD37C\uC9C0\uACE0 \uC788\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839231
    m_Localized: "\"\uC21C\uD658\uC758 \uC885\uACB0\uC774\uB2E4. \uC218\uB9AC\uAC00
      \uC544\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839232
    m_Localized: "\uB124 \uC0AC\uB78C\uC774 \uC544\uB798\uB97C \uBCF8\uB2E4. \uC5B4\uB460\uC774
      \uC62C\uB77C\uC628\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839233
    m_Localized: "\"\uC2E0\uC559\uB3C4, \uC804\uC7C1\uB3C4... \uC804\uBD80 \uC774\uAC83\uC758
      \uBD80\uC0B0\uBB3C\uC774\uC5C8\uB2E4\uB294 \uAC81\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839234
    m_Localized: "\"\uBD80\uC0B0\uBB3C\uC774\uB77C\uB2C8. \uAF64 \uBE44\uC2FC \uBD80\uC0B0\uBB3C\uC774\uB124.
      \uC218\uCC9C \uB144\uCE58 \uC804\uC7C1\uC774\uC796\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839235
    m_Localized: "\"\uADF8\uB7FC \uBC11\uC5D0 \uBB50\uAC00 \uC788\uB4E0 \uBD80\uC218\uB7EC
      \uAC00\uBA74 \uB418\uC796\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839236
    m_Localized: "\"\uBD80\uC218\uBA74 \uAE30\uC5B5\uC774 \uC804\uBD80 \uC0AC\uB77C\uC9C4\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839237
    m_Localized: "\uCE68\uBB35. Grave Hexer\uC758 \uD45C\uC815\uC774 \uCC98\uC74C\uC73C\uB85C
      \uAD73\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839238
    m_Localized: "\"...\uADF8\uAC74 \uC548 \uB3FC.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839239
    m_Localized: "\"\uD30C\uAD34\uAC00 \uC544\uB2C8\uB77C \uB2E4\uB978 \uBC29\uBC95\uC744
      \uCC3E\uC544\uC57C \uD569\uB2C8\uB2E4. \uC544\uB798\uB85C \uB0B4\uB824\uAC11\uC2DC\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839240
    m_Localized: "\"\uBA85\uBD84\uC774 \uBC14\uB00C\uC5C8\uB124. \uC870\uC0AC\uC5D0\uC11C
      \uC218\uB9AC\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839241
    m_Localized: "\uAD00\uBB38 \uC55E\uC5D0 \uB124 \uAC1C\uC758 \uD648\uC774 \uC788\uB2E4.
      \uAC01 \uC138\uB825\uC758 \uBB38\uC591 \uBAA8\uC591. \uBB34\uC5B8\uAC00\uB97C
      \uB0B4\uB824\uB193\uC544\uC57C \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839242
    m_Localized: "\"\uAE30\uB3C4\uC11C\uB97C \uB193\uACA0\uC2B5\uB2C8\uB2E4. Aldric\uC774
      \uC4F4 \uC6D0\uBB38\uC785\uB2C8\uB2E4. \uB354 \uC774\uC0C1 \uC774 \uAE30\uB3C4\uB97C
      \uC62C\uB9AC\uC9C0 \uC54A\uACA0\uB2E4\uB294 \uB73B\uC73C\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839243
    m_Localized: "\"...\uAC11\uC2DC\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839244
    m_Localized: "\uB124 \uC0AC\uB78C\uC774 \uAD00\uBB38\uC744 \uB118\uB294\uB2E4.
      \uBE5B\uC774 \uADF8\uB4E4\uC744 \uC0BC\uD0A8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839245
    m_Localized: "Dawn Priest\uAC00 \uAE30\uB3C4\uC11C\uB97C \uD648\uC5D0 \uB193\uB294\uB2E4.
      \uC190\uC774 \uB5A8\uB9AC\uC9C0\uB9CC, \uB193\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839246
    m_Localized: "\"\uD615\uC81C\uC758 \uD30C\uD3B8\uC744 \uB193\uC744\uAC8C. Wolfpine\uC5D0\uC11C
      \uBF51\uC740 \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839247
    m_Localized: "\uD30C\uD3B8\uC774 \uD648\uC5D0 \uB2FF\uC790 \uC9C4\uB3D9\uC774
      \uC6B8\uB9B0\uB2E4. Pack Raider\uAC00 \uC774\uB97C \uC545\uBB38\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839248
    m_Localized: "\"\uB098\uB294... \uC774\uAC83.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839249
    m_Localized: "Grave Hexer\uAC00 \uBE5B\uB098\uB294 \uAD6C\uC2AC\uC744 \uAEBC\uB0B8\uB2E4.
      \uAC00\uC7A5 \uC624\uB798\uB41C \uAE30\uC5B5\uC774 \uB2F4\uAE34 \uAC83. \uC544\uC9C1
      \uB193\uC9C0 \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839250
    m_Localized: "\"\uC544\uC9C1\uC740 \uC548 \uB193\uC744 \uAC70\uC57C. \uB9C8\uC9C0\uB9C9\uC5D0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839251
    m_Localized: "\"\uB098\uB294 \uBAB8\uC744 \uB193\uB294\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839252
    m_Localized: "\uC544\uBB34\uB3C4 \uB300\uAFB8\uD558\uC9C0 \uC54A\uB294\uB2E4.
      \uAD00\uBB38\uC758 \uBE5B\uC774 \uB354 \uAC15\uD574\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839253
    m_Localized: "Dawn Priest\uAC00 \uBB34\uB98E\uC744 \uAFC7\uB294\uB2E4. \uC7AC\uAC00
      \uB0B4\uB824\uC549\uC544 \uAE30\uB3C4\uD558\uB294 \uC190\uB4F1\uC744 \uB36E\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839254
    m_Localized: "\"\uC601\uC6D0\uD55C \uC9C8\uC11C\uC758 \uC774\uB984\uC73C\uB85C,
      \uC774 \uBB38 \uB108\uBA38\uC758 \uC624\uC5FC\uC744 \uC815\uD654\uD558\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839255
    m_Localized: "\uADF8\uB140\uC758 \uC190\uC774 \uBA48\uCD98\uB2E4. \uBB38 \uC548\uCABD
      \uBCBD\uC5D0 \uCC0D\uD78C \uC790\uAD6D \u2014 \uBC16\uC5D0\uC11C \uB4E4\uC774\uCE5C
      \uD754\uC801\uC774 \uC544\uB2C8\uB2E4. \uC548\uC5D0\uC11C \uBC00\uC5B4\uB0B8
      \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839256
    m_Localized: "\"\uC774 \uBB38\uC740 \uC6B0\uB9AC\uAC00 \uC138\uC6E0\uC2B5\uB2C8\uB2E4.
      \uC6B0\uB9AC\uAC00 \uC9C0\uCF30\uC2B5\uB2C8\uB2E4. \uADF8\uB7F0\uB370... \uC548\uC5D0\uC11C\uBD80\uD130...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839257
    m_Localized: "\uAE30\uB3C4\uB97C \uB9C8\uCE58\uC9C0 \uBABB\uD55C\uB2E4. \uADF8\uB140\uAC00
      \uC77C\uC5B4\uC120\uB2E4. \uBB34\uB98E\uC5D0 \uC7AC\uAC00 \uBB3B\uC5B4 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839258
    m_Localized: "\"\uB208\uC744 \uAC10\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4. \uADF8\uAC83\uC774
      \uC0AC\uC81C\uC5D0\uAC8C \uD5C8\uB77D\uB41C \uC720\uC77C\uD55C \uC6A9\uAE30\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839259
    m_Localized: "Dawn Priest\uAC00 \uC0AC\uC81C \uC778\uC7A5\uC744 \uC190\uC5D0
      \uC950\uACE0 \uC11C \uC788\uB2E4. \uC624\uB7AB\uB3D9\uC548 \uB9D0\uC774 \uC5C6\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839260
    m_Localized: "\"\uB3C4\uAD74\uD488 \uC704\uC5D0 \uC138\uC6B4 \uC2E0\uC559\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839261
    m_Localized: "\"\uC131\uBB3C\uD568 \uC548\uC5D0 \uB4E0 \uAC83\uC774 \uC2E0\uC758
      \uCD95\uBCF5\uC774 \uC544\uB2C8\uB77C \uB0A8\uC758 \uBF08\uC600\uB2E4\uBA74...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839262
    m_Localized: "\uBB38\uC7A5\uC774 \uB04A\uAE34\uB2E4. \uADF8\uB140\uAC00 \uC785\uC744
      \uB2E4\uBB38\uB2E4. \uB2E4\uC2DC \uC5F0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839263
    m_Localized: "\"\uC6B0\uB9AC\uAC00 \uC62C\uB9B0 \uAE30\uB3C4\uB294... \uB204\uAD6C\uC5D0\uAC8C...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839264
    m_Localized: "\uB05D\uB9FA\uC9C0 \uBABB\uD55C\uB2E4. \uC778\uC7A5\uC774 \uC190\uC5D0\uC11C
      \uBBF8\uB044\uB7EC\uC9C8 \uBED4\uD55C\uB2E4. \uADF8\uB140\uAC00 \uC6C0\uCF1C\uC954\uB2E4
      \u2014 \uC544\uC9C1 \uB193\uC9C0\uB294 \uBABB\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839265
    m_Localized: "\"\uBB34\uB108\uC9C4 \uAC83\uB3C4 \uD759\uC774 \uB3FC.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839266
    m_Localized: "\"...\uD759\uC774\uC694?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839267
    m_Localized: "\"\uD759\uC5D0\uC11C \uBFCC\uB9AC\uAC00 \uB098\uB294 \uBC95\uC774\uC57C.
      \uB124\uAC00 \uC2EC\uC744 \uCC28\uB840\uB2E4, \uC0AC\uC81C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839268
    m_Localized: "Dawn Priest\uAC00 \uC778\uC7A5\uC744 \uC8FC\uBA38\uB2C8\uC5D0 \uB123\uB294\uB2E4.
      \uBC84\uB9AC\uC9C0\uB294 \uC54A\uB294\uB2E4. \uC544\uC9C1\uC740."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839269
    m_Localized: "Dawn Priest\uAC00 \uAE30\uB85D\uBD80\uB97C \uC190\uC5D0 \uB4E4\uACE0
      \uC11C \uC788\uB2E4. \uC789\uD06C\uAC00 \uC544\uC9C1 \uB9C8\uB974\uC9C0 \uC54A\uC740
      \uD398\uC774\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839270
    m_Localized: "\"\uC81C\uAC00 \uC12C\uAE34 \uC9C8\uC11C... \uADF8 \uBC11\uBC14\uB2E5\uC5D0
      \uC774\uB7F0 \uAC83\uC774 \uC788\uC5C8\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839271
    m_Localized: "\"\uC774\uAC78 \uC544\uB294 \uC790\uB4E4\uC774 \uC788\uC5C8\uACE0,
      \uADF8\uB4E4\uC740 \uCE68\uBB35\uC744 \uD0DD\uD588\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839272
    m_Localized: "\uAE30\uB85D\uBD80\uC758 \uC11C\uBA85\uB780\uC5D0 \"A. Sternholt\"\uAC00
      \uB610 \uC788\uB2E4. \uAC19\uC740 \uD544\uCCB4. \uAC19\uC740 \uC0AC\uB78C."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839273
    m_Localized: "\"\uC758\uC2EC\uD558\uB294 \uAC83\uB3C4 \uC6A9\uAE30\uC57C, \uC0AC\uC81C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839274
    m_Localized: "\"...\uB2F9\uC2E0\uC5D0\uAC8C \uADF8\uB7F0 \uB9D0\uC744 \uB4E4\uC744
      \uC904\uC740 \uBAB0\uB790\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839275
    m_Localized: "\"\uBC14\uB78C\uC744 \uAC70\uC2A4\uB974\uB294 \uC9D0\uC2B9\uC740
      \uBB34\uB9AC\uC5D0\uC11C \uCAD3\uACA8\uB098. \uADFC\uB370 \uAC00\uB054\uC740
      \uADF8\uB188\uC774 \uAE38\uC744 \uCC3E\uAC70\uB4E0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839276
    m_Localized: "Dawn Priest\uAC00 \uAE30\uB85D\uBD80\uB97C \uBC30\uB0AD\uC5D0 \uB123\uB294\uB2E4.
      \uC190\uC774 \uB5A8\uB9AC\uC9C0\uB9CC, \uB193\uC9C0 \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839277
    m_Localized: "Dawn Priest\uAC00 \uBA48\uCD98\uB2E4. \uC8FC\uBA38\uB2C8\uC5D0\uC11C
      \uC0AC\uC81C \uC778\uC7A5\uC744 \uAEBC\uB0B8\uB2E4. \uC624\uB798 \uC950\uACE0
      \uC788\uC5C8\uB2E4. \uC190\uC790\uAD6D\uC774 \uB0A8\uC544 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839278
    m_Localized: "\"\uC774 \uC778\uC7A5\uC740 Aldric\uC774 \uC124\uACC4\uD55C \uAD50\uB9AC\uC758
      \uC99D\uBA85\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839279
    m_Localized: "\"\uB354 \uC774\uC0C1 \uC774\uAC83\uC73C\uB85C \uC2A4\uC2A4\uB85C\uB97C
      \uC815\uC758\uD558\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839280
    m_Localized: "\uC778\uC7A5\uC744 \uBC14\uB2E5\uC5D0 \uB193\uB294\uB2E4. \uAE08\uC18D\uC774
      \uB3CC\uC5D0 \uB2FF\uB294 \uC18C\uB9AC\uAC00 \uC6B8\uB9B0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839281
    m_Localized: "\"\uB2E4\uB9CC... \uAE30\uB3C4\uB294 \uACC4\uC18D\uD558\uACA0\uC2B5\uB2C8\uB2E4.
      Aldric\uC758 \uAE30\uB3C4\uAC00 \uC544\uB2C8\uB77C, \uC81C \uAE30\uB3C4\uB97C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839282
    m_Localized: "\uADF8\uB140\uC758 \uB208\uC774 \uC816\uC5B4 \uC788\uB2E4. \uD558\uC9C0\uB9CC
      \uC6B8\uC9C0 \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839283
    m_Localized: "\"\uC601\uC6D0\uD55C \uC9C8\uC11C\uC758 \uC774\uB984\uC774 \uC544\uB2C8\uB77C...
      \uADF8\uB0E5. \uC81C \uC774\uB984\uC73C\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839284
    m_Localized: "\uC778\uC7A5\uC774 \uBC14\uB2E5\uC5D0\uC11C \uD76C\uBBF8\uD558\uAC8C
      \uBE5B\uB09C\uB2E4. \uADF8\uB9AC\uACE0 \uAEBC\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839285
    m_Localized: "\uB098\uBA38\uC9C0 \uC14B\uC774 \uC55E\uC11C \uAC77\uB294\uB2E4.
      Dawn Priest\uAC00 \uB4A4\uCC98\uC838 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839286
    m_Localized: "\"\uC81C\uAC00 \uC62C\uB9B0 \uAE30\uB3C4\uB294... \uAE30\uACC4\uC758
      \uBD80\uC0B0\uBB3C \uC704\uC5D0 \uC138\uC6B4 \uAC83\uC774\uC5C8\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839287
    m_Localized: "\"Aldric Sternholt\uAC00 \uC124\uACC4\uD55C \uAD50\uB9AC\uB97C
      \uC81C\uAC00... \uC544\uBB34 \uC758\uC2EC \uC5C6\uC774...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839288
    m_Localized: "\uBB38\uC7A5\uC774 \uB610 \uB04A\uAE34\uB2E4. \uC138 \uBC88\uC9F8\uB2E4.
      \uADF8\uB140\uC758 \uC5B4\uBC95\uC774 \uBCC0\uD558\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839289
    m_Localized: "\"\uC758\uC2EC \uC5C6\uC774 \uBBFF\uC740 \uAC74 \uB124 \uC798\uBABB\uC774
      \uC544\uB2C8\uC57C. \uADF8\uB807\uAC8C \uC124\uACC4\uB41C \uAC70\uB2C8\uAE4C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839290
    m_Localized: "\"\uADF8\uAC8C \uB354 \uB098\uC069\uB2C8\uB2E4. \uC124\uACC4\uB41C
      \uAC78 \uBAA8\uB974\uACE0 \uC0B4\uC558\uB2E4\uB294 \uAC8C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839291
    m_Localized: "Dawn Priest\uAC00 \uAC78\uC74C\uC744 \uC62E\uAE34\uB2E4. \uB2E4\uC2DC
      \uAC77\uB294\uB2E4. \uB290\uB9AC\uC9C0\uB9CC \uBA48\uCD94\uC9C0\uB294 \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839292
    m_Localized: "\"\uC544\uC9C1 \uAC77\uB124. \uADF8\uB7EC\uBA74 \uB410\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839293
    m_Localized: "Pack Raider\uC758 \uC190\uC774 \uBB36\uC5EC \uC788\uB2E4. \uD558\uC9C0\uB9CC
      \uCF54\uB294 \uC26C\uC9C0 \uC54A\uB294\uB2E4 \u2014 \uC5F0\uC2E0 \uBC14\uB78C\uC744
      \uC77D\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839294
    m_Localized: "\"\uB4A4\uC5D0 \uC2A4\uBB3C, \uC55E\uC5D0 \uB2E4\uC12F. \uBC14\uB78C
      \uB0C4\uC0C8\uB85C \uB2E4 \uC548\uB2E4. \uB3C4\uB9DD\uCE60 \uC0DD\uAC01\uC740
      \uC5C6\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839295
    m_Localized: "\"\uB2F9\uC2E0\uC758 \uBD88\uC2E0\uC744 \uD0D3\uD558\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839296
    m_Localized: "\"\uBD88\uC2E0? \uB108\uD76C\uAC00 \uC6B0\uB9AC \uC0AC\uB0E5\uD130\uC5D0
      \uCCA0\uC744 \uBC15\uC558\uC796\uC544. \uADF8\uAC78 \uBD88\uC2E0\uC774\uB77C\uACE0
      \uBD88\uB7EC?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839297
    m_Localized: "Dawn Priest\uC758 \uD45C\uC815\uC774 \uAD73\uB294\uB2E4. \uB300\uAFB8\uD558\uC9C0
      \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839298
    m_Localized: "\"\uC0AC\uC81C\uAC00 \uC785 \uC5F4\uBA74 \uBC14\uB78C\uC774 \uBA48\uCDB0.
      \uC57D\uC18D\uC740 \uD759\uC5D0 \uC2EC\uC5B4\uC57C \uBFCC\uB9AC\uAC00 \uB098\uC9C0.
      \uB9D0\uB85C\uB294 \uC548 \uB3FC.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839299
    m_Localized: "\"\uAC19\uC740 \uAE38\uC744 \uAC77\uB294 \uB3D9\uC548\uB9CC\uC774\uB77C\uB3C4
      \uB4F1\uC744 \uB9E1\uAE30\uC2ED\uC2DC\uC624.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839300
    m_Localized: "\"\uB4F1\uC744 \uB9E1\uAE30\uB77C\uACE0? \uB4F1\uC5D0 \uCE7C\uC744
      \uAF42\uB294 \uAC74 \uB108\uD76C \uC804\uD1B5\uC774\uC796\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839301
    m_Localized: "\uCE68\uBB35\uC774 \uB0B4\uB824\uC549\uB294\uB2E4. \uC194\uC78E
      \uC0AC\uC774\uB85C \uBC14\uB78C\uC774 \uBD84\uB2E4. Pack Raider\uC758 \uCF54\uAC00
      \uC6C0\uCC14\uD55C\uB2E4 \u2014 \uBB54\uAC00\uB97C \uAC10\uC9C0\uD55C \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839302
    m_Localized: "\"...\uC88B\uC544. \uADFC\uB370 \uC55E\uC5D0\uC11C \uAC78\uC5B4.
      \uB4F1\uC740 \uB124\uAC00 \uBCF4\uC5EC.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839303
    m_Localized: "\uBC24. Pack Raider\uAC00 \uC528\uC871 \uD1A0\uD15C\uC744 \uC190\uC5D0
      \uC950\uACE0 \uC549\uC544 \uC788\uB2E4. \uC720\uB9AC \uB098\uBB34\uC758 \uBE5B\uC774
      \uADF8\uC758 \uC5BC\uAD74\uC744 \uBE44\uCD98\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839304
    m_Localized: "\"...\uC7A0\uC774 \uC548 \uC635\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839305
    m_Localized: "\"\uD1A0\uD15C\uC774 \uC6B8\uB9AC\uC9C0 \uC54A\uC544. \uBC18\uCABD\uC774
      \uAC08\uB77C\uC9C0\uBA74 \uC9C4\uB3D9\uC774 \uBC18\uC73C\uB85C \uC904\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839306
    m_Localized: "Dawn Priest\uAC00 \uC606\uC5D0 \uC549\uB294\uB2E4. \uB9D0\uD558\uC9C0
      \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839307
    m_Localized: "\"\uC62C\uBC14\uB978 \uC120\uD0DD\uC744 \uD588\uB2E4\uACE0 \uC0DD\uAC01\uD588\uC5B4.
      \uD615\uC81C\uB97C \uBBF8\uCE58\uAC8C \uB9CC\uB4E0 \uAC83\uC774 \uBB54\uC9C0
      \uC54C\uC544\uB0B4\uBA74, \uC528\uC871\uC774 \uC774\uD574\uD560 \uC904 \uC54C\uC558\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839308
    m_Localized: "\"\uC800\uB3C4 \uADF8\uB7AC\uC2B5\uB2C8\uB2E4. \uC9C4\uC2E4\uC744
      \uBC1D\uD788\uBA74 \uAD50\uD68C\uAC00 \uACE0\uCE60 \uC904 \uC54C\uC558\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839309
    m_Localized: "\"\uC6B0\uB9AC \uB458 \uB2E4 \uC21C\uC9C4\uD588\uB124.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839310
    m_Localized: "\uC720\uB9AC\uAC00 \uB2EC\uBE5B\uC5D0 \uC6B8\uB9B0\uB2E4. \uB9D1\uC740
      \uC18C\uB9AC. \uC2AC\uD508 \uC18C\uB9AC."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839311
    m_Localized: "\"\uC21C\uC9C4\uD55C \uAC83\uACFC \uC633\uC740 \uAC83\uC740 \uB2E4\uB985\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839312
    m_Localized: "\"...\uADF8\uB798. \uADF8\uB798\uC57C\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839313
    m_Localized: "Pack Raider\uAC00 \uBCBD\uC744 \uBC1C\uD1B1\uC73C\uB85C \uAE01\uB294\uB2E4.
      \uB300\uB9AC\uC11D\uC5D0 \uB2E4\uC12F \uC904\uC758 \uC790\uAD6D\uC774 \uC0DD\uAE34\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839314
    m_Localized: "\"80\uB144\uC774\uC57C. 80\uB144 \uB3D9\uC548 \uC6B0\uB9AC \uB545
      \uBC11\uC744 \uD30C\uAC14\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839315
    m_Localized: "\"\uC0C8\uB07C\uB4E4\uC774 \uC11C\uB85C \uBB3C\uC5B4\uB72F\uB294
      \uB3D9\uC548, \uB108\uD76C\uB294 \uADF8\uAC78\uB85C \uBCBD\uB3CC\uC744 \uC313\uACE0
      \uC788\uC5C8\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839316
    m_Localized: "\"\uBD80\uC815\uD558\uC9C0 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839317
    m_Localized: "\"\uBD80\uC815 \uC548 \uD55C\uB2E4\uACE0? \uADF8\uAC8C \uBB50 \uB300\uB2E8\uD55C
      \uAC74 \uC904 \uC54C\uC544?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839318
    m_Localized: "Pack Raider\uC758 \uC190\uC774 \uB5A8\uB9B0\uB2E4. \uBD84\uB178\uC640
      \uC2AC\uD514\uC774 \uC11E\uC778 \uB5A8\uB9BC\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839319
    m_Localized: "\"\uC655\uAD6D\uC774 \uC800\uC9C0\uB978 \uC77C\uC758 \uBB34\uAC8C\uB97C
      \uC81C\uAC00 \uB300\uC2E0 \uC9C8 \uC218\uB294 \uC5C6\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uC678\uBA74\uD558\uC9C0\uB3C4 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839320
    m_Localized: "\"\uB9D0\uC740 \uC798 \uD558\uC2DC\uB124. \uD56D\uC0C1.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839321
    m_Localized: "Pack Raider\uAC00 \uD1A0\uD15C\uC744 \uD5C8\uB9AC\uC5D0\uC11C \uD480\uC5B4
      \uC55E\uC5D0 \uB193\uB294\uB2E4. \uBC18\uCABD\uC9DC\uB9AC \uC528\uC871\uC758
      \uD45C\uC2DD."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839322
    m_Localized: "\"\uC528\uC871 \uB9F9\uC138\uAC00 \uC544\uB2C8\uC57C. \uBC18\uCABD\uBC16\uC5D0
      \uC548 \uB0A8\uC558\uC73C\uB2C8\uAE4C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839323
    m_Localized: "\uADF8\uAC00 \uC774\uBE68\uC744 \uB4DC\uB7EC\uB0B8\uB2E4. \uC57C\uC218\uC871\uC758
      \uC11C\uC57D \uC790\uC138."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839324
    m_Localized: "\"\uB0B4 \uC774\uBE68\uB85C \uB9F9\uC138\uD55C\uB2E4. \uC5EC\uAE30\uC11C
      \uB05D\uB0B4\uACE0, \uB3CC\uC544\uAC00\uC11C, \uB0A8\uC740 \uC528\uC871\uC5D0\uAC8C
      \uC9C4\uC2E4\uC744 \uC804\uD55C\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839325
    m_Localized: '"Pack Raider..."'
    m_Metadata:
      m_Items: []
  - m_Id: 501683839326
    m_Localized: "\"\uB0B4 \uC774\uB984\uC740 \uC528\uC871\uC5D0\uC11C \uBC1B\uC740
      \uAC70\uC57C. \uBC18\uCABD\uC774 \uB5A8\uC5B4\uC838 \uB098\uAC14\uC9C0\uB9CC
      \uC774\uB984\uC740 \uB0B4\uAC00 \uC9C0\uD0A8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839327
    m_Localized: "\uC774\uBE68\uC774 \uBE5B\uC744 \uBC1B\uC544 \uBC88\uCA4D\uC778\uB2E4.
      \uC704\uD611\uC774 \uC544\uB2C8\uB77C \uC57D\uC18D\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839328
    m_Localized: "\"\uAF64 \uBA4B\uC9C0\uB124.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839329
    m_Localized: "\uC18C\uB098\uBB34 \uD55C \uADF8\uB8E8\uAC00 \uB2E4\uB978 \uB098\uBB34\uBCF4\uB2E4
      \uAE4A\uC774 \uC0C8\uACA8\uC838 \uC788\uB2E4. \uAC08\uD034 \uC790\uAD6D \uC704\uB85C
      \uC218\uC9C0\uAC00 \uAD73\uC5B4 \uD638\uBC15\uC0C9 \uC904\uC744 \uC774\uB8E8\uACE0
      \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839330
    m_Localized: "\"\uC774\uAC74 \uBB34\uAE30\uAC00 \uC544\uB2C8\uC57C. \uC0AC\uB0E5\uD130\uC758
      \uACBD\uACC4\uC774\uACE0, \uC0C8\uB07C\uB4E4\uC5D0\uAC8C \uB0A8\uAE30\uB294
      \uC57D\uC18D\uC774\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839331
    m_Localized: "\"\uC5B4\uB5A4 \uC57D\uC18D\uC785\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839332
    m_Localized: "\"\uC5EC\uAE30\uAE4C\uC9C0\uB294 \uC548\uC804\uD558\uB2E4. \uC5EC\uAE30\uC11C\uBD80\uD130\uB294
      \uB124 \uBC1C\uB85C \uC11C\uB77C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839333
    m_Localized: "Pack Raider\uAC00 \uB098\uBB34\uC5D0 \uC190\uC744 \uB304\uB2E4.
      \uC190\uBC14\uB2E5 \uC544\uB798\uC5D0\uC11C \uC9C4\uB3D9\uC774 \uC6B8\uB9B0\uB2E4.
      \uADF8\uC758 \uD45C\uC815\uC774 \uBCC0\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839334
    m_Localized: "\"\uD1A0\uD15C\uC774 \uBBF8\uCCD0 \uB0A0\uB6F0\uACE0 \uC788\uC5B4.
      \uC548\uC5D0\uC11C \uBB54\uAC00\uAC00 \uC6B8\uB824.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839335
    m_Localized: "\"\uC774 \uC9C4\uB3D9... \uC131\uBB3C\uD568 \uC548\uC758 \uC720\uBB3C\uACFC
      \uAC19\uC740 \uD30C\uC7A5\uC785\uB2C8\uB2E4. \uAC19\uC740 \uBB3C\uC9C8\uC774\uB780
      \uB9D0\uC785\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839336
    m_Localized: "\"\uB108\uD76C\uAC00 \uD6D4\uCCD0\uAC04 \uAC83\uC758 \uBB34\uAC8C\uB97C
      \uC774\uB188\uC774 \uAE30\uC5B5\uD558\uACE0 \uC788\uB294 \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839337
    m_Localized: "\uD1A0\uD15C\uC758 \uC9C4\uB3D9\uC774 \uBC1C\uBC11\uC73C\uB85C
      \uC804\uD574\uC9C4\uB2E4. \uC544\uB798\uB85C. \uB354 \uC544\uB798\uB85C. \uBB34\uC5B8\uAC00\uC640
      \uACF5\uBA85\uD558\uB4EF."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839338
    m_Localized: "\"...\uAE30\uB85D\uC744 \uC218\uC815\uD574\uC57C\uACA0\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839339
    m_Localized: "\uACA9\uC790\uBB38\uC774 \uD478\uB978 \uBE5B\uC73C\uB85C \uD0C0\uC624\uB978\uB2E4.
      \uC11D\uD654 \uB098\uBB34 \uC0AC\uC774\uC5D0\uC11C \uD55C \uC874\uC7AC\uAC00
      \uCC9C\uCC9C\uD788 \uC77C\uC5B4\uC120\uB2E4. \uAD00\uC808\uC774 \uC6C0\uC9C1\uC77C
      \uB54C\uB9C8\uB2E4 \uB3CC \uBD80\uC2A4\uB7EC\uAE30\uAC00 \uB5A8\uC5B4\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839340
    m_Localized: "\"...\uC2DC\uB044\uB7FD\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839341
    m_Localized: "\"...\uC5EC\uAE30\uAC00 \uC5B4\uB514\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839342
    m_Localized: "\"\uAE34 \uC598\uAE30\uC57C. \uC549\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839343
    m_Localized: "Echo Savant\uAC00 \uC549\uC9C0 \uC54A\uB294\uB2E4. \uC11C \uC788\uB2E4.
      \uB2E4\uB9AC\uAC00 \uB5A8\uB9AC\uC9C0\uB9CC."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839344
    m_Localized: "\"\uBF08\uAC00 \uC6B8\uB9B0\uB2E4. \uACA9\uC790\uAC00... \uB2F3\uC558\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839345
    m_Localized: "\uADF8\uC758 \uCCAB \uB9C8\uB514. 1800\uB144 \uB9CC\uC5D0. \uB208\uC774
      \uCD08\uC810\uC744 \uBABB \uC7A1\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501683839346
    m_Localized: "\"\uBD09\uC778\uC758 \uC218\uD638\uC790\uAC00... \uC0B4\uC544 \uC788\uC5C8\uC2B5\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501683839347
    m_Localized: "\"\uC0C8 \uB0C4\uC0C8\uC57C. \uBC14\uB78C\uC5D0\uB3C4 \uC5C6\uB358
      \uC885\uB958.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033280
    m_Localized: "\"\uC5B4\uBA38\uB098. \uACA9\uC790 \uC548\uC5D0\uC11C \uC9C4\uC9DC\uB85C
      \uB204\uAC00 \uB098\uC654\uB124.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033281
    m_Localized: "\"\uBA38\uB9AC\uAC00... \uC6B8\uB9B0\uB2E4. \uC774 \uC18C\uB9AC\uAC00
      \uBB50\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033282
    m_Localized: "Echo Savant\uAC00 \uC190\uC744 \uB4E4\uC5B4 \uC62C\uB9B0\uB2E4.
      \uCC9C\uCC9C\uD788. \uC790\uAE30 \uC190\uC744 \uBCF4\uB294 \uAC83 \u2014 1800\uB144
      \uC804\uC5D0 \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uBCF8 \uC190\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033283
    m_Localized: "\"\uC6B0\uB9AC\uAC00 \uCE68\uB7B5\uC790\uB77C \uBD80\uB978 \uC874\uC7AC\uAC00...
      \uC774 \uC138\uACC4\uB97C \uC9C0\uD0A4\uACE0 \uC788\uC5C8\uB2E4\uB2C8.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033284
    m_Localized: "\"1800\uB144 \uB3D9\uC548 \uC790\uACE0 \uC77C\uC5B4\uB0AC\uC73C\uB2C8
      \uCEE8\uB514\uC158\uC774 \uC880 \uADF8\uB807\uACA0\uB124.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033285
    m_Localized: "\uC11D\uAD00\uC774 \uCE35\uCE35\uC774 \uC313\uC5EC \uC788\uB2E4.
      \uC778\uAD11 \uC774\uB07C\uAC00 \uD1B5\uB85C\uB97C \uD76C\uBBF8\uD558\uAC8C
      \uBC1D\uD78C\uB2E4. \uACF5\uAE30\uAC00 \uCC28\uAC11\uACE0 \uCD95\uCD95\uD558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033286
    m_Localized: "\"\uC8FD\uC74C\uC758 \uB545\uC774\uB77C \uB4E4\uC5C8\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033287
    m_Localized: "\"\uC774 \uBE5B\uC740... \uC8FD\uC74C\uBCF4\uB2E4\uB294 \uAE30\uB2E4\uB9BC\uC5D0
      \uAC00\uAE5D\uAD70\uC694.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033288
    m_Localized: "\"\uB9DE\uC544. \uAE30\uB2E4\uB9BC\uC774\uC57C. \uAF64 \uC624\uB798\uB41C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033289
    m_Localized: "\uC5B4\uB460 \uC18D\uC5D0\uC11C \uBC1C\uC18C\uB9AC. \uB290\uB9BF\uD558\uACE0
      \uC870\uC2EC\uC131 \uC5C6\uB294 \uAC78\uC74C. \uB204\uAD70\uAC00\uAC00 \uAC78\uC5B4
      \uB098\uC628\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033290
    m_Localized: "\"\uC5B4, \uC190\uB2D8\uC774\uB124. \uC624\uB798\uAC04\uB9CC\uC774\uC57C.
      \uD55C 300\uB144? 400\uB144? ...\uBB50, \uC0C1\uAD00\uC5C6\uC9C0\uB9CC.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033291
    m_Localized: "\"\uC8FD\uC740 \uAC83\uC774 \uAC78\uC5B4. \uCF54\uC5D0 \uC544\uBB34
      \uB0C4\uC0C8\uB3C4 \uC548 \uC640.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033292
    m_Localized: "\"\uB0C4\uC0C8\uAC00 \uC548 \uB098\uBA74 \uC704\uD5D8\uD558\uB2E4\uACE0
      \uD588\uC9C0? \uC88B\uC740 \uCF54\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033293
    m_Localized: "\"\uB2F9\uC2E0\uC740 \uB204\uAD6C\uC2ED\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033294
    m_Localized: "\"\uAE30\uC5B5 \uAD00\uB9AC\uC790. \uC5EC\uAE30 \uC788\uB294 \uC18D\uC0AD\uC784
      \uB4E4\uB824? \uACF5\uACA9\uC774 \uC544\uB2C8\uC57C. \uC7A0\uB4E0 \uAE30\uC5B5\uC774
      \uC190\uB2D8\uC744 \uB9DE\uC774\uD558\uB294 \uAC70\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033295
    m_Localized: "\uBCBD \uD2C8\uC5D0\uC11C \uD76C\uBBF8\uD55C \uBE5B\uC774 \uB9E5\uB3D9\uD55C\uB2E4.
      \uC18D\uC0AD\uC784\uCC98\uB7FC."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033296
    m_Localized: "\"\uC880 \uC2DC\uB044\uB7FD\uAE34 \uD55C\uB370. \uC218\uBC31 \uB144
      \uB9CC\uC758 \uC190\uB2D8\uC774\uB77C \uD765\uBD84\uD55C \uBAA8\uC591\uC774\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033297
    m_Localized: "Aldric\uC758 \uD615\uC0C1\uC774 \uD769\uC5B4\uC9C4\uB2E4. \uBD84\uB178\uB3C4
      \uC6D0\uD55C\uB3C4 \uC544\uB2CC, \uADF8\uC800 \uC0AC\uB77C\uC9C0\uB294 \uD55C
      \uB0A8\uC790\uC758 \uD45C\uC815."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033298
    m_Localized: "\uACA9\uC790\uAC00 \uBC18\uC751\uD55C\uB2E4. \uC815\uD654\uC758
      \uC21C\uC11C\uAC00 \uC2DC\uC791\uB41C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033299
    m_Localized: "\uACA9\uC790\uAC00 \uADF8\uB97C \uAC10\uC2FC\uB2E4. \uD504\uB9AC\uC998
      \uBCF4\uB77C\uBE5B\uC774 \uB9E5\uB3D9\uD558\uAE30 \uC2DC\uC791\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033300
    m_Localized: '"Echo Savant..."'
    m_Metadata:
      m_Items: []
  - m_Id: 501688033301
    m_Localized: "\"\uC798 \uAC78\uC5B4\uB77C. \uC704\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033302
    m_Localized: "\uBE5B\uC774 \uAC15\uD574\uC9C4\uB2E4. Heartforge\uAC00 \uBA48\uCD98\uB2E4.
      \uC2EC\uC7A5\uC774 \uB6F0\uC9C0 \uC54A\uB294\uB2E4. \uACE0\uC694."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033303
    m_Localized: "\"\uC2DC\uC791\uD569\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033304
    m_Localized: "Dawn Priest\uC758 \uC190\uC5D0\uC11C \uBE5B\uC774 \uB09C\uB2E4.
      \uC0AC\uC81C\uC758 \uBE5B\uC774 \uC544\uB2C8\uB2E4. \uADF8\uB140 \uC790\uC2E0\uC758
      \uBE5B\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033305
    m_Localized: "Grave Hexer\uAC00 \uBE48 \uC190\uC744 \uB4E4\uC5B4\uC62C\uB9B0\uB2E4.
      \uC544\uAE4C \uB193\uC740 \uAD6C\uC2AC\uC774 \uC788\uB358 \uC790\uB9AC."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033306
    m_Localized: "\"...\uB05D\uB0AC\uC5B4. \uB1A8\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033307
    m_Localized: "Pack Raider\uAC00 \uC774\uBE68\uC744 \uB4DC\uB7EC\uB0B8\uB2E4.
      \uC11C\uC57D \uC790\uC138. \uC6B8\uBD80\uC9D6\uC9C0 \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033308
    m_Localized: "\"\uB3CC\uC544\uAC00\uBA74 \uB0A8\uC740 \uC528\uC871\uC5D0\uAC8C
      \uC804\uD55C\uB2E4. \uC804\uBD80.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033309
    m_Localized: "Echo Savant\uAC00 \uACA9\uC790\uC758 \uC911\uC2EC\uC73C\uB85C \uAC78\uC5B4\uAC04\uB2E4.
      \uB290\uB9AC\uAC8C. \uD55C \uAC78\uC74C\uC529."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033310
    m_Localized: "\"\uAD1C\uCC2E\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033311
    m_Localized: "Echo Savant\uAC00 \uC77C\uC5B4\uC120\uB2E4. \uC774\uBC88\uC5D0\uB294
      \uB2E4\uB9AC\uAC00 \uB5A8\uB9AC\uC9C0 \uC54A\uB294\uB2E4. \uB208\uC5D0 \uCD08\uC810\uC774
      \uC7A1\uD78C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033312
    m_Localized: "\"\uC2EC\uC7A5\uC774 \uAE30\uC5B5\uC744 \uBA39\uACE0 \uC788\uB2E4.
      \uBC49\uC5B4\uB0B4\uB294 \uAC83\uC740 \uBD84\uB178.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033313
    m_Localized: "\"\uB124 \uACF5\uBA85\uACFC \uB0B4 \uAE30\uC5B5\uC774 \uAC19\uC740
      \uD30C\uC7A5\uC774\uAD70. 1800\uB144\uC744 \uC0AC\uC774\uC5D0 \uB450\uACE0.
      \uC7AC\uBC0C\uB124.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033314
    m_Localized: "\"\uACA9\uC790\uAC00 \uB2F3\uC558\uB2E4. \uBD84\uB178\uAC00 \uC0C8\uC5B4\uB098\uC628\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033315
    m_Localized: "\"\uC6B0\uB9AC \uBAA8\uB450\uAC00... \uC870\uC885\uB2F9\uD55C \uAC81\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033316
    m_Localized: "\"\uC870\uC885\uC774 \uC544\uB2C8\uB2E4. \uB204\uC218\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033317
    m_Localized: "\"\uB204\uC218\uB4E0 \uC870\uC885\uC774\uB4E0. \uD615\uC81C\uAC00
      \uBBF8\uCCD0 \uC8FD\uC740 \uAC74 \uB611\uAC19\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033318
    m_Localized: "Echo Savant\uAC00 Pack Raider\uB97C \uBCF8\uB2E4. \uC624\uB798.
      \uB300\uB2F5\uD558\uC9C0 \uC54A\uB294\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033319
    m_Localized: "\"...\uBBF8\uC548\uD558\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033320
    m_Localized: "\"\uB124\uAC00 \uD55C \uC9D3\uC774 \uC544\uB2C8\uC796\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033321
    m_Localized: "Echo Savant\uAC00 \uBC14\uB2E5\uC5D0 \uC190\uC744 \uB304\uB2E4.
      \uB208\uC744 \uAC10\uB294\uB2E4. \uD504\uB9AC\uC998 \uBCF4\uB77C\uBE5B\uC774
      \uC190\uB05D\uC5D0\uC11C \uD37C\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033322
    m_Localized: "\"\uACA9\uC790\uAC00... \uBE44\uBA85\uC744 \uC9C0\uB974\uACE0 \uC788\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033323
    m_Localized: "\"\uC704\uD5D8\uD55C \uAC81\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033324
    m_Localized: "\"\uC704\uD5D8\uD558\uC9C0 \uC54A\uC740 \uAC83\uC774 \uC5C6\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033325
    m_Localized: "\"1800\uB144 \uC790\uACE0 \uC77C\uC5B4\uB098\uC11C \uAE0D\uC815\uC801\uC774\uBA74
      \uC624\uD788\uB824 \uBB34\uC11C\uC6B8 \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033326
    m_Localized: "Echo Savant\uC758 \uBAB8\uC774 \uBBF8\uC138\uD558\uAC8C \uB5A8\uB9B0\uB2E4.
      \uACA9\uC790\uC640 \uB3D9\uAE30\uD654\uB418\uB294 \uC911\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033327
    m_Localized: "\"\uAC08 \uC218 \uC788\uB2E4. \uC544\uB798\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033328
    m_Localized: "\"\uADF8\uB7FC \uAC00\uC790. \uC5EC\uAE30 \uB354 \uC788\uC73C\uBA74
      \uC720\uB9AC\uAC00 \uB420 \uAC83 \uAC19\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033329
    m_Localized: "\uACA9\uC790\uC758 \uC911\uC2EC\uC774 \uBCF4\uC778\uB2E4. \uBE48\uC790\uB9AC.
      \uC218\uD638\uC790\uAC00 \uB4E4\uC5B4\uAC08 \uC790\uB9AC."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033330
    m_Localized: "\"\uC5EC\uAE30\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033331
    m_Localized: "\"\uC815\uB9D0\uB85C... \uB2E4\uB978 \uBC29\uBC95\uC740 \uC5C6\uC2B5\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033332
    m_Localized: "\"\uC5C6\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033333
    m_Localized: "\"\uB124\uAC00 \uC548 \uB4E4\uC5B4\uAC00\uBA74 \uC548 \uB418\uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033334
    m_Localized: "\"\uACA9\uC790\uB97C \uC77D\uC744 \uC218 \uC788\uB294 \uAC83\uC740
      \uB098\uBFD0\uC774\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033335
    m_Localized: "\uC0AC\uC2E4\uC774\uB2E4. \uC544\uBB34\uB3C4 \uBC18\uBC15\uD558\uC9C0
      \uBABB\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033336
    m_Localized: "\"\uC758\uBB34\uAC00 \uC544\uB2C8\uB2E4. \uC120\uD0DD\uC774\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033337
    m_Localized: "\uC6B8\uD0C0\uB9AC\uAC00 \uC788\uB2E4. \uC720\uB9AC\uAC00 \uC544\uB2C8\uB77C
      \uBF08\uB85C \uB9CC\uB4E0 \uC6B8\uD0C0\uB9AC. \uC548\uC5D0\uC11C \uC6C0\uC9C1\uC774\uB294
      \uAC83\uB4E4\uC774 \uBCF4\uC778\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033338
    m_Localized: "\"\uC774\uAC74... \uC57C\uC218\uAC00 \uC544\uB2C8\uC57C. \uC57C\uC218\uC600\uB358
      \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033339
    m_Localized: "\uBCC0\uC774\uB41C \uC0DD\uBB3C\uB4E4\uC774 \uC6B8\uD0C0\uB9AC
      \uC548\uC744 \uBC30\uD68C\uD55C\uB2E4. \uB208\uC774 \uC5C6\uB2E4. \uADC0\uB9CC
      \uB0A8\uC544 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033340
    m_Localized: "\"\uACA9\uC790 \uC624\uC5FC\uC774 \uC774 \uC815\uB3C4\uAE4C\uC9C0...\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033341
    m_Localized: "\"\uB3D9\uBB3C\uC6D0\uC774\uB77C\uAE30\uBCF4\uB2E4 \uAC10\uC625\uC774\uC57C.
      \uC2A4\uC2A4\uB85C \uB4E4\uC5B4\uC628 \uAC10\uC625.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033342
    m_Localized: "\"\uC6B8\uC74C\uC18C\uB9AC\uAC00 \uC548 \uB098. \uC6B8 \uC904\uB3C4
      \uC78A\uC740 \uAC70\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033343
    m_Localized: "\"\uACA9\uC790\uAC00 \uC0DD\uBA85\uC744 \uBE44\uD2C0\uC5C8\uB2E4.
      \uC624\uB798 \uBC29\uCE58\uB41C \uACF3\uC774\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033344
    m_Localized: "Pack Raider\uAC00 \uC6B8\uD0C0\uB9AC\uC5D0 \uC190\uC744 \uB304\uB2E4.
      \uC548\uC758 \uC0DD\uBB3C\uC774 \uB2E4\uAC00\uC628\uB2E4 \u2014 \uC801\uB300\uAC00
      \uC544\uB2C8\uB77C, \uAE30\uC5B5\uD558\uB294 \uAC83\uCC98\uB7FC."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033345
    m_Localized: "\"...\uD615\uC81C\uC758 \uC0AC\uB0E5\uAC1C\uB791 \uAC19\uC740 \uB0C4\uC0C8\uAC00
      \uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033346
    m_Localized: "\"\uB05D\uB0B4\uC57C \uD569\uB2C8\uB2E4. \uC774 \uACE0\uD1B5\uC744.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033347
    m_Localized: "\uB300\uB9AC\uC11D \uAE30\uB465\uC774 \uBE44\uC2A4\uB4EC\uD788
      \uC11C \uC788\uB2E4. \uBB3C\uC774 \uBCF5\uB3C4\uB97C \uBC1C\uBAA9\uAE4C\uC9C0
      \uCC44\uC6B0\uACE0 \uC788\uACE0, \uBCBD\uC758 \uBB38\uC591\uC774 \uBC18\uCBE4
      \uBB3C\uC5D0 \uC7A0\uACA8 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033348
    m_Localized: "\"\uC774 \uC591\uC2DD\uC740... \uC81C\uAC00 \uC218\uB828\uBC1B\uB358
      \uACF3\uACFC \uAC19\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033349
    m_Localized: "\"...\uC548\uC73C\uB85C \uB4E4\uC5B4\uAC11\uB2C8\uB2E4. \uC5EC\uAE30\uC11C
      \uBB34\uC2A8 \uC77C\uC774 \uC788\uC5C8\uB294\uC9C0 \uC54C\uC544\uC57C \uD569\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033350
    m_Localized: "\uB450 \uC0AC\uB78C\uC774 \uAE30\uC6B8\uC5B4\uC9C4 \uBCF5\uB3C4\uB97C
      \uAC77\uB294\uB2E4. \uBB3C\uC774 \uD55C\uCABD\uC73C\uB85C \uD750\uB974\uACE0,
      \uADF8\uB4E4\uC758 \uBC1C\uC18C\uB9AC\uAC00 \uC6B8\uB9B0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033351
    m_Localized: "\uADF8\uB140\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uAC00\uB77C\uC549\uB294\uB2E4.
      \uAE30\uB465\uC774 \uAE30\uC6B8\uC5B4\uC9C4 \uAC01\uB3C4\uB97C \uBCF4\uACE0
      \uC788\uB2E4 \u2014 \uAD6C\uC870\uAC00 \uC544\uB2C8\uB77C \uC0C1\uC9D5\uC744
      \uC77D\uB294 \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033352
    m_Localized: "\"\uC9C8\uC11C\uAC00... \uAC00\uB77C\uC549\uACE0 \uC788\uC2B5\uB2C8\uB2E4.
      \uBB3C\uB9AC\uC801\uC73C\uB85C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033353
    m_Localized: "\"\uC790\uAE30\uAC00 \uC9C0\uC740 \uAC83\uB3C4 \uBABB \uC9C0\uD0A4\uB294\uAD70.
      \uB3CC\uB2F4\uC774 \uBB3C\uC5D0 \uBE60\uC9C0\uB294 \uAF34\uC774\uB77C\uB2C8.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033354
    m_Localized: "Pack Raider\uAC00 \uBB3C\uC18D\uC5D0 \uBC1C\uC744 \uB2F4\uADFC\uB2E4.
      \uBC14\uB2E5\uC5D0 \uB179\uC2A8 \uBB34\uAE30\uAC00 \uC7A0\uACA8 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033355
    m_Localized: "\"\uB179 \uB0C4\uC0C8. \uC624\uB798\uB41C \uD53C \uB0C4\uC0C8.
      \uC5EC\uAE30\uC11C \uC790\uAE30\uB4E4\uB07C\uB9AC \uC2F8\uC6E0\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033356
    m_Localized: "\"\uAC19\uC740 \uC9C8\uC11C\uC758 \uC2E0\uB3C4\uB07C\uB9AC \uCE7C\uC744
      \uACA8\uB234\uB2E4\uB294 \uAC81\uB2C8\uAE4C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033357
    m_Localized: "\uBB3C \uC704\uB85C \uAE30\uB984 \uB9C9\uC774 \uBC88\uC9C4\uB2E4.
      \uC0C9\uC774 \uC774\uC0C1\uD558\uB2E4 \u2014 \uBB34\uC9C0\uAC1C\uAC00 \uC544\uB2C8\uB77C,
      \uACA9\uC790 \uD30C\uD3B8\uC774 \uB179\uC544\uB0B4\uB9B0 \uC0C9\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033358
    m_Localized: "\"\uADF8\uB7EC\uAC8C. \uC9C8\uC11C\uB77C\uB294 \uAC8C \uC6D0\uB798
      \uC774\uB7F0 \uB9DB\uC774\uC57C?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033359
    m_Localized: "\uD3EC\uC7A5 \uB3C4\uB85C \uC591\uD3B8\uC5D0 \uCC98\uD615\uB300\uC640
      \uACE0\uD574\uC18C\uAC00 \uBC88\uAC08\uC544 \uC11C \uC788\uB2E4. \uB3CC\uBC14\uB2E5\uC5D0
      \uAC80\uC740 \uC5BC\uB8E9\uC774 \uADDC\uCE59\uC801\uC73C\uB85C \uCC0D\uD600
      \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033360
    m_Localized: "\"\uC815\uD654 \uC7AC\uD310\uC758 \uD604\uC7A5\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033361
    m_Localized: "\"\uC548\uC0C9\uC774 \uC88B\uC744 \uC218\uAC00 \uC5C6\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033362
    m_Localized: "\uBC14\uB78C\uC774 \uB3C4\uB85C\uB97C \uB530\uB77C \uBD84\uB2E4.
      \uC7AC\uAC00 \uC544\uB2C8\uB77C \uBA3C\uC9C0\uB2E4. \uC624\uB798\uB41C \uBA3C\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033363
    m_Localized: "\"\uC790\uAE30 \uB3D9\uC871\uD55C\uD14C\uB3C4 \uC774\uB7F0 \uC9D3\uC744?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033364
    m_Localized: "Pack Raider\uAC00 \uCC98\uD615\uB300 \uC704\uC758 \uC1E0\uACE0\uB9AC\uB97C
      \uB9CC\uC9C4\uB2E4. \uC190\uAC00\uB77D \uD06C\uAE30\uC5D0 \uB9DE\uAC8C \uB2F3\uC544
      \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033365
    m_Localized: "\"\uC9D0\uC2B9\uC740 \uCD5C\uC18C\uD55C \uBA39\uC73C\uB824\uACE0
      \uC8FD\uC774\uAE30\uB77C\uB3C4 \uD558\uC9C0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033366
    m_Localized: "\"\uC815\uD654\uB77C\uB294 \uC774\uB984\uC73C\uB85C \uD589\uD574\uC9C4
      \uC77C\uB4E4\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033367
    m_Localized: "\uBC14\uB2E5\uC5D0 \uAE68\uC9C4 \uC131\uBB3C\uD568\uC774 \uC788\uB2E4.
      \uC548\uC774 \uBE44\uC5B4 \uC788\uB2E4 \u2014 \uC6D0\uB798\uBD80\uD130 \uBE44\uC5B4
      \uC788\uC5C8\uB358 \uAC83\uCC98\uB7FC."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033368
    m_Localized: "\"\uBE48 \uC131\uBB3C\uD568 \uC704\uC5D0 \uD53C\uB97C \uBFCC\uB838\uC2B5\uB2C8\uB2E4.
      \uC774\uAC83\uC744 \uCD95\uBCF5\uC774\uB77C \uBD88\uB800\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033369
    m_Localized: "Dawn Priest\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uD754\uB4E4\uB9B0\uB2E4.
      \uCC98\uC74C\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033370
    m_Localized: "\"...\uC0AC\uC81C. \uC548\uC0C9\uC774 \uC548 \uC88B\uC544.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033371
    m_Localized: "\uC18C\uB098\uBB34 \uAECD\uC9C8\uC5D0 \uAC08\uD034 \uC790\uAD6D\uC774
      \uAE4A\uAC8C \uD30C\uC5EC \uC788\uB2E4. \uB2E4\uC12F \uAC1C. \uC190\uD1B1\uC774
      \uC544\uB2C8\uB77C \uBC1C\uD1B1\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033372
    m_Localized: "\"\uC57C\uC218\uC871\uC758 \uC601\uC5ED \uD45C\uC2DD\uC785\uB2C8\uB2E4.
      \uACBD\uACC4\uB97C \uB2A6\uCD94\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033373
    m_Localized: "\"\uACBD\uACE0\uAC00 \uC544\uB2C8\uC57C. \uBC14\uB78C\uC5D0\uAC8C
      \uC62C\uB9AC\uB294 \uAE30\uB3C4\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033374
    m_Localized: "\uC548\uAC1C \uC0AC\uC774\uB85C \uB178\uB780 \uB208\uC774 \uBC18\uC9DD\uC778\uB2E4.
      \uD558\uB098, \uB458, \uC14B \u2014 \uB208\uC744 \uAE5C\uBE61\uC774\uBA74 \uC0AC\uB77C\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033375
    m_Localized: "\"\uC6C0\uC9C1\uC774\uC9C0 \uB9C8\uC2ED\uC2DC\uC624. \uD3EC\uC704
      \uC9D5\uD6C4\uAC00 \uBCF4\uC785\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033376
    m_Localized: "\"\uD3EC\uC704\uAC00 \uC544\uB2C8\uC57C. \uAD6C\uACBD\uD558\uB294
      \uAC70\uC57C. \uB108\uD76C\uAC00 \uC5BC\uB9C8\uB098 \uC2DC\uB044\uB7EC\uC6B4\uC9C0\uB97C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033377
    m_Localized: "Pack Raider\uAC00 \uCF54\uB97C \uB4E4\uC5B4\uC62C\uB9B0\uB2E4.
      \uC194\uC78E \uC544\uB798\uB85C \uC816\uC740 \uD759\uACFC \uD138 \uB0C4\uC0C8\uAC00
      \uACB9\uCE5C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033378
    m_Localized: "\"\uC0C8\uB07C\uB4E4\uC774 \uAC00\uAE4C\uC774 \uC788\uC5B4. \uC5EC\uAE30\uC11C\uBD80\uD134
      \uB124 \uC2DD\uB300\uB85C \uD558\uBA74 \uC548 \uB3FC.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033379
    m_Localized: "\"\uB2F9\uC2E0\uC758 \uC601\uC5ED\uC774\uB77C\uB294 \uAC83\uC740
      \uC778\uC815\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uC6B0\uB9AC\uC758 \uBA85\uBD84\uC740
      \uBCC0\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033380
    m_Localized: "\"\uBA85\uBD84. \uC88B\uC740 \uB0C4\uC0C8\uAC00 \uB098\uB294 \uB2E8\uC5B4\uC57C.
      \uC232\uC5D0\uC120 \uB0C4\uC0C8\uAC00 \uC548 \uB098\uB294 \uAC83\uB9CC \uC704\uD5D8\uD558\uAC70\uB4E0.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033381
    m_Localized: "\uBCBD\uBA74\uC774 \uBE5B\uB098\uACE0 \uC788\uB2E4. 3000\uB144\uC758
      \uAE30\uC5B5\uC774 \uC9C0\uCE35\uCC98\uB7FC \uC313\uC5EC \uC788\uB2E4. \uAC78\uC744\uC218\uB85D
      \uC2DC\uB300\uAC00 \uAE4A\uC5B4\uC9C4\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033382
    m_Localized: "\"\uC774\uAC74... \uB0B4 \uAE30\uC5B5 \uBCF4\uAD00\uC18C\uBCF4\uB2E4
      \uD06C\uB124. \uD6E8\uC52C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033383
    m_Localized: "\"\uADF8\uB798. \uBD80\uC218\uB294 \uAC74 \uB2F5\uC774 \uC544\uB2C8\uC57C.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033384
    m_Localized: "\uC544\uB798\uC5D0\uC11C \uB9E5\uB3D9\uC774 \uAC15\uD574\uC9C4\uB2E4.
      \uC2EC\uC7A5\uC5D0 \uAC00\uAE4C\uC6CC\uC9C0\uACE0 \uC788\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033385
    m_Localized: "\"\uB9E8 \uC544\uB798 \uCE35\uC5D0 Aldric\uC758 \uC2DC\uB300\uAC00
      \uC788\uC744 \uAC81\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033386
    m_Localized: "\uBCBD\uC5D0 \uC804\uD22C \uC7A5\uBA74\uC774 \uC7AC\uC0DD\uB41C\uB2E4.
      \uC624\uB798\uB41C \uAC83\uBD80\uD130. \uCCAB \uC804\uC7C1, \uBD09\uC778, \uAE34
      \uD3C9\uD654, \uADF8\uB9AC\uACE0 \uD48D\uD654."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033387
    m_Localized: "\"\uC57C\uC218\uC871\uC774 \uBCF4\uC5EC. \uC61B\uB0A0 \uC57C\uC218\uC871.
      \uBB34\uAE30\uAC00 \uC5C6\uC5B4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033388
    m_Localized: "\"\uB098\uB3C4 \uBCF4\uC778\uB2E4. 1800\uB144 \uC804\uC758 \uB098.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033389
    m_Localized: "Echo Savant\uAC00 \uBCBD\uC5D0 \uC190\uC744 \uB304\uB2E4. \uC790\uC2E0\uC758
      \uACFC\uAC70\uC640 \uB9C8\uC8FC\uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 501688033390
    m_Localized: "\"\uAE30\uBD84 \uC774\uC0C1\uD558\uC9C0?\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033391
    m_Localized: "\"\uC774\uC0C1\uD55C \uAC8C \uC544\uB2C8\uB2E4. \uC544\uD504\uB2E4.\""
    m_Metadata:
      m_Items: []
  - m_Id: 501688033392
    m_Localized: "\"\uBAA8\uB450\uC758 \uAE30\uC5B5\uC785\uB2C8\uB2E4. \uC774\uAC83\uC744
      \uC9C0\uCF1C\uC57C \uD569\uB2C8\uB2E4.\""
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
